{
  "annotations": { "list": [] },
  "description": "Cost, tokens, retries, and node duration for iterion workflows. Requires the OTLP exporter to be configured with NodeID, Cost, Tokens, Model, and DurationMS attributes (see iterion docs/observability/README.md).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "title": "Cost per node (USD)",
      "type": "barchart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (node_id) (iterion_node_cost_usd_total)",
          "legendFormat": "{{node_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 2,
      "title": "Tokens per model",
      "type": "barchart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (model) (iterion_node_tokens_total)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Retry rate",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(iterion_llm_retry_total[5m])) / sum(rate(iterion_llm_request_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 4,
      "title": "Node duration (p50/p95/p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(iterion_node_duration_ms_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(iterion_node_duration_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(iterion_node_duration_ms_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 5,
      "title": "Parallel branches in flight",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "max_over_time(iterion_parallel_branches[5m])",
          "legendFormat": "branches",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Cost per run (top 10)",
      "type": "table",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (run_id) (iterion_node_cost_usd_total))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "id": 7,
      "title": "Tool calls (per tool)",
      "type": "barchart",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (tool) (rate(iterion_tool_call_total[15m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["iterion", "workflow", "claw-code-go"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Iterion Workflow",
  "uid": "iterion-workflow",
  "version": 1,
  "weekStart": ""
}
