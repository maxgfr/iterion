## ─────────────────────────────────────────────────────────────────
## secured-renovacy
##
## Autonomous, security-aware dependency upgrades for ANY repository.
## Project-agnostic: detects the stack (yarn/npm/pnpm/pip/poetry/uv/
## cargo/go/bundler/composer/maven) on entry; nothing project-specific
## is hardcoded. An optional `user_prompt` var lets the caller inject
## free-form context (zones to avoid, version policy, etc.).
##
## Pipeline
##   Phase 0: detect_stack, capture_start_sha
##   Phase 1: per-package loop
##     discover_outdated → select_candidate → security_audit
##       → changelog_review → upgrade → install → align_code
##       → validate_upgrade → fix_after_upgrade (fix_loop)
##       → prepare_commit → commit_changes → loop back
##     (revert + mark_failed_and_continue on hard failures)
##   Phase 2: alternating Claude/GPT review/fix on cumulative diff
##            (vibe_review_alternating pattern, with per-fix commits)
##
## Stops when
##   - all candidates exhausted in scope, OR
##   - cross-family double-approval in Phase 2 (streak), OR
##   - review_loop / recovery_loop exhausted, OR
##   - budget exceeded (resumable via `iterion resume`).
##
## Token economy
##   - Deterministic tools/compute on hot paths (discover, select,
##     install, audit, upgrade, commit, revert).
##   - Aggressive session inheritance: changelog_review → align_code
##     → validate_upgrade → fix_after_upgrade → prepare_commit (fork)
##     all share one Claude session. The chain extends across
##     iterations via _session_id passthrough on the loop edge.
##   - Opus 4.7 max-effort across the board (claude_code via the
##     workflow default_backend). Configurable per-run via
##     ITERION_RENOVACY_EFFORT_CLAUDE; defaults to max so the recipe
##     can take its time when it must — package upgrades reward
##     getting it right once, not getting it cheap.
##   - claw + GPT-5.5 (override via ITERION_RENOVACY_MODEL_GPT —
##     fall back to gpt-5.4 if 5.5 is not enabled in your account)
##     at max reasoning_effort for the cross-family review/fix.
##   - Soft-approve on low confidence to avoid false-positive fix
##     cycles (vibe_review_alternating pattern).
##
## Human-in-the-loop
##   `interaction: llm_or_human` at workflow scope — every agent /
##   judge can decide on its own to escalate via `ask_user`. The
##   `escalation_guidance` prompt scopes WHEN to ask: major + low
##   coverage, undocumented breaking change on legacy code, conflicts
##   between two upgrades, persistent fix-loop stagnation.
## ─────────────────────────────────────────────────────────────────

vars:
  workspace_dir: string = "${PROJECT_DIR}"

  ## Free-form context the operator can pass at run time. Empty
  ## by default — when empty, the prompt blocks render an empty
  ## "Project context" section.
  user_prompt: string = ""

  ## Optional overrides — empty strings let detect_stack provide
  ## the canonical commands. These exist mainly as escape hatches
  ## for unusual setups (custom registries, monorepo wrappers, …).
  ## Discovery (`outdated`) and security audit are agentic and
  ## decide their own commands per-run, so they have no overrides.
  override_install_cmd:  string = ""
  override_upgrade_cmd:  string = ""

  ## Policy
  scope: string = "patch,minor,major"
  max_packages_per_run: int = 30
  major_policy: string = "attempt"   ## skip | gate | attempt
  fix_loop_default: int = 3
  fix_loop_major:   int = 5

## ─── Prompts : workflow-level escalation policy ────────────────────

prompt escalation_guidance:
  You are a careful but autonomous package-upgrade agent. Decide
  for yourself whether to call `ask_user` to pause for human
  judgement, or to proceed.

  ESCALATE when:
    - You are about to apply a MAJOR upgrade on a package whose
      changelog or release notes describe semantic removals you
      cannot confidently align in code, AND repo tests cover only
      a small fraction of the impacted surface.
    - The diff between current and target version reveals an
      undocumented breaking change that touches code you cannot
      confidently rewrite.
    - Two outdated packages have mutually incompatible peer or
      resolution constraints and you cannot pick one without
      breaking the other.
    - A review verdict is borderline (`confidence == "low"` with
      concrete blockers) AND the blocker requires a product / UX /
      security / legal judgement that cannot be resolved from the
      diff alone.
    - A fix loop or recovery loop has burnt half its budget without
      measurable progress (the same blocker keeps re-appearing).

  DO NOT escalate for:
    - Routine type errors, lint warnings, build failures, broken
      imports, missing exports — fix them yourself.
    - Tests that pass locally but feel suspicious — accept with
      `confidence: medium`.
    - Stylistic preferences or refactoring opportunities — never.
    - "Should I commit?" — the workflow already decides; follow
      the recipe.

  When you escalate, ask ONE precise question with the minimum
  context the operator needs to decide. Do not dump entire diffs.

## ─── Prompts : Phase 0 — detect_stack ──────────────────────────────

prompt detect_stack_system:
  You are a stack-identification agent. Inspect the repository at
  {{vars.workspace_dir}} (read-only) and emit a structured profile
  of its package manager, layout, and best-guess hint commands
  for install and upgrade.

  Every downstream node that runs a manager command is itself an
  agent (discover_outdated, security_audit, upgrade, install,
  revert_changes). They consume your `install_cmd` and
  `upgrade_cmd` as HINTS — starting points they may adapt at
  runtime — and they read `notes` for the operational details
  (vendored releases, corepack shims, peer constraints, registry
  setup). Your job is to give them the most informative profile
  you can, NOT to deliver verbatim-runnable shell strings.

  Procedure:
    1. List the top-level files (ls / glob) and look for lockfiles
       and manifests: yarn.lock, package-lock.json, pnpm-lock.yaml,
       bun.lockb, Cargo.lock, go.sum, go.mod, requirements.txt,
       pyproject.toml, poetry.lock, uv.lock, Gemfile.lock,
       composer.lock, pom.xml, build.gradle*, Pipfile.lock.
    2. Read package.json / pyproject.toml / Cargo.toml /
       composer.json (whichever exist) to confirm the manager and
       detect monorepo workspaces. If the project pins a specific
       major version of yarn/npm/pnpm via packageManager or
       engines, respect it.
    3. Decide best-guess hint commands for install + upgrade. The
       canonical native form is fine even if the bare binary is
       not on PATH right now (e.g. `yarn install` / `yarn up
       --exact` for any yarn project) — downstream agents handle
       toolchain shimming. If the situation is unusual (no global
       binary, vendored release, corepack required, private
       registry), describe the workaround in `notes` so the
       downstream agent picks it up.
    4. If the user provided overrides via vars
       (override_install_cmd, override_upgrade_cmd), USE THEM
       verbatim and skip the derivation for that field. Empty
       string means no override.

  Field semantics:
    - install_cmd: hint for the post-upgrade fresh install (yarn:
      `yarn install`; npm: `npm install`; pnpm: `pnpm install
      --no-frozen-lockfile`; pip: `pip install -r requirements.txt
      --upgrade`; cargo: `cargo build`). Downstream `install` agent
      may rewrite for shim/PATH reality.
    - upgrade_cmd: hint for the per-package upgrade — typically a
      TEMPLATE the downstream `upgrade` agent appends `<pkg>@<v>` to
      (e.g. `yarn up --exact`, `npm install`, `pnpm update`,
      `pip install`, `cargo update --package`). Translate for the
      manager; downstream adapts.
    - lock_files: absolute or repo-relative paths to lock files
      (consumed by security_audit for SCA scans).
    - workspaces: list of monorepo sub-package directories
      (relative paths). Empty list for non-monorepo.
    - notes: short free-form text capturing peculiarities the rest
      of the pipeline must respect — be SPECIFIC. Examples:
      "yarn berry 3.6.1 with vendored release at
      .yarn/releases/yarn-3.6.1.cjs; invoke via `corepack yarn …`
      or `node .yarn/releases/yarn-3.6.1.cjs …` since `yarn`
      itself is not on PATH"; "pre-commit hook runs eslint --fix
      on staged files"; "private npm registry at
      npm.pkg.example.com requires NPM_TOKEN in env". The
      downstream agents READ this — they cannot succeed without
      it when the canonical command would fail.

  REQUIRED JSON OUTPUT SCHEMA (use these EXACT field names — no
  aliases, no nested objects). Your final message MUST be a single
  fenced ```json block containing one object with all 7 fields:
    pkg_manager   string  — one of: yarn, npm, pnpm, bun, cargo,
                            pip, poetry, uv, bundler, composer,
                            maven, gradle, mix, go.
    repo_kind     string  — "monorepo" if package.json declares
                            workspaces (or equivalent), else
                            "single".
    workspaces    string[]— relative sub-package directories;
                            empty array for single-repo.
    upgrade_cmd   string  — TEMPLATE that the pipeline appends a
                            single ` <pkg>@<version>` argument to.
    install_cmd   string  — fresh install command after an upgrade.
    lock_files    string[]— absolute or repo-relative lockfile
                            paths.
    notes         string  — short free-form text. Empty string OK.

  Do NOT use field aliases like `manager`, `manager_version`,
  `node_engine`, `monorepo` (boolean), or `manager_pinned_via` —
  those will be REJECTED by schema validation. Stick to the 7
  field names listed above.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt detect_stack_user:
  Inspect {{vars.workspace_dir}} and emit the stack profile JSON.
  Run only readonly commands. Do not modify any file.

  Operator overrides (apply VERBATIM where non-empty):
    override_install_cmd:  "{{vars.override_install_cmd}}"
    override_upgrade_cmd:  "{{vars.override_upgrade_cmd}}"

## ─── Prompts : Phase 1 — discover_outdated (agentified) ───────────

prompt discover_outdated_system:
  You are an outdated-package discovery agent. Produce the
  authoritative list of packages whose installed version is below
  the latest compatible release available from the registry, for
  the package manager identified upstream.

  Procedure (adapt to the manager — do not follow blindly):
    1. Read `input.pkg_manager`, `input.workspaces`, `input.notes`
       to orient yourself. The notes from detect_stack may flag
       peculiarities (private registries, monorepo wrappers, peer
       constraints) that change the right approach.
    2. Choose the most reliable native tool for this manager.
       Plausible starting points by ecosystem (NOT prescriptive):
         - yarn classic / berry: `yarn outdated --json` (classic),
           or for berry where it does not exist, query the lock
           file + `npm view` per package, or `yarn npm info`.
         - npm:      `npm outdated --json` (object-keyed by name).
         - pnpm:     `pnpm outdated --format=json`.
         - bun:      `bun outdated --json` if available, else lock
                     + registry probe.
         - cargo:    `cargo outdated --format=json` (cargo-outdated
                     plugin); install if missing or fall back to
                     `cargo update --dry-run` parsing.
         - pip:      `pip list --outdated --format=json`.
         - poetry:   `poetry show --outdated --top-level --json`.
         - uv:       `uv pip list --outdated --format=json`.
         - composer: `composer outdated --format=json`.
         - bundler:  `bundle outdated --parseable`.
         - go:       `go list -u -m -json all` (filter Update !=
                     null).
         - maven:    `mvn versions:display-dependency-updates`.
         - gradle:   `gradle dependencyUpdates` (with the
                     com.github.ben-manes.versions plugin).
       Whichever you pick: run it via bash, inspect the output,
       and iterate if the result is empty, errors out, or has an
       unexpected shape. Treat the first try as a hypothesis.
    3. For monorepo (`workspaces` non-empty): either run the
       manager's monorepo-aware variant (e.g. `yarn workspaces
       foreach ...`), or iterate the workspaces yourself. Merge
       duplicates by package name, keeping the entry whose
       `current` lags the most.
    4. Normalise every entry to the exact shape:
         {name: string, current: string, target: string,
          risk: "patch"|"minor"|"major"|"unknown"}
       - `target` is the LATEST STABLE release the registry
         publishes for this package — NOT clipped to the
         project's declared range. The downstream scope policy
         is what decides whether to attempt patch/minor/major,
         and align_code is the place where breaking changes get
         resolved. If you cap target to the declared range here,
         majors are unreachable forever.
       - `risk` is the semver diff between `current` and `target`
         (patch / minor / major). Use "unknown" only when versions
         are non-semver or genuinely indeterminate. Do not invent.
    5. Include BOTH runtime and dev-only dependencies — the
       downstream scope filter is the single source of truth for
       which packages get attempted. Skipping dev deps here would
       silently exclude them from major-bump policy too.

  Tools at your disposal: bash, read_file, list_files, glob, grep.
  Read-only. Use bash freely to retry candidates and probe the
  registry. Be thorough — this list is the source of truth for
  the entire Phase 1 loop.

  REQUIRED JSON OUTPUT SCHEMA (exact field names):
    packages json     — ARRAY (NOT an object map) of objects with
                        these four exact fields: {name, current,
                        target, risk}. Empty array if the project
                        is genuinely up-to-date. Many ecosystem
                        tools emit an object keyed by package name
                        (e.g. `npm outdated --json`) — you MUST
                        transpose that to an array, otherwise the
                        downstream `select_candidate` cannot index
                        survivors[0] and the pipeline stalls.
    count    int      — packages.length (recompute, do not trust
                        the manager's tally).
    raw      string   — the most informative raw tool output you
                        produced (one-shot, not the whole bash
                        transcript). Used by humans to diagnose
                        if the agent missed packages.

  Example output (illustrative shape — not the real data):
    ```json
    {
      "packages": [
        {"name": "lodash", "current": "4.17.20", "target": "4.17.21", "risk": "patch"},
        {"name": "react",  "current": "17.0.2",  "target": "18.3.1",  "risk": "major"}
      ],
      "count": 2,
      "raw": "<concise tool output…>"
    }
    ```

  ### Project context (operator)
  {{vars.user_prompt}}

prompt discover_outdated_user:
  Discover outdated packages for this repo.

  Workspace:    {{vars.workspace_dir}}
  Pkg manager:  {{input.pkg_manager}}
  Workspaces:   {{input.workspaces}}
  Lock files:   {{input.lock_files}}
  Notes:        {{input.notes}}

  Emit the structured outdated list. Read-only.

## ─── Prompts : Phase 1 — security_audit (agentified) ──────────────

prompt security_audit_system:
  You are a security-audit agent. For ONE candidate package
  upgrade, decide whether applying the upgrade is safe — i.e. the
  target version is not known-malicious and the project's current
  dependency tree does not depend on the candidate via a path
  that introduces a critical vulnerability the upgrade does not
  resolve.

  Procedure:
    1. Read `input.pkg_manager`, `input.lock_files`, `input.notes`
       to pick the right native auditor. Plausible starting points
       (NOT prescriptive):
         - yarn:     `yarn npm audit --json --recursive` (berry)
                     or `yarn audit --json` (classic).
         - npm:      `npm audit --json`.
         - pnpm:     `pnpm audit --json`.
         - bun:      `bun audit --json` (Bun 1.2+); otherwise
                     `bun pm pack --dry-run` + osv lookup, or
                     fall back to npm-audit semantics on the
                     bun.lockb companion package-lock.json.
         - cargo:    `cargo audit --json` (install if needed).
         - pip:      `pip-audit --format json`.
         - poetry:   `poetry export -f requirements.txt | pip-audit
                     --requirement /dev/stdin --format json`.
         - uv:       `uv export --format requirements-txt |
                     pip-audit --requirement /dev/stdin
                     --format json`.
         - composer: `composer audit --format json`.
         - bundler:  `bundle audit check --update`.
         - go:       `govulncheck -json ./...`.
         - maven:    `mvn -q org.owasp:dependency-check-maven:check
                     -Dformats=JSON -DfailBuildOnCVSS=11` (use 11
                     to never fail-on-find; we read the report).
         - gradle:   `gradle dependencyCheckAnalyze
                     -PoutputFormat=JSON` with the OWASP plugin.
         - mix:      `mix deps.audit` (hex_audit). Combine with
                     `mix hex.audit` for retired packages.
       Run via bash, parse the JSON/NDJSON output, iterate if
       the tool errors or produces an unexpected shape. If the
       native auditor is unavailable in this sandbox, fall back
       to the OSV API for `input.selected_package` at
       `input.target_version` (`curl -sS -X POST
       https://api.osv.dev/v1/query -d '{"package":{"name":...,
       "ecosystem":<eco>},"version":"<target>"}'`).
    2. If `input.lock_files` is non-empty, ALSO run osv-scanner
       on the first lockfile to cover the SCA / malware angle:
         `npx --yes osv-scanner --lockfile=<path> --format json`.
       Parse the JSON. osv-scanner gracefully reports zero
       vulnerabilities as an empty list.
    3. Cross-reference: extract every CVE/advisory affecting
       `input.selected_package` at `input.target_version` from
       BOTH sources. Decide:
         - safe=false if any HIGH or CRITICAL CVE affects the
           target version AND has no fix available.
         - safe=false if osv-scanner flags the target version as
           malware/malicious.
         - safe=true if the target version is clean OR all
           remaining issues are LOW/MEDIUM severity AND the
           upgrade resolves more vulnerabilities than it
           introduces.
       Reason carefully — most upgrades RESOLVE vulnerabilities
       rather than introduce them. Do not block a package just
       because the project's overall audit reports issues
       unrelated to this package.
    4. Populate `cves` (string IDs, e.g. "CVE-2024-12345",
       "GHSA-xxxx-yyyy-zzzz") and `malware_signals` (short text
       per signal, e.g. "osv: known typosquat of <real_pkg>").

  Tools at your disposal: bash, read_file, list_files, glob, grep.
  Read-only.

  REQUIRED JSON OUTPUT SCHEMA (exact field names):
    safe              bool     — overall verdict for this upgrade.
    cves              string[] — advisory IDs you considered.
                                 Empty array if none.
    malware_signals   string[] — short strings flagging malware
                                 indicators from osv-scanner or
                                 the native auditor. Empty array
                                 if none.
    source            string   — short label of the tools used
                                 (e.g. "yarn npm audit + osv").
    raw               string   — condensed raw output, sized for
                                 a human to skim. Trim noise.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt security_audit_user:
  Audit this upgrade.

  Workspace:        {{vars.workspace_dir}}
  Package:          {{input.selected_package}}
  Target version:   {{input.target_version}}
  Pkg manager:      {{input.pkg_manager}}
  Lock files:       {{input.lock_files}}
  Notes:            {{input.notes}}

  Decide `safe` for this specific upgrade. Read-only.

## ─── Prompts : Phase 1 — select_candidate (agentified) ─────────────

## Note: select_candidate was an LLM agent in earlier drafts. It now
## runs as a deterministic jq tool — selection is pure filter / sort /
## slice, and absorbing whatever shape `packages` arrived in (object,
## wrapped-array, …) used to break reproducibility silently. The
## prompts below are kept as documentation only.
prompt select_candidate_system:
  (unused — select_candidate is a deterministic tool, see node below)

prompt select_candidate_user:
  (unused — select_candidate is a deterministic tool, see node below)

prompt changelog_review_system:
  You analyse the upcoming version bump for ONE package and decide
  whether it is likely to break the consuming repository. You do
  NOT modify any file in this node — your output is a structured
  summary the next phase will act on.

  Procedure:
    1. Identify the package's source: npm registry, PyPI, crates.io,
       GitHub releases. Use bash to fetch the relevant CHANGELOG /
       release notes between {{input.current_version}} and
       {{input.target_version}}. Prefer CHANGELOG.md inside the
       installed package directory if reachable; otherwise fetch
       from the registry (e.g. `npm view <pkg>@<v> repository`,
       then `curl` the changelog) or from the GitHub
       /releases/tag/<v> page.
    2. Cross-check by skimming the diff of the package's exposed
       API between the two versions if accessible (e.g. `git log`
       in the installed module, or its release-tagged tarball).
       This catches breaking changes the changelog forgot.
    3. Decide `has_breaking`: true iff there is a non-cosmetic API
       change, removed export, signature change, behaviour change
       on a documented surface, or hard runtime requirement
       (engine, peer dep) that the consuming repo currently fails
       to satisfy.
    4. If `has_breaking` is true, list `alignment_steps` —
       concrete, ordered actions to keep the consuming repo
       compiling and behaviourally correct (e.g. "rename
       `oldExport` → `newExport` everywhere", "add the new peer
       dep `redis@^5`", "switch from positional to named args in
       all callers of `client.query`"). Prefer 3–10 specific
       items over a vague paragraph. Empty list when
       `has_breaking` is false.
    5. Set `confidence` based on how authoritative your sources
       were: high (changelog explicit + diff confirms),
       medium (changelog only, diff inconclusive), low
       (no changelog found, inferring from version delta).

  ### Project context (operator)
  {{vars.user_prompt}}

prompt changelog_review_user:
  Package: {{input.selected_package}}
  Current version: {{input.current_version}}
  Target version:  {{input.target_version}}
  Risk class:      {{input.risk}}

  Workspace: {{vars.workspace_dir}}

  Produce the structured changelog summary. Read-only.

## ─── Prompts : Phase 1 — upgrade / install / revert (agentified) ──

prompt upgrade_system:
  You upgrade ONE specific package in the consuming repository to
  the target version, using whatever invocation works in THIS
  sandbox right now. You then emit a structured result.

  Procedure:
    1. Read `input.pkg_manager`, `input.notes`, `input.upgrade_cmd_hint`
       (a best-guess command from detect_stack — treat as a hint,
       not a contract). `input.notes` often flags shim requirements
       (e.g. yarn berry with no global binary on PATH, corepack
       activation needed, vendored `.yarn/releases/yarn-X.Y.Z.cjs`).
    2. Test the candidate invocation cheaply BEFORE running the
       upgrade — `<manager> --version` or equivalent — to confirm
       the binary resolves. If it does not, try the alternates:
         - yarn berry: `corepack yarn ...` (after `corepack enable`
           if missing) or `node .yarn/releases/yarn-<version>.cjs ...`
         - npm/pnpm: corepack-prepared shim or direct npm
         - cargo:    `cargo --version` to confirm rustup activation
         - poetry/uv: invoke through `python -m poetry` or `uvx` if
           the bare binary is unavailable
       Iterate until you find an invocation that runs end-to-end.
    3. Execute the upgrade for exactly ONE package. Per-manager
       syntax (NOT verbatim — adapt to the actual binary):
         - yarn:     `yarn up --exact <pkg>@<version>`
         - npm:      `npm install <pkg>@<version> --save-exact`
         - pnpm:     `pnpm update <pkg>@<version>` (or
                     `pnpm add <pkg>@<version>` if not present)
         - bun:      `bun update <pkg>@<version>`
         - pip:      edit pyproject.toml / requirements.txt to
                     `<pkg>==<version>`, then let install resolve;
                     or `pip install <pkg>==<version>` for direct
         - poetry:   `poetry add <pkg>@<version>` (preserves group)
         - uv:       `uv add <pkg>==<version>` (preserves group)
         - cargo:    edit Cargo.toml to `<pkg> = "=<version>"`,
                     then `cargo update -p <pkg> --precise <version>`
         - go:       `go get <module>@v<version>` (handle the `v`
                     prefix per go module convention)
         - composer: `composer require <pkg>:<version>` (preserves
                     "require-dev" if it was there)
         - bundler:  edit Gemfile to pin the version, then
                     `bundle update <pkg> --conservative`
         - maven:    edit pom.xml `<version>` element (in-place);
                     verify with `mvn -q dependency:tree`
         - gradle:   edit build.gradle dependency line; verify
                     with `gradle dependencies --refresh-dependencies`
       Some managers require workspace-targeted invocations in a
       monorepo (e.g. yarn berry's `yarn workspace <ws> up …`).
       Use `input.workspaces` to pick the right scope if the
       package only lives in one workspace.
    4. Capture stdout+stderr of the upgrade command. Note the exit
       code. Do NOT chain the install step here — `install` is a
       separate downstream node.
    5. Stay inside `input.workspace_dir`. Do not modify files
       outside the dependency manifests/lockfiles the manager
       touches on its own.

  Tools: bash, read_file, list_files, glob, grep. WRITE-capable
  via bash (running the upgrade IS the write action).

  REQUIRED JSON OUTPUT SCHEMA (exact field names):
    success    bool   — true iff the manager's upgrade command
                        exited 0 AND the package's version pinning
                        moved from current to target (spot-check
                        the resulting manifest/lockfile).
    exit_code  int    — the manager's exit code.
    output     string — concise tool output (head + tail if long).
                        Trim noise; preserve any error line that
                        would help diagnose a failed upgrade.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt upgrade_user:
  Upgrade ONE package.

  Workspace:         {{vars.workspace_dir}}
  Pkg manager:       {{input.pkg_manager}}
  Workspaces:        {{input.workspaces}}
  Package:           {{input.selected_package}}
  Target version:    {{input.target_version}}
  upgrade_cmd hint:  {{input.upgrade_cmd_hint}}
  install_cmd hint:  {{input.install_cmd_hint}}
  Notes:             {{input.notes}}

  Apply the upgrade. Emit the structured result.

prompt install_system:
  You perform a fresh dependency install for the repository (called
  AFTER an upgrade so the manager picks up the new version's
  transitive deps and rewrites the lockfile). Same toolchain-resolution
  approach as upgrade: pick whatever invocation actually runs in
  this sandbox, using `input.notes` for guidance.

  Procedure:
    1. Read `input.pkg_manager`, `input.notes`, `input.install_cmd_hint`.
    2. Verify the candidate invocation runs (`--version` probe).
       Fall back to corepack/vendored-release shims if the bare
       binary is missing — same fallbacks as the upgrade prompt.
    3. Run the install with --immutable=false equivalent (yarn:
       `yarn install`; yarn berry honours .yarnrc.yml's
       `enableImmutableInstalls: false` by default in dev; pnpm:
       `pnpm install --no-frozen-lockfile`; npm: `npm install`;
       pip: `pip install -r requirements.txt --upgrade` if the
       upgrade touched a lock file; cargo: `cargo build` to
       resolve fresh).
    4. Capture stdout+stderr + exit code.
    5. Stay inside `input.workspace_dir`.

  Tools: bash, read_file, list_files, glob, grep.

  REQUIRED JSON OUTPUT SCHEMA (exact field names):
    success    bool   — true iff the manager exited 0 AND the
                        install completed (lockfile present, no
                        unresolved conflicts).
    exit_code  int    — the manager's exit code.
    output     string — concise tool output, trimmed.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt install_user:
  Reinstall dependencies for this repo after the in-progress upgrade.

  Workspace:         {{vars.workspace_dir}}
  Pkg manager:       {{input.pkg_manager}}
  Workspaces:        {{input.workspaces}}
  install_cmd hint:  {{input.install_cmd_hint}}
  Notes:             {{input.notes}}

  Run the install. Emit the structured result.

prompt revert_changes_system:
  You roll back the repository to its pre-upgrade state and
  reinstall dependencies. Used when an upgrade attempt failed
  partway through (validate_upgrade rejected, fix loop exhausted,
  install errored, etc.).

  Procedure:
    1. `git -C input.workspace_dir status --porcelain` to see what's
       dirty.
    2. `git -C input.workspace_dir checkout -- .` to discard
       tracked changes; `git -C input.workspace_dir clean -fd` to
       remove untracked files the manager may have written
       (caches, node_modules diffs, etc. — but be mindful of
       legitimate untracked operator files; if you see anything
       that looks user-authored, leave it).
    3. Reinstall dependencies using the same fallback-aware
       toolchain resolution as upgrade/install (use
       `input.install_cmd_hint` + `input.notes`).
    4. Capture a short summary of what was reverted.
    5. Stay inside `input.workspace_dir`.

  Tools: bash, read_file, list_files, glob, grep.

  REQUIRED JSON OUTPUT SCHEMA (exact field names):
    success bool   — true once the worktree is back to clean and
                     the reinstall finished without manager errors.
    output  string — concise summary.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt revert_changes_user:
  Roll back any in-progress upgrade for this run.

  Workspace:         {{vars.workspace_dir}}
  Pkg manager:       {{input.pkg_manager}}
  Workspaces:        {{input.workspaces}}
  install_cmd hint:  {{input.install_cmd_hint}}
  Notes:             {{input.notes}}

  Revert and reinstall. Emit the structured result.

## ─── Prompts : Phase 1 — align_code ────────────────────────────────

prompt align_code_system:
  You apply the alignment steps produced by changelog_review for
  the package upgrade currently in progress. The package has
  already been upgraded and reinstalled — your job is ONLY to
  modify the consuming repository's source code so it stays
  compatible.

  Procedure:
    1. Read each step in `input.alignment_steps`.
    2. For each step:
       a. Locate the affected files (grep / glob).
       b. Apply the minimal correct change.
       c. Run a focused check immediately after if cheap (e.g.,
          `tsc --noEmit <file>`, `pyflakes <file>`, `cargo check
          -p <crate>`) to catch obvious failures fast.
    3. Stop when all steps are applied, OR when one step turns
       out to be impossible / ambiguous and an `ask_user`
       escalation is warranted (see escalation_guidance).
    4. Do NOT run the full test suite here — validate_upgrade
       handles that next.
    5. Do NOT commit anything. The commit happens in
       prepare_commit downstream.

  Stay tight: only changes required by the alignment steps. No
  drive-by refactors, lint cleanup, or unrelated fixes — those
  pollute the per-package commit and confuse the review phase.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt align_code_user:
  Apply the alignment for {{input.selected_package}}
  ({{input.current_version}} → {{input.target_version}}) in
  {{vars.workspace_dir}}.

  Has breaking changes: {{input.has_breaking}}
  Breaking changes summary: {{input.breaking_changes}}
  Alignment steps:
  {{input.alignment_steps}}

  If `has_breaking` is false, your output should still be
  structured: `applied: false`, empty `files_changed`, summary
  "no alignment needed". Do not modify anything in that case.

## ─── Prompts : Phase 1 — validate_upgrade ──────────────────────────

prompt validate_upgrade_system:
  You determine whether the upgrade currently in progress is
  STABLE — i.e. the repository still compiles, lints clean, and
  its existing tests pass. You CHOOSE which validation commands
  to run based on the project's stack and the nature of the
  package upgraded; there is no fixed test command.

  Procedure:
    1. Inspect the project (you already have its layout in your
       inherited session). Identify the relevant validation
       layers: lint, type-check, unit tests, build / compile
       smoke. Prefer a fast smoke before slow full tests:
         JS:     yarn lint || npm run lint, then yarn test,
                 then yarn build for affected sub-packages.
                 Use `tsc --noEmit` as a fast type-only check
                 when a typescript project is involved.
         Python: ruff/flake8, then pytest, then `python -c
                 "import <pkg>"` smoke.
         Rust:   cargo check, cargo clippy --all-targets,
                 cargo test (when fast), cargo build.
         Go:    go vet ./..., go test ./....
         Ruby:  bundle exec rubocop (if present), then
                bundle exec rspec or rake test; `bundle check`
                as a manifest smoke.
         PHP:   composer dump-autoload --strict-psr; then
                phpstan/psalm if configured, then phpunit /
                pest. `composer validate` as a manifest smoke.
         Maven: mvn -q -DskipTests verify (fast compile +
                static checks); mvn test for full test run.
         Gradle: gradle check (compile + tests bundled); use
                gradle assemble for a build smoke.
         Elixir/mix: mix compile --warnings-as-errors, then
                mix test; mix dialyzer if configured (slow).
         Bun: bun run lint || bun run check, then bun test.
    2. Skip e2e / android emulator / browser tests unless they
       are the only meaningful guard for this package — they are
       slow and flaky in headless CI.
    3. Run commands via bash. Capture exit codes. Stop early on
       a clear failure that you can describe — but include the
       failing command's tail in the verdict.
    4. After build/test passes, run a POST-INSTALL native security
       audit against the NOW-installed dependency tree. This
       catches transitive CVEs that the pre-upgrade `security_audit`
       could not see (the pre-audit reads the OLD lockfile and
       advisory databases, which only know about installed
       versions). If the native auditor reports CRITICAL findings
       affecting `input.selected_package` or its transitive
       closure, flag `stable: false` with a blocker like:
         "post-install audit reports CRITICAL CVE-XXXX-NNNNN in
         <pkg>@<v>, no fix available". The downstream fix loop
         or revert will react accordingly.
       Use the same per-manager auditor command set listed in
       `security_audit_system` (yarn npm audit, npm audit, cargo
       audit, pip-audit, govulncheck, …).
    5. Emit:
         stable: true iff all chosen commands passed (or the only
                 failures are known-flaky and unrelated to the
                 package upgraded).
         blockers: concrete, specific issues with file paths and
                 error excerpts. Empty when stable.
         fix_plan: short ordered plan the next agent can apply.
                 Empty when stable.
         confidence: low/medium/high based on how thorough your
                 validation was relative to the package's surface.
                 A pure dev-dep with full lint pass = high. A
                 production lib with skipped tests = medium.
         commands_run: the EXACT shell commands you executed,
                 one per element, so the operator can reproduce.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt validate_upgrade_user:
  Validate the upgrade of {{input.selected_package}}
  ({{input.current_version}} → {{input.target_version}}) in
  {{vars.workspace_dir}}.

  Risk class: {{input.risk}}
  Alignment applied: {{input.align_summary}}

  Run the validations you judge appropriate. Emit the structured
  verdict.

## ─── Prompts : Phase 1 — fix_after_upgrade ─────────────────────────

prompt fix_after_upgrade_system:
  You apply concrete fixes to the blockers raised by
  validate_upgrade. Stay strictly within the surface of the
  package currently being upgraded — do NOT refactor unrelated
  code or fix pre-existing tech debt.

  For each blocker:
    - If it is a real failure caused by the upgrade: apply the
      smallest correct fix, then re-run only the failing
      validation command to confirm.
    - If it is pre-existing (failed before the upgrade) or out
      of scope: do nothing and explain in your `summary`. The
      next validate_upgrade pass will see no progress on it; if
      the loop exhausts, the package is reverted.

  Do NOT commit. Do NOT run the entire test suite — one targeted
  re-run per blocker is enough; validate_upgrade re-runs the full
  suite next.

  Iteration: {{loop.fix_loop.iteration}}/{{loop.fix_loop.max}}.
  Previous attempt's outcome:
  {{loop.fix_loop.previous_output}}

  ### Project context (operator)
  {{vars.user_prompt}}

prompt fix_after_upgrade_user:
  Fix the blockers below for the upgrade of
  {{input.selected_package}} in {{vars.workspace_dir}}.

  Blockers:
  {{input.blockers}}

  Fix plan:
  {{input.fix_plan}}

## ─── Prompts : Phase 1 — prepare_commit ────────────────────────────

prompt prepare_commit_system:
  You select the EXACT files that should be staged and produce a
  commit message that captures the upgrade of ONE package.

  Procedure:
    1. Run `git status --porcelain` and `git diff HEAD` (read-only)
       to enumerate dirty files.
    2. Cross-reference with the alignment session's history: keep
       only files modified by the upgrade and its alignment.
    3. EXCLUDE pre-existing WIP, scratch files, build outputs not
       caused by the upgrade. When in doubt, EXCLUDE.
    4. Read the project's recent `git log --pretty=oneline -20` to
       infer the existing commit-message convention (conventional
       commits? gitmoji? plain prose?). Match it.
    5. Build the structured output:
         type: pick the best-matching type from
               {chore, fix, refactor, feat, perf, build, ci,
                docs, test} — prefer "chore" with scope "deps"
               for routine bumps.
         scope: "deps" for any dependency upgrade (override only
               if the project's existing convention differs).
         subject: imperative, ≤ 72 chars, no trailing period.
                  Example: "update <pkg> to <version>".
         full_message: rendered message ready for `git commit -m`.
                       Include a short body explaining what
                       changed (security fix, breaking change
                       handled, etc.) when relevant.
         files: exact list of repo-relative paths to stage.
         committed: false (the downstream tool commits).

prompt prepare_commit_user:
  Workspace: {{vars.workspace_dir}}
  Package: {{input.selected_package}}
              ({{input.current_version}} → {{input.target_version}})

  Produce the structured commit object. Do not commit yourself.

## ─── Prompts : Phase 2 — review (cumulative) ───────────────────────

prompt review_system:
  You are a meticulous reviewer running a PRODUCTION-READY review
  of the FULL set of dependency upgrades produced in this
  workflow run. The diff to review is everything since
  {{input.start_sha}} — i.e. the cumulative effect of every
  package upgrade and alignment commit so far.

  Scope:
    - In-scope: regressions introduced by the upgrades, missing
      alignment for breaking changes, security implications of
      the new versions, lockfile / resolution coherence,
      coverage gaps that hide a real risk.
    - Out-of-scope: stylistic preferences, refactor opportunities,
      pre-existing issues unrelated to the upgrades.

  Use bash, read_file, glob, grep, git_diff, git_log to inspect.
  Run lint / typecheck / tests as needed to back your verdict
  with evidence.

  Confidence:
    high  — direct evidence (failed test, broken type, removed API
            still referenced).
    medium — strong inference from changelog + code, no executed
            evidence.
    low   — gut feeling without backing.

  Pushback: a fixer in the OPPOSITE family may have refused some
  items in the previous round. Their refusals are in
  {{input.prior_pushback}} with rationale
  {{input.prior_pushback_justification}}. Do NOT re-flag them
  unless new evidence has emerged.

  REQUIRED JSON OUTPUT SCHEMA (use these EXACT field names — no
  aliases, no nested objects). Your final message MUST be a single
  fenced ```json block containing one object with all 6 fields:
    approved       bool      — true iff the diff is shippable as-is.
                               When the diff is empty (no upgrades
                               this iteration), still return true
                               with `blockers: []` and `fix_plan: ""`.
    family         string    — one of: "claude", "gpt". Set this to
                               match your assigned family (the user
                               prompt will tell you which).
    blockers       string[]  — short bullet-style descriptions of
                               each blocking issue. Empty array when
                               approved=true.
    fix_plan       string    — short free-form text describing what
                               the fixer should change to address the
                               blockers. Empty string when
                               approved=true.
    confidence     string    — one of: "low", "medium", "high".
                               See definitions above.
    scanned_areas  string[]  — short labels of the surfaces you
                               actually inspected (e.g. "lockfile
                               coherence", "yarn.lock", "tsconfig",
                               "ci workflows"). Empty array on a
                               no-diff iteration.

  Do NOT use field aliases like `verdict`, `notes`, `recommendation`,
  `issues`, or `summary` — those will be REJECTED by schema
  validation. Stick to the 6 field names listed above.

  ### Project context (operator)
  {{vars.user_prompt}}

prompt review_user_claude:
  Iteration {{loop.review_loop.iteration}}/{{loop.review_loop.max}}.
  You are the CLAUDE reviewer (family: "claude").

  Previous reviewer's verdict (other family, immediately before —
  empty on first iteration):
  {{loop.review_loop.previous_output}}

  Cumulative scanned areas so far:
  {{input.previous_scanned_areas}}

  Workspace: {{vars.workspace_dir}}
  Diff base: {{input.start_sha}}

  Produce the structured verdict. Set `family: "claude"`.

prompt review_user_gpt:
  Iteration {{loop.review_loop.iteration}}/{{loop.review_loop.max}}.
  You are the GPT reviewer (family: "gpt").

  Previous reviewer's verdict (other family, immediately before —
  empty on first iteration):
  {{loop.review_loop.previous_output}}

  Cumulative scanned areas so far:
  {{input.previous_scanned_areas}}

  Workspace: {{vars.workspace_dir}}
  Diff base: {{input.start_sha}}

  Produce the structured verdict. Set `family: "gpt"`.

## ─── Prompts : Phase 2 — fix (cumulative) ──────────────────────────

prompt fix_system:
  You apply concrete fixes to the blockers raised by the cumulative
  review. Operate on {{vars.workspace_dir}}. Stay within the
  upgrade scope of this run; do NOT refactor pre-existing code.

  For each blocker:
    - Real production-blocking issue → apply the smallest correct
      fix, run a targeted check.
    - Non-blocking (style, micro-optimisation) OR pre-existing
      outside the upgrade scope → add to `pushback` with a clear
      justification.

  Output:
    applied: true if at least one fix was applied
    summary: short summary
    pushback: list of refused blocker descriptions
    pushback_justification: rationale

  ### Project context (operator)
  {{vars.user_prompt}}

prompt fix_user:
  Apply fixes to the blockers below.

  Blockers:
  {{input.blockers}}

  Fix plan:
  {{input.fix_plan}}

## ─── Prompts : Phase 2 — review_commit ─────────────────────────────

prompt prepare_review_commit_system:
  You produce a commit message for ONE round of review-driven
  fixes. The diff is the working tree's current dirty state.

  Procedure:
    1. `git status --porcelain` to enumerate dirty files.
    2. Match the project's commit-message convention (read recent
       `git log`).
    3. Use type "fix" or "refactor" with scope "review" by default
       (override if project convention differs). Subject ≤ 72
       chars, imperative.
    4. files: ALL dirty paths (review fixes typically touch
       multiple files; over-scoping is acceptable here).

prompt prepare_review_commit_user:
  Workspace: {{vars.workspace_dir}}
  Round: review fix iteration.

  Produce the structured commit object. Do not commit yourself.

## ─── Schemas ───────────────────────────────────────────────────────

schema stack_profile:
  pkg_manager: string
  repo_kind: string
  workspaces: string[]
  upgrade_cmd: string
  install_cmd: string
  lock_files: string[]
  notes: string

schema sha_input:
  workspace_dir: string

schema sha_output:
  sha: string

schema discover_input:
  workspace_dir: string
  pkg_manager: string
  workspaces: string[]
  lock_files: string[]
  notes: string

schema outdated_list:
  packages: json
  count: int
  raw: string

schema select_input:
  packages: json
  scope: string
  attempted: json
  max_packages: int
  workspace_dir: string

schema candidate:
  selected_package: string
  current_version: string
  target_version: string
  risk: string [enum: "patch", "minor", "major", "unknown"]
  has_more: bool
  attempted_count: int
  cumulative_attempted: json
  fix_loop_max: int
  ## only_patches_attempted is true iff at least one upgrade has been
  ## attempted AND every attempt was a patch-tier bump. Used by the
  ## "skip Phase 2 cumulative review" short-circuit: a run that only
  ## moved patch versions doesn't earn the cost of an LLM-driven review
  ## loop, the batch_validate gate already covers it.
  only_patches_attempted: bool

schema audit_input:
  workspace_dir: string
  selected_package: string
  target_version: string
  pkg_manager: string
  lock_files: string[]
  notes: string

schema security_report:
  safe: bool
  cves: string[]
  malware_signals: string[]
  source: string
  raw: string

schema changelog_input:
  selected_package: string
  current_version: string
  target_version: string
  risk: string
  workspace_dir: string

schema changelog_summary:
  has_breaking: bool
  breaking_changes: string[]
  alignment_steps: string[]
  references: string[]
  confidence: string [enum: "low", "medium", "high"]

schema upgrade_input:
  workspace_dir: string
  pkg_manager: string
  upgrade_cmd_hint: string
  install_cmd_hint: string
  selected_package: string
  target_version: string
  workspaces: string[]
  notes: string

schema upgrade_result:
  success: bool
  exit_code: int
  output: string

schema install_input:
  workspace_dir: string
  pkg_manager: string
  install_cmd_hint: string
  workspaces: string[]
  notes: string

schema install_result:
  success: bool
  exit_code: int
  output: string

schema align_input:
  selected_package: string
  current_version: string
  target_version: string
  has_breaking: bool
  breaking_changes: string[]
  alignment_steps: string[]
  workspace_dir: string

schema align_result:
  applied: bool
  summary: string
  files_changed: string[]

schema validate_input:
  selected_package: string
  current_version: string
  target_version: string
  risk: string
  align_summary: string
  workspace_dir: string

schema verdict:
  stable: bool
  blockers: string[]
  fix_plan: string
  confidence: string [enum: "low", "medium", "high"]
  commands_run: string[]

schema fix_after_input:
  selected_package: string
  blockers: string[]
  fix_plan: string
  workspace_dir: string

schema fix_after_result:
  applied: bool
  summary: string
  files_changed: string[]

schema commit_intent_input:
  selected_package: string
  current_version: string
  target_version: string
  workspace_dir: string

schema commit_intent:
  type: string
  scope: string
  subject: string
  full_message: string
  files: string[]
  committed: bool

schema commit_files_input:
  files: string[]

schema commit_files_output:
  files_lines: string

schema commit_tool_input:
  full_message: string
  files_lines: string
  workspace_dir: string

schema commit_result:
  success: bool
  output: string

schema revert_input:
  workspace_dir: string
  pkg_manager: string
  install_cmd_hint: string
  workspaces: string[]
  notes: string

schema revert_result:
  success: bool
  output: string

schema mark_failed_input:
  selected_package: string
  reason: string

schema mark_failed_result:
  package: string
  reason: string

schema review_input:
  start_sha: string
  prior_pushback: string[]
  prior_pushback_justification: string
  previous_scanned_areas: string[]
  workspace_dir: string

schema review_verdict:
  approved: bool
  family: string [enum: "claude", "gpt"]
  blockers: string[]
  fix_plan: string
  confidence: string [enum: "low", "medium", "high"]
  scanned_areas: string[]

schema streak_state:
  stop: bool
  approved: bool
  family: string
  blockers: string[]
  fix_plan: string
  cumulative_scanned_areas: string[]

schema review_fix_input:
  blockers: string[]
  fix_plan: string

schema review_fix_result:
  applied: bool
  summary: string
  pushback: string[]
  pushback_justification: string

## review_commit_input carries everything review_commit_auto needs to
## build a meaningful commit subject + body. `family` and `iteration`
## are tags for traceability; `summary` is the fixer's free-form
## description that becomes the commit subject (first line, 72ch cap)
## and body.
schema review_commit_input:
  workspace_dir: string
  family: string
  iteration: int
  summary: string

## ─── Schemas : audit-trail + patch-batching paths ────────────────────

## audit_md_input drives write_audit_md, which materialises a
## per-package markdown trail under docs/renovacy/ so humans (and
## downstream LLMs reading the repo on a later run) can reconstruct
## the *why* of every upgrade without spelunking through the run log.
## All fields are JSON-typed so structured upstream outputs (verdicts,
## blockers, scanned areas) round-trip without lossy stringification.
schema audit_md_input:
  workspace_dir: string
  package_name: string
  current_version: string
  target_version: string
  risk: string
  changelog_summary: json
  security_report: json
  align_summary: string
  validate_report: json
  commit_sha: string
  batch_packages: json

schema audit_md_result:
  success: bool
  output: string
  ## was_batch is true when write_audit_md was called from the patch
  ## fast-track (batch_packages array non-empty). Drives the
  ## downstream routing back to select_candidate: batch path passes
  ## `attempted: outputs.bucket_patches.attempted_after_batch` so the
  ## per-package loop skips already-bumped patches; per-package path
  ## passes `outputs.select_candidate.cumulative_attempted` (the
  ## iteratively-grown ledger).
  was_batch: bool

## bucket_patches_input is the single shape consumed by the
## bucket_patches compute node: it forwards discover_outdated.packages
## verbatim so the deterministic JS can filter to risk=="patch"
## without re-discovering.
schema bucket_patches_input:
  packages: json
  scope: string

## bucket_patches_output exposes the patches[] subset plus the
## auxiliary fields the workflow needs: has_patches gates the
## fast-track edge; attempted_after_batch is the name → metadata map
## ready to drop into the next select_candidate's `attempted` slot so
## the per-package loop skips every patch the batch already moved.
schema bucket_patches_output:
  patches: json
  has_patches: bool
  patches_count: int
  attempted_after_batch: json

## batch_upgrade_input drives batch_upgrade_patches: the yarn up tool
## invocation takes the array of `{name, current, target}` triples and
## the manager hint from detect_stack.
schema batch_upgrade_input:
  workspace_dir: string
  pkg_manager: string
  patches: json
  notes: string

schema batch_upgrade_result:
  success: bool
  output: string
  upgraded_specs: string[]

## batch_validate_input keeps it deterministic — a shell-based health
## check is enough for the patch tier (lint + tests + typecheck;
## changelog review is skipped by design since patches are
## non-breaking).
schema batch_validate_input:
  workspace_dir: string
  pkg_manager: string
  notes: string

schema batch_validate_result:
  stable: bool
  blockers: string[]
  commands_run: string[]

## batch_commit packs the patches into one conventional-commit message
## ("chore(deps): batch update N patches") and amends the audit-md
## into the same commit so a single git revert can roll back the
## whole batch atomically.
schema batch_commit_input:
  workspace_dir: string
  patches: json
  audit_summary: string

schema batch_commit_result:
  success: bool
  output: string
  sha: string

## batch_revert undoes a failed batch: hard-reset to the worktree's
## start_sha for staged/working changes, then yarn install to restore
## node_modules. The mark_failed_and_continue downstream node then
## records every patch as attempted so the run doesn't retry them
## individually (they'd hit the same failure, just slower).
schema batch_revert_input:
  workspace_dir: string
  pkg_manager: string
  patches: json
  start_sha: string

schema batch_revert_result:
  success: bool
  output: string

schema review_commit_intent:
  type: string
  scope: string
  subject: string
  full_message: string
  files: string[]
  committed: bool

## ─── Nodes : Phase 0 ───────────────────────────────────────────────

agent detect_stack:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  output: stack_profile
  publish: stack_profile_artifact
  system: detect_stack_system
  user: detect_stack_user
  session: fresh
  readonly: true
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 15

## Emit JSON so the runtime maps the SHA onto the declared
## `sha` field. A bare stdout string gets auto-wrapped as
## `{result: "..."}`, leaving `outputs.capture_start_sha.sha`
## empty — and Phase 2's review nodes diff against an empty
## base, which silently degrades to "review the whole repo".
tool capture_start_sha:
  command: "printf '{\"sha\":\"%s\"}' \"$(git -C {{input.workspace_dir}} rev-parse HEAD)\""
  input: sha_input
  output: sha_output

## ─── Nodes : Phase 1 — discover & select ───────────────────────────

## discover_outdated decides for itself how to enumerate outdated
## packages for the manager identified by detect_stack. Agentified
## because no single shell pipeline normalises across yarn berry,
## npm, pnpm, pip, poetry, cargo, go, composer, bundler, maven,
## gradle without ecosystem-specific quirks — pushing that
## complexity into deterministic jq made the pipeline silently
## return count=0 on yarn berry monorepos and similar setups.
agent discover_outdated:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: discover_input
  output: outdated_list
  system: discover_outdated_system
  user: discover_outdated_user
  session: inherit
  readonly: true
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 25

## select_candidate is a deterministic Node tool — selection is pure
## filter/sort/slice with no need for an LLM. The previous Sonnet
## implementation absorbed whatever wrapper shape `packages` arrived
## in (object map, `{list: [...]}` wrapper, …), which made each run
## non-reproducible. The script below normalises common shapes
## (object keyed by name, array of objects, or single-key wrapper
## like `{list: [...]}`) into a uniform survivor list, then applies
## the policy.
##
## Inputs flow as raw JSON via `{{!input.X}}` substitution into JS
## object/array literals — JSON is a strict subset of JS literal
## syntax, so the substituted text parses verbatim, no jq/shell
## escape juggling. The standalone source-of-truth lives at
## `examples/secured-renovacy.select-candidate.js` for review.
tool select_candidate:
  input: select_input
  output: candidate
  language: js
  script: |
    const packagesRaw = {{!input.packages}};
    const attemptedRaw = {{!input.attempted}};
    const scopeStr = "{{!input.scope}}";
    const maxPackages = {{!input.max_packages}};

    function unwrap(value, wrapperKeys) {
      if (!value || typeof value !== "object" || Array.isArray(value)) return value;
      // Try the explicit wrapper-key list first (stable contract for
      // common LLM-emitted shapes: {list:[...]}, {items:[...]}, etc.).
      for (const key of wrapperKeys) {
        if (Array.isArray(value[key])) return value[key];
      }
      // Fallback: any single-key object whose value is an array is
      // unwrapped automatically. This is what saves us when the
      // upstream LLM decides to wrap under a semantically-meaningful
      // key we didn't anticipate ("outdated", "results", "deps", ...).
      // The shape contract says "array", so we treat any wrapper as
      // noise. If multiple keys are present we leave the object as-is
      // and let downstream report empty so the failure is visible.
      const keys = Object.keys(value);
      if (keys.length === 1 && Array.isArray(value[keys[0]])) {
        return value[keys[0]];
      }
      return value;
    }

    function normaliseEntries(pkgs) {
      if (Array.isArray(pkgs)) {
        return pkgs.map((p) => ({
          name: p.name || "",
          current: p.current || "",
          target: p.target || "",
          risk: p.risk || "unknown",
        }));
      }
      if (pkgs && typeof pkgs === "object") {
        return Object.entries(pkgs).map(([name, v]) => ({
          name,
          current: (v && v.current) || "",
          target: (v && v.target) || "",
          risk: (v && v.risk) || "unknown",
        }));
      }
      return [];
    }

    function attemptedNames(atts) {
      if (Array.isArray(atts)) return atts.map((a) => (a && a.name) || a).filter((n) => typeof n === "string" && n);
      if (atts && typeof atts === "object") return Object.keys(atts);
      return [];
    }

    const packages = unwrap(packagesRaw, ["list", "items", "packages", "data"]);
    const attempted = unwrap(attemptedRaw, ["list"]) || {};
    const scope = scopeStr.split(",").map((s) => s.trim()).filter(Boolean);
    const allowed = scope.includes("all") ? ["patch", "minor", "major", "unknown"] : scope;
    const rank = { patch: 1, minor: 2, major: 3, unknown: 4 };

    const all = normaliseEntries(packages);
    const attemptedList = attemptedNames(attempted);
    const attemptedCount = attemptedList.length;

    const survivors = all
      .filter((p) => !attemptedList.includes(p.name))
      .filter((p) => allowed.includes(p.risk))
      .sort((a, b) => (rank[a.risk] || 4) - (rank[b.risk] || 4));

    // only_patches_attempted: drives the Phase 2 short-circuit. True
    // iff we've attempted at least one upgrade AND every attempt was
    // patch-tier. Computed from cumulative_attempted entries' .risk.
    function computeOnlyPatches(cum) {
      const entries = Object.values(cum || {});
      if (entries.length === 0) return false;
      return entries.every((v) => v && v.risk === "patch");
    }

    let result;
    if (attemptedCount >= maxPackages || survivors.length === 0) {
      result = {
        selected_package: "",
        current_version: "",
        target_version: "",
        risk: "unknown",
        has_more: false,
        attempted_count: attemptedCount,
        cumulative_attempted: attempted,
        fix_loop_max: 0,
        only_patches_attempted: computeOnlyPatches(attempted),
      };
    } else {
      const p = survivors[0];
      const cumulative = { ...attempted, [p.name]: { current: p.current, target: p.target, risk: p.risk } };
      result = {
        selected_package: p.name,
        current_version: p.current,
        target_version: p.target,
        risk: p.risk,
        has_more: true,
        attempted_count: attemptedCount,
        cumulative_attempted: cumulative,
        fix_loop_max: p.risk === "major" ? 5 : 3,
        only_patches_attempted: computeOnlyPatches(cumulative),
      };
    }

    process.stdout.write(JSON.stringify(result));

## ─── Nodes : Phase 1 — security_audit ──────────────────────────────

## security_audit reasons about whether THIS specific upgrade is
## safe. Agentified because a deterministic `grep -qiE
## 'high|critical|malware|malicious'` over multi-format auditor
## output produces both false positives (the word "critical" in a
## comment header) and false negatives (json-nested severity that
## the regex never sees). The agent picks the right native auditor
## per ecosystem, parses structured output, and judges per-package
## instead of returning a project-wide boolean.
agent security_audit:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: audit_input
  output: security_report
  system: security_audit_system
  user: security_audit_user
  session: inherit
  readonly: true
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 25

## ─── Nodes : Phase 1 — changelog_review ────────────────────────────

agent changelog_review:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: changelog_input
  output: changelog_summary
  system: changelog_review_system
  user: changelog_review_user
  session: inherit
  readonly: true
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 20

## ─── Nodes : Phase 1 — upgrade & install ───────────────────────────

## upgrade is agentic so it can adapt to the sandbox's available
## toolchain at runtime. A deterministic shell tool died on yarn berry
## monorepos where `yarn` itself isn't on PATH (vendored release) and
## a static `upgrade_cmd` string from detect_stack therefore fails. The
## agent invokes the manager via whatever shim works (corepack, direct
## `node .yarn/releases/yarn-X.Y.Z.cjs`, …) using `notes` as guidance.
agent upgrade:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: upgrade_input
  output: upgrade_result
  system: upgrade_system
  user: upgrade_user
  session: inherit
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 15

agent install:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: install_input
  output: install_result
  system: install_system
  user: install_user
  session: inherit
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 15

## ─── Nodes : Phase 1 — align_code ──────────────────────────────────

agent align_code:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: align_input
  output: align_result
  system: align_code_system
  user: align_code_user
  session: inherit
  tools: [bash, read_file, write_file, file_edit, glob, grep, git_diff, git_status]
  tool_max_steps: 30

## ─── Nodes : Phase 1 — validate_upgrade ────────────────────────────

agent validate_upgrade:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: validate_input
  output: verdict
  system: validate_upgrade_system
  user: validate_upgrade_user
  session: inherit
  tools: [bash, read_file, list_files, glob, grep, git_diff, git_status]
  tool_max_steps: 25

## ─── Nodes : Phase 1 — fix_after_upgrade ───────────────────────────

agent fix_after_upgrade:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: fix_after_input
  output: fix_after_result
  system: fix_after_upgrade_system
  user: fix_after_upgrade_user
  session: inherit
  tools: [bash, read_file, write_file, file_edit, glob, grep, git_diff, git_status]
  tool_max_steps: 30

## ─── Nodes : Phase 1 — prepare_commit & commit ─────────────────────

agent prepare_commit:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: commit_intent_input
  output: commit_intent
  system: prepare_commit_system
  user: prepare_commit_user
  session: fork
  readonly: true
  tools: [bash, read_file, list_files, git_diff, git_status, git_log]
  tool_max_steps: 10

## join_files turns the agent-emitted `files: string[]` into a single
## newline-delimited string so the tool below can pipe it through
## `tr '\n' '\0' | xargs -0 git add --` — passing each path as its own
## shell argument without the JSON-array-as-one-token bug that broke the
## previous shape of `git add -- {{input.files}}`.
compute join_files:
  input: commit_files_input
  output: commit_files_output
  expr:
    files_lines: "join(input.files, '\n')"

## set -euo pipefail + explicit exit-code checks on every git call
## so a failed `git commit` (missing identity, hook rejection, …)
## surfaces as a real tool failure instead of being papered over by
## a trailing `printf {success:true}`. The previous shape silently
## skipped every package upgrade when the sandbox lacked
## GIT_AUTHOR_EMAIL — all 30 iterations of the loop reported
## "committed" while git refused them all.
tool commit_changes:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
FILES_LINES={{input.files_lines}}
MSG={{input.full_message}}
printf '%s' "$FILES_LINES" | tr '\n' '\0' | xargs -0 git add --
if git diff --cached --quiet; then
  printf '{"success":false,"output":"nothing staged to commit"}\n'
  exit 1
fi
if ! printf '%s' "$MSG" | git commit -F -; then
  printf '{"success":false,"output":"git commit failed"}\n'
  exit 1
fi
if git status --porcelain | grep -q .; then
  printf '%s' "$FILES_LINES" | tr '\n' '\0' | xargs -0 git add --
  if ! git commit --amend --no-edit; then
    printf '{"success":false,"output":"git commit --amend failed"}\n'
    exit 1
  fi
fi
SHA=$(git rev-parse HEAD)
printf '{"success":true,"output":"committed %s"}\n' "$SHA"
`
  input: commit_tool_input
  output: commit_result

## ─── Nodes : Phase 1 — revert + mark_failed ────────────────────────

## revert_changes is agentic so the post-revert reinstall can adapt
## to the same manager-shim concerns as upgrade/install — the
## deterministic `install_cmd` substitution had identical brittleness
## here. The agent restores the worktree to its pre-upgrade state and
## reinstalls dependencies fresh.
agent revert_changes:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: revert_input
  output: revert_result
  system: revert_changes_system
  user: revert_changes_user
  session: inherit
  tools: [bash, read_file, list_files, glob, grep]
  tool_max_steps: 12

## mark_failed_and_continue is a deterministic passthrough — it just
## relays the package name + reason for the next select_candidate
## iteration to bookkeep. Implemented as `compute` instead of a
## shell `echo` to avoid any quoting risk on the {{input.X}} values.
compute mark_failed_and_continue:
  output: mark_failed_result
  expr:
    package: "input.selected_package"
    reason: "input.reason"

## ─── Nodes : Phase 2 — review/fix loop ─────────────────────────────

router alt_review:
  mode: round_robin

judge reviewer_claude:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: review_input
  output: review_verdict
  system: review_system
  user: review_user_claude
  session: inherit
  tools: [bash, read_file, glob, grep, git_diff, git_log, git_status]
  tool_max_steps: 25

judge reviewer_gpt:
  backend: "claw"
  model: "openai/${ITERION_RENOVACY_MODEL_GPT:-gpt-5.5}"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_GPT:-max}"
  input: review_input
  output: review_verdict
  system: review_system
  user: review_user_gpt
  session: fresh
  ## claw backend has no first-class git_diff/git_log/git_status tools
  ## (those are claude_code-only — see pkg/backend/tool/claw_builtins.go).
  ## bash + standard git invocations cover the same reviewer needs.
  tools: [bash, read_file, glob, grep]
  tool_max_steps: 25

compute streak_check:
  output: streak_state
  expr:
    stop: "input.approved && loop.review_loop.previous_output.approved && input.family != loop.review_loop.previous_output.family"
    approved: "input.approved || input.confidence == 'low'"
    family: "input.family"
    blockers: "input.blockers"
    fix_plan: "input.fix_plan"
    cumulative_scanned_areas: "unique(concat(outputs.streak_check.cumulative_scanned_areas, input.scanned_areas))"

agent fix_claude:
  backend: "claude_code"
  provider: "${RESCUE_PROVIDER:-zai}"
  model: "claude-opus-4-7"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_CLAUDE:-max}"
  input: review_fix_input
  output: review_fix_result
  system: fix_system
  user: fix_user
  session: inherit
  tools: [bash, read_file, write_file, file_edit, glob, grep, git_diff, git_status]
  tool_max_steps: 30

agent fix_gpt:
  backend: "claw"
  model: "openai/${ITERION_RENOVACY_MODEL_GPT:-gpt-5.5}"
  reasoning_effort: "${ITERION_RENOVACY_EFFORT_GPT:-max}"
  input: review_fix_input
  output: review_fix_result
  system: fix_system
  user: fix_user
  session: inherit
  ## claw backend: bash subsumes git_diff/git_status (see reviewer_gpt note).
  tools: [bash, read_file, write_file, file_edit, glob, grep]
  tool_max_steps: 30

## Deterministic auto-commit for review fixes. We don't fork an LLM
## session here — fix_X may converge from either family (claude or
## gpt) into this single tool, and `session: fork` would be forbidden
## on a convergence point. The commit subject is built from the fixer's
## summary (first line, capped at 72 chars to satisfy conventional
## commit / git log readability) and tagged with family + recovery_loop
## iteration so the git log makes the alternation visible. Body carries
## the full summary for any LLM/operator running `git log -1`.
## set -euo pipefail + exit on git commit failure — same hardening as
## commit_changes. A nothing-to-commit case is legitimate success
## (review pass produced no actionable diff); a real git error must
## fail the node, not silently report committed.
tool review_commit_auto:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
git add -A
if git diff --cached --quiet; then
  printf '{"success":true,"output":"no review fix changes"}\n'
else
  SUMMARY={{input.summary}}
  FAMILY={{input.family}}
  ITER={{input.iteration}}
  # Subject: first line of summary, truncated to 72 chars; fall back
  # to a generic message if the fixer didn't produce one.
  SUBJECT=$(printf '%s' "$SUMMARY" | head -n1 | cut -c1-72)
  [ -n "$SUBJECT" ] || SUBJECT="cumulative review fix"
  [ -n "$FAMILY" ] || FAMILY="unknown"
  [ -n "$ITER" ] || ITER="0"
  if ! git commit -m "fix(review/${FAMILY}#${ITER}): ${SUBJECT}" -m "${SUMMARY}"; then
    printf '{"success":false,"output":"git commit failed"}\n'
    exit 1
  fi
  SHA=$(git rev-parse HEAD)
  printf '{"success":true,"output":"committed %s"}\n' "$SHA"
fi
`
  input: review_commit_input
  output: commit_result

## ─── Nodes : audit-trail (markdown materialisation) ────────────────

## write_audit_md persists a per-package upgrade record under
## docs/renovacy/<pkg>-<from>-to-<to>.md and appends a row to
## docs/renovacy/INDEX.md, then amends the previous commit so the
## audit doc travels with the upgrade. Keeps the run's rationale
## inspectable by humans (and downstream LLMs reading the repo on a
## later iteration) without re-deriving it from run.log.
##
## Tool node (deterministic JS) — no LLM call. The cost is a few ms
## per package; the value is a permanent paper trail that survives
## the run.
tool write_audit_md:
  language: js
  script: |
    const fs = require("fs");
    const path = require("path");
    const wd = {{!input.workspace_dir}};
    const pkg = {{!input.package_name}};
    const from = {{!input.current_version}};
    const to = {{!input.target_version}};
    const risk = {{!input.risk}};
    const changelog = {{!input.changelog_summary}};
    const security = {{!input.security_report}};
    const align = {{!input.align_summary}};
    const validate = {{!input.validate_report}};
    const sha = {{!input.commit_sha}};
    const batchPackages = {{!input.batch_packages}};

    const sanitize = (s) => String(s || "")
      .replace(/^@/, "")
      .replace(/[^a-zA-Z0-9._-]/g, "-")
      .replace(/-+/g, "-")
      .replace(/^-|-$/g, "");

    const dir = path.join(wd, "docs", "renovacy");
    fs.mkdirSync(dir, { recursive: true });

    function renderSummary(v) {
      if (!v) return "(none)";
      if (typeof v === "string") return v;
      if (typeof v === "object") {
        return "```json\n" + JSON.stringify(v, null, 2) + "\n```";
      }
      return String(v);
    }

    const isBatch = Array.isArray(batchPackages) && batchPackages.length > 0;
    const fnameBase = isBatch
      ? `batch-${batchPackages.length}-patches-${sha.slice(0, 7)}`
      : `${sanitize(pkg)}-${sanitize(from)}-to-${sanitize(to)}`;
    const fname = `${fnameBase}.md`;
    const fpath = path.join(dir, fname);

    const lines = [];
    if (isBatch) {
      lines.push(`# Batch patch upgrade (${batchPackages.length} packages)`);
      lines.push("");
      lines.push(`- **Commit**: \`${sha}\``);
      lines.push(`- **Date**: ${new Date().toISOString().slice(0, 10)}`);
      lines.push("");
      lines.push("## Packages");
      lines.push("");
      lines.push("| Package | From | To |");
      lines.push("|---|---|---|");
      for (const p of batchPackages) {
        lines.push(`| ${p.name} | ${p.current || "?"} | ${p.target || "?"} |`);
      }
      lines.push("");
      lines.push("## Validation");
      lines.push(renderSummary(validate));
    } else {
      lines.push(`# ${pkg} ${from} → ${to}`);
      lines.push("");
      lines.push(`- **Risk**: ${risk}`);
      lines.push(`- **Commit**: \`${sha}\``);
      lines.push(`- **Date**: ${new Date().toISOString().slice(0, 10)}`);
      lines.push("");
      lines.push("## Changelog");
      lines.push(renderSummary(changelog));
      lines.push("");
      lines.push("## Security audit");
      lines.push(renderSummary(security));
      lines.push("");
      lines.push("## Code adaptations");
      lines.push(align || "(none required)");
      lines.push("");
      lines.push("## Validation");
      lines.push(renderSummary(validate));
    }
    lines.push("");

    fs.writeFileSync(fpath, lines.join("\n"));

    // Append/maintain INDEX.md row(s) so a single file is enough to
    // see every upgrade applied so far.
    const indexPath = path.join(dir, "INDEX.md");
    const today = new Date().toISOString().slice(0, 10);
    const indexHeader = [
      "# Renovacy upgrade trail",
      "",
      "| Package | From | To | Risk | Date | Commit | File |",
      "|---|---|---|---|---|---|---|",
      "",
    ].join("\n");

    if (!fs.existsSync(indexPath)) fs.writeFileSync(indexPath, indexHeader);

    let appendRows = "";
    if (isBatch) {
      for (const p of batchPackages) {
        appendRows += `| ${p.name} | ${p.current || "?"} | ${p.target || "?"} | patch | ${today} | \`${sha.slice(0, 7)}\` | [${fname}](./${fname}) |\n`;
      }
    } else {
      appendRows += `| ${pkg} | ${from} | ${to} | ${risk} | ${today} | \`${sha.slice(0, 7)}\` | [${fname}](./${fname}) |\n`;
    }
    fs.appendFileSync(indexPath, appendRows);

    // Amend the upgrade commit so the audit md ships in the same SHA.
    // git add the new/updated files, then `commit --amend --no-edit`.
    const { execSync } = require("child_process");
    try {
      execSync("git add docs/renovacy/", { cwd: wd, stdio: "pipe" });
      execSync("git commit --amend --no-edit", { cwd: wd, stdio: "pipe" });
      process.stdout.write(JSON.stringify({ success: true, output: `audit md amended into ${sha.slice(0, 7)} (${fname})`, was_batch: isBatch }));
    } catch (e) {
      // Treat amend failure as soft — the audit doc still landed on
      // disk; the operator can manually fold it into the next commit.
      process.stdout.write(JSON.stringify({ success: true, output: `audit md written to ${fname}; amend failed: ${e.message}`, was_batch: isBatch }));
    }
  input: audit_md_input
  output: audit_md_result

## ─── Nodes : patch fast-track (bucket + batch upgrade) ──────────────

## bucket_patches splits discover_outdated.packages into a patches[]
## subset (risk == "patch") and emits the auxiliary fields the patch
## fast-track edges need (has_patches gate + attempted_after_batch
## map ready to drop into select_candidate's `attempted` slot so the
## per-package loop downstream skips every patch we batched).
##
## Implemented as a tool with `language: js` rather than a compute
## because iterion's compute expression language doesn't ship `filter`
## / lambda / dict-from-entries primitives — and patching it for this
## one recipe would be over-engineering. The script runs in ~ms; cost
## is negligible.
tool bucket_patches:
  language: js
  script: |
    const raw = {{!input.packages}};
    const scopeStr = "{{!input.scope}}";

    // Normalise discover_outdated's `packages` field to an array of
    // {name, current, target, risk} rows regardless of the shape the
    // LLM emitted. Three shapes seen in practice:
    //   1. proper array: [{name, current, target, risk}, ...] — keep as-is
    //   2. single-key wrap: {list: [...]} / {items: [...]} / etc. — unwrap
    //   3. object-keyed-by-name: {"@apollo/client": {current, target, risk}, ...}
    //      — emitted whenever the discover_outdated schema is `packages: json`
    //      (which JSON Schema validates as `type: object`). The formatter
    //      then can coerce the array into a name → row map. Merge the key
    //      back into each row as `name`.
    // Anything else → empty array (the batch lane safely degrades to
    // `has_patches: false` and the per-package loop picks up).
    function toRowArray(value) {
      if (Array.isArray(value)) return value;
      if (!value || typeof value !== "object") return [];
      const keys = Object.keys(value);
      if (keys.length === 1 && Array.isArray(value[keys[0]])) return value[keys[0]];
      for (const k of ["list", "items", "packages", "data", "outdated"]) {
        if (Array.isArray(value[k])) return value[k];
      }
      // Object-keyed-by-name: every value is itself an object with at least
      // one of the expected row fields. Guard against {_meta: {...}}-style
      // sidecar keys by requiring a recognisable field.
      const ROW_FIELDS = ["current", "target", "risk", "version", "from", "to"];
      const looksLikePackageMap = keys.length > 0 && keys.every((k) => {
        const v = value[k];
        if (!v || typeof v !== "object" || Array.isArray(v)) return false;
        return ROW_FIELDS.some((f) => Object.prototype.hasOwnProperty.call(v, f));
      });
      if (looksLikePackageMap) {
        return keys.map((k) => Object.assign({ name: k }, value[k]));
      }
      return [];
    }

    // Operator-side scope filter. When scope excludes "patch" (e.g. a
    // run pinned to scope: major), the fast-track must yield an empty
    // batch — even if discover_outdated found patches, the operator
    // explicitly chose not to bump them.
    const allowedRisks = (!scopeStr || scopeStr === "all")
      ? ["patch", "minor", "major", "unknown"]
      : scopeStr.split(",").map((s) => s.trim()).filter(Boolean);
    const patchesAllowed = allowedRisks.includes("patch");

    const list = toRowArray(raw);

    let patches = [];
    if (patchesAllowed) {
      for (const p of list) {
        if (!p || typeof p !== "object") continue;
        // case-insensitive: defensive against LLM drift on discover_outdated
        // emitting "Patch" / "PATCH" instead of the schema's canonical "patch".
        if (String(p.risk || "unknown").toLowerCase() !== "patch") continue;
        patches.push({
          name: p.name || "",
          current: p.current || "",
          target: p.target || "",
          risk: "patch",
        });
      }
    }

    // attempted_after_batch is a name → {current, target, risk} map,
    // ready to be passed verbatim as select_candidate's `attempted`
    // input. When the batch lands (or even when it gets reverted),
    // every patch must be marked as attempted so the per-package
    // loop downstream doesn't retry them one-by-one.
    const attemptedAfterBatch = {};
    for (const p of patches) {
      if (p.name) attemptedAfterBatch[p.name] = { current: p.current, target: p.target, risk: "patch" };
    }

    process.stdout.write(JSON.stringify({
      patches: patches,
      has_patches: patches.length > 0,
      patches_count: patches.length,
      attempted_after_batch: attemptedAfterBatch,
    }));
  input: bucket_patches_input
  output: bucket_patches_output

## batch_upgrade_patches bumps every patch in one yarn up invocation.
## Patches are non-breaking by definition; bundling them saves 30+
## yarn-install round-trips on a typical repo and lets a single test
## pass cover them all. If yarn refuses a spec it fails the whole
## batch — the recipe then falls back to batch_revert and the patches
## are marked attempted so the per-package loop doesn't retry them.
##
## yarn up auto-installs after resolving, so no separate install step
## is needed. The spec list is built defensively (skip entries with
## empty target) and split on whitespace to keep `yarn up` happy with
## a single shell line.
tool batch_upgrade_patches:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
PKG_MGR={{input.pkg_manager}}
PATCHES={{input.patches}}
NOTES={{input.notes}}
# Build the spec list (name@target) from the patches JSON.
SPECS=$(printf '%s' "$PATCHES" | node -e "
  let s='';
  try {
    const arr = JSON.parse(require('fs').readFileSync(0,'utf8'));
    for (const p of arr) {
      if (!p || !p.name || !p.target) continue;
      s += (s ? ' ' : '') + p.name + '@' + p.target;
    }
  } catch (e) { process.exit(2); }
  process.stdout.write(s);
")
if [ -z "$SPECS" ]; then
  printf '{"success":true,"output":"no specs to upgrade","upgraded_specs":[]}\n'
  exit 0
fi
case "$PKG_MGR" in
  yarn|yarn3|yarn4) CMD="yarn up $SPECS" ;;
  npm)              CMD="npm install $SPECS" ;;
  pnpm)             CMD="pnpm update $SPECS" ;;
  bun)              CMD="bun update $SPECS" ;;
  *)                printf '{"success":false,"output":"batch_upgrade_patches: unsupported pkg_manager %s — extend the case block to add it","upgraded_specs":[]}\n' "$PKG_MGR"; exit 1 ;;
esac
if ! eval "$CMD"; then
  printf '{"success":false,"output":"batch upgrade failed: %s","upgraded_specs":[]}\n' "$CMD"
  exit 1
fi
# Emit upgraded_specs as a JSON array for downstream nodes.
UPGRADED_JSON=$(printf '%s' "$SPECS" | node -e "
  const raw = require('fs').readFileSync(0, 'utf8').trim();
  const arr = raw ? raw.split(/\s+/) : [];
  process.stdout.write(JSON.stringify(arr));
")
printf '{"success":true,"output":"batch upgrade succeeded","upgraded_specs":%s}\n' "$UPGRADED_JSON"
`
  input: batch_upgrade_input
  output: batch_upgrade_result

## batch_validate runs a shell-based health check (tests + lint +
## typecheck when relevant) on the post-batch workspace. Deliberately
## NOT an agent: patches are by construction safe enough that LLM
## review adds ~0 value; the cost-saving point of the fast-track is
## precisely to skip those LLM calls. blockers[] captures the failing
## command tails so the operator can diagnose without re-running.
##
## Detection is conservative: only commands that the manager
## advertises are run. A missing `lint` script is NOT a failure; only
## a non-zero exit code from a run command marks the batch unstable.
tool batch_validate:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
PKG_MGR={{input.pkg_manager}}
LOGDIR=/tmp/iterion-batch-validate
mkdir -p "$LOGDIR"
STABLE=true
BLOCKERS=()
CMDS=()

run_check() {
  local name="$1"; shift
  local log="$LOGDIR/$name.out"
  CMDS+=("$*")
  if eval "$*" >"$log" 2>&1; then
    return 0
  else
    STABLE=false
    local tail
    tail=$(tail -c 800 "$log" | tr '\n' ' ' | sed 's/"/\\"/g')
    BLOCKERS+=("$name: $tail")
    return 1
  fi
}

# Tests: try the canonical script for each manager. jq targets
# .scripts.<name> precisely so a dep called "test-runner" or a
# devDependency key matching "lint" can't trigger a phantom run.
# Missing-script => skip the check (no failure). Real failure =>
# non-zero exit from the script => batch unstable.
has_script() { jq -e --arg n "$1" '.scripts[$n] // empty' package.json >/dev/null 2>&1; }
case "$PKG_MGR" in
  yarn|yarn3|yarn4)
    has_script test      && run_check tests     "yarn test"      || true
    has_script lint      && run_check lint      "yarn lint"      || true
    has_script typecheck && run_check typecheck "yarn typecheck" || true ;;
  npm)
    has_script test      && run_check tests     "npm test --silent"          || true
    has_script lint      && run_check lint      "npm run lint --silent"      || true
    has_script typecheck && run_check typecheck "npm run typecheck --silent" || true ;;
  pnpm)
    has_script test      && run_check tests     "pnpm test"      || true
    has_script lint      && run_check lint      "pnpm lint"      || true
    has_script typecheck && run_check typecheck "pnpm typecheck" || true ;;
  bun)
    has_script test      && run_check tests     "bun test"           || true
    has_script lint      && run_check lint      "bun run lint"       || true
    has_script typecheck && run_check typecheck "bun run typecheck"  || true ;;
esac

BLOCKERS_JSON=$(printf '%s\n' "${BLOCKERS[@]:-}" | node -e "
  const lines = require('fs').readFileSync(0,'utf8').split('\n').filter(Boolean);
  process.stdout.write(JSON.stringify(lines));
")
CMDS_JSON=$(printf '%s\n' "${CMDS[@]:-}" | node -e "
  const lines = require('fs').readFileSync(0,'utf8').split('\n').filter(Boolean);
  process.stdout.write(JSON.stringify(lines));
")
printf '{"stable":%s,"blockers":%s,"commands_run":%s}\n' "$STABLE" "$BLOCKERS_JSON" "$CMDS_JSON"
`
  input: batch_validate_input
  output: batch_validate_result

## batch_commit lands the bundled patch upgrade as a single
## conventional-commit commit. The subject summarises the count, the
## body lists every package@from→to so git log readers see what
## moved.
tool batch_commit:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
PATCHES={{input.patches}}
AUDIT={{input.audit_summary}}
COUNT=$(printf '%s' "$PATCHES" | node -e "
  try { process.stdout.write(String(JSON.parse(require('fs').readFileSync(0,'utf8')).length)); }
  catch { process.stdout.write('0'); }
")
SUBJECT="chore(deps): batch update ${COUNT} patch upgrades"
BODY=$(printf '%s' "$PATCHES" | node -e "
  let lines = '';
  try {
    const arr = JSON.parse(require('fs').readFileSync(0,'utf8'));
    for (const p of arr) {
      if (!p || !p.name) continue;
      lines += '- ' + p.name + ' ' + (p.current || '?') + ' -> ' + (p.target || '?') + '\n';
    }
  } catch (e) {}
  process.stdout.write(lines);
")
git add -A
if git diff --cached --quiet; then
  printf '{"success":false,"output":"nothing staged to commit","sha":""}\n'
  exit 1
fi
COMMIT_MSG=$(printf '%s\n\n%s\n\n%s' "$SUBJECT" "$BODY" "$AUDIT")
if ! printf '%s' "$COMMIT_MSG" | git commit -F -; then
  printf '{"success":false,"output":"git commit failed","sha":""}\n'
  exit 1
fi
SHA=$(git rev-parse HEAD)
printf '{"success":true,"output":"batch committed %s","sha":"%s"}\n' "$SHA" "$SHA"
`
  input: batch_commit_input
  output: batch_commit_result

## batch_revert rolls the batch back atomically when batch_validate
## says unstable. Strategy: hard-reset to the run's start_sha so both
## the manifest changes AND the lockfile / node_modules side-effects
## of `yarn up` disappear; then a fresh install restores a clean
## node_modules. Slower than per-file revert but guarantees a
## consistent state.
tool batch_revert:
  command: `set -euo pipefail
cd {{input.workspace_dir}}
PKG_MGR={{input.pkg_manager}}
START_SHA={{input.start_sha}}
PATCHES={{input.patches}}
if [ -z "$START_SHA" ]; then
  printf '{"success":false,"output":"missing start_sha; cannot revert atomically"}\n'
  exit 1
fi
git reset --hard "$START_SHA" || {
  printf '{"success":false,"output":"git reset --hard failed"}\n'
  exit 1
}
case "$PKG_MGR" in
  yarn|yarn3|yarn4) yarn install || true ;;
  npm)              npm install || true ;;
  pnpm)             pnpm install || true ;;
esac
printf '{"success":true,"output":"reverted batch to %s"}\n' "$START_SHA"
`
  input: batch_revert_input
  output: batch_revert_result

## ─── Nodes : parallel intel (security + changelog in parallel) ──────

## intel_fanout is the entry point for the parallel security + changelog
## investigation. Both downstream agents are read-only and independent;
## running them sequentially as before paid for waiting on the slower of
## the two (~30-90s per package). fan_out_all dispatches both branches
## simultaneously; intel_join awaits both before deciding routing.
##
## Trade-off: when security_audit says "unsafe", we already paid for
## changelog_review tokens (~$1-3). Acceptable because unsafe verdicts
## are rare in practice (most upgrades clear); the time saved on the
## safe path dominates.
router intel_fanout:
  mode: fan_out_all

## intel_join converges the parallel intel branches and exposes a
## flat view downstream nodes can read for routing + prompt context.
## await: wait_all blocks until both security_audit and changelog_review
## have completed. The expr block re-projects the relevant fields so
## the downstream upgrade edge doesn't need to know which agent
## produced which key.
compute intel_join:
  await: wait_all
  output: intel_join_output
  expr:
    safe: "outputs.security_audit.safe"
    security_blockers: "outputs.security_audit.blockers"
    security_fix_plan: "outputs.security_audit.fix_plan"
    changelog_summary: "outputs.changelog_review"

## intel_join_output is consumed by the upgrade edge for routing
## (safe?) and prompt-context (changelog_summary). Defined late
## because the schema references existing types only.
schema intel_join_output:
  safe: bool
  security_blockers: string[]
  security_fix_plan: string
  changelog_summary: json

## phase2_decider routes select_candidate's "no more candidates"
## verdict to the right terminal. Splitting the decision into a
## dedicated compute lets us keep select_candidate's outbound edges
## simple-form ({when has_more, when not has_more}) which satisfies
## the iterion validator's C012 exhaustiveness check (expression-form
## conditions can't be statically proved exhaustive, so the validator
## demands a default — which we'd rather not have).
compute phase2_decider:
  output: phase2_decider_output
  expr:
    go_done: "input.attempted_count == 0 || input.only_patches_attempted"

schema phase2_decider_output:
  go_done: bool

## ─── Workflow ──────────────────────────────────────────────────────

workflow secured_renovacy:
  entry: detect_stack

  worktree: auto

  default_backend: "claude_code"

  interaction: llm_or_human

  ## Sandboxing rationale: this recipe runs `yarn install`, `yarn up`,
  ## `npx`, post-install hooks, etc. — exactly the supply-chain attack
  ## surface it tries to surface via security_audit. Letting agents
  ## execute that chain on the host means a malicious package's
  ## postinstall script runs with the operator's user permissions.
  ##
  ## We pin an explicit `image:` (inline mode) instead of `mode: auto`
  ## because `auto` reuses the target project's
  ## .devcontainer/devcontainer.json — and many devcontainers (e.g.
  ## modjo's) rely on the `features:` block to layer in node/npm,
  ## which iterion does not honour yet (devcontainer features support
  ## is V2 work). The result was a container with no npm, postCreate
  ## that "succeeded" with claude-code never installed, and runs
  ## ending instantly with "claude session ended without result".
  ##
  ## `iterion-sandbox-slim` already ships node 22, npm, git, jq, curl,
  ## devbox + Nix — i.e. everything any package-manager-aware recipe
  ## needs to bootstrap regardless of target project. We layer
  ## claude-code on top via post_create.
  ##
  ## Mounting `${localEnv:HOME}/.claude` into the container's
  ## `/home/devbox/.claude` carries the operator's existing OAuth /
  ## API-key credentials so the in-sandbox claude CLI can talk to
  ## Anthropic without a fresh login flow per run.
  ##
  ## Network stays default (egress allowed) because the workflow MUST
  ## reach the npm registry, GitHub release notes, and osv-scanner's
  ## OSV database. A future tightening would set
  ## `network.preset: package-managers` once that preset lands.
  sandbox:
    ## Image is `:latest` for convenience; pin to an immutable
    ## digest (`ghcr.io/socialgouv/iterion-sandbox-slim@sha256:...`)
    ## once the recipe goes to production so identical runs land on
    ## identical toolchains. The slim image ships Node 22, npm,
    ## git, jq, curl, devbox/Nix. Operators upgrading to
    ## multi-ecosystem repos (Rust, Go, PHP, Maven, Gradle, Ruby,
    ## Elixir, Python — beyond the ones included) need to swap
    ## image for `iterion-sandbox-full` or use devbox/Nix in
    ## post_create to materialise the toolchain.
    image: "ghcr.io/socialgouv/iterion-sandbox-slim:latest"
    user: "devbox"
    workspace_folder: "/workspace"
    ## R&D phase: egress is fully open. Every domain the
    ## downstream agents actually hit (registries, OSV API,
    ## raw.githubusercontent.com, github.com/releases, deps.dev,
    ## telemetry from the SDKs, …) is allowed. Once we've collected
    ## the real domain set from a few production runs, convert
    ## this to `mode: allowlist` with an explicit, observed-and-
    ## safe rule list (probably built on top of the
    ## `iterion-default` preset + project-specific additions).
    network:
      mode: open
    env:
      CLAUDE_CONFIG_DIR: "/home/devbox/.claude"
      ## Git identity for in-sandbox `git commit` calls. Without
      ## these the pipeline's commit step fails with "Author
      ## identity unknown" but the shell tool would still report
      ## success — silent loss of every per-package commit.
      GIT_AUTHOR_NAME: "iterion-secured-renovacy"
      GIT_AUTHOR_EMAIL: "iterion@noreply.local"
      GIT_COMMITTER_NAME: "iterion-secured-renovacy"
      GIT_COMMITTER_EMAIL: "iterion@noreply.local"
    mounts: ["type=bind,source=${localEnv:HOME}/.claude,target=/home/devbox/.claude,consistency=cached"]
    ## post_create:
    ##   - install claude-code CLI (the agentic backbone). Pin to
    ##     a known-good version (currently 2.1.138 per `npm view
    ##     @anthropic-ai/claude-code version` on 2026-05-11) once
    ##     the recipe goes to production; `latest` here lets the
    ##     CLI drift between runs.
    ##   - activate corepack so yarn/pnpm/bun shims resolve from
    ##     the project's `packageManager` field without each
    ##     downstream agent re-discovering the right invocation.
    ##     Corepack ships with Node 22 (no extra install).
    post_create: "set -e; command -v claude >/dev/null 2>&1 || sudo npm install -g @anthropic-ai/claude-code@latest; sudo corepack enable 2>/dev/null || true; corepack prepare --activate 2>/dev/null || true"

  budget:
    max_parallel_branches: 1
    max_duration: "12h"
    max_cost_usd: 100.0
    max_iterations: 500
    max_tokens: 5000000

  compaction:
    threshold: 0.9
    preserve_recent: 8

  ## ═══ Phase 0 : Detect stack + capture base SHA ════════════════════

  detect_stack -> capture_start_sha with {
    workspace_dir: "{{vars.workspace_dir}}"
  }

  capture_start_sha -> discover_outdated with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    lock_files: "{{outputs.detect_stack.lock_files}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  ## ═══ Phase 1 : Patch fast-track + per-package loop ══════════════

  ## bucket_patches splits the discover_outdated.packages list into
  ## patches[] (for the fast-track) and "the rest" (left in the
  ## discover_outdated output for the per-package loop downstream).
  ## When patches.length > 0 we batch them all in a single
  ## yarn-up / validate / commit cycle; the per-package loop then
  ## picks up only minors and majors. The split is gated by `scope`:
  ## a run with scope=major skips the fast-track entirely.
  discover_outdated -> bucket_patches with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}"
  }

  ## has_patches → enter the fast-track. yarn up bundles every patch
  ## in one invocation; install side-effects are bundled too.
  bucket_patches -> batch_upgrade_patches when has_patches with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    patches: "{{outputs.bucket_patches.patches}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  ## !has_patches → go straight to per-package loop with an empty
  ## attempted slot (legacy entry shape preserved).
  bucket_patches -> select_candidate when not has_patches with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}",
    attempted: "[]",
    max_packages: "{{vars.max_packages_per_run}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  batch_upgrade_patches -> batch_validate with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  ## stable → commit the bundle, materialise the audit md, then
  ## proceed to the per-package loop with all patches marked
  ## attempted so it won't retry them.
  batch_validate -> batch_commit when stable with {
    workspace_dir: "{{vars.workspace_dir}}",
    patches: "{{outputs.bucket_patches.patches}}",
    audit_summary: "{{outputs.batch_validate.commands_run}}"
  }

  batch_commit -> write_audit_md with {
    workspace_dir: "{{vars.workspace_dir}}",
    package_name: "",
    current_version: "",
    target_version: "",
    risk: "patch",
    changelog_summary: "",
    security_report: "",
    align_summary: "",
    validate_report: "{{outputs.batch_validate}}",
    commit_sha: "{{outputs.batch_commit.sha}}",
    batch_packages: "{{outputs.bucket_patches.patches}}"
  }

  ## !stable → atomic revert (hard reset to start_sha + reinstall)
  ## then continue with non-patches. The patches are flagged in
  ## attempted_after_batch so we don't retry them.
  batch_validate -> batch_revert when not stable with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    patches: "{{outputs.bucket_patches.patches}}",
    start_sha: "{{outputs.capture_start_sha.sha}}"
  }

  ## After batch_revert: go to select_candidate with all patches
  ## marked attempted, so the per-package loop only sees non-patches.
  batch_revert -> select_candidate with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}",
    attempted: "{{outputs.bucket_patches.attempted_after_batch}}",
    max_packages: "{{vars.max_packages_per_run}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  ## No more candidates → phase2_decider picks the right terminal
  ## (done vs alt_review) based on attempted_count + only_patches_attempted.
  ## Going through a separate compute keeps select_candidate's edges
  ## simple-form so the validator can prove exhaustiveness — see the
  ## phase2_decider declaration for the rationale.
  select_candidate -> phase2_decider when not has_more with {
    attempted_count: "{{outputs.select_candidate.attempted_count}}",
    only_patches_attempted: "{{outputs.select_candidate.only_patches_attempted}}"
  }

  ## phase2_decider routes either to terminal `done` (no useful Phase 2
  ## work to do — either zero attempts or patches-only) or to Phase 2's
  ## cumulative review loop.
  phase2_decider -> done when go_done
  phase2_decider -> alt_review when not go_done

  ## More candidates → parallel intel: security_audit and
  ## changelog_review run simultaneously instead of sequentially.
  ## intel_join converges both and routes based on safety verdict.
  select_candidate -> intel_fanout when has_more with {
    workspace_dir: "{{vars.workspace_dir}}",
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    risk: "{{outputs.select_candidate.risk}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    lock_files: "{{outputs.detect_stack.lock_files}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  ## Fan-out to the two read-only analyses. Both fire concurrently;
  ## intel_join awaits wait_all before routing.
  intel_fanout -> security_audit with {
    workspace_dir: "{{vars.workspace_dir}}",
    selected_package: "{{outputs.select_candidate.selected_package}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    lock_files: "{{outputs.detect_stack.lock_files}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  intel_fanout -> changelog_review with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    risk: "{{outputs.select_candidate.risk}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.detect_stack._session_id}}"
  }

  ## Both converge on intel_join. Routing decision (safe vs unsafe)
  ## happens AFTER both finish, so we never waste tokens by going
  ## straight to upgrade when security flagged the package.
  security_audit -> intel_join
  changelog_review -> intel_join

  ## Unsafe → mark and skip. No revert needed: nothing was applied
  ## (intel_join precedes upgrade).
  intel_join -> mark_failed_and_continue when not safe with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    reason: "security audit flagged the package"
  }

  intel_join -> upgrade when safe with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    upgrade_cmd_hint: "{{outputs.detect_stack.upgrade_cmd}}",
    install_cmd_hint: "{{outputs.detect_stack.install_cmd}}",
    selected_package: "{{outputs.select_candidate.selected_package}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  upgrade -> revert_changes when not success with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    install_cmd_hint: "{{outputs.detect_stack.install_cmd}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  upgrade -> install when success with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    install_cmd_hint: "{{outputs.detect_stack.install_cmd}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  install -> revert_changes when not success with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    install_cmd_hint: "{{outputs.detect_stack.install_cmd}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  install -> align_code when success with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    has_breaking: "{{outputs.changelog_review.has_breaking}}",
    breaking_changes: "{{outputs.changelog_review.breaking_changes}}",
    alignment_steps: "{{outputs.changelog_review.alignment_steps}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.changelog_review._session_id}}"
  }

  align_code -> validate_upgrade with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    risk: "{{outputs.select_candidate.risk}}",
    align_summary: "{{outputs.align_code.summary}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.align_code._session_id}}"
  }

  validate_upgrade -> prepare_commit when stable with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.validate_upgrade._session_id}}"
  }

  validate_upgrade -> fix_after_upgrade when not stable with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    blockers: "{{outputs.validate_upgrade.blockers}}",
    fix_plan: "{{outputs.validate_upgrade.fix_plan}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.validate_upgrade._session_id}}"
  }

  ## fix_loop is per-package: the runtime resets the counter on the
  ## first non-loop edge that re-enters this loop's body from outside
  ## (typically `align_code -> validate_upgrade` after the next
  ## package's upgrade lands). 5 retries per package — enough for
  ## majors that need a few alignment passes, tight enough that a
  ## genuinely stuck package gets reverted instead of burning the
  ## whole budget.
  fix_after_upgrade -> validate_upgrade as fix_loop(5) with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    risk: "{{outputs.select_candidate.risk}}",
    align_summary: "{{outputs.fix_after_upgrade.summary}}",
    workspace_dir: "{{vars.workspace_dir}}",
    _session_id: "{{outputs.fix_after_upgrade._session_id}}"
  }

  ## fix_loop exhausted → revert + skip
  fix_after_upgrade -> revert_changes with {
    workspace_dir: "{{vars.workspace_dir}}",
    pkg_manager: "{{outputs.detect_stack.pkg_manager}}",
    install_cmd_hint: "{{outputs.detect_stack.install_cmd}}",
    workspaces: "{{outputs.detect_stack.workspaces}}",
    notes: "{{outputs.detect_stack.notes}}"
  }

  ## Successful upgrade path → prepare commit → join files → commit.
  prepare_commit -> join_files with {
    files: "{{outputs.prepare_commit.files}}"
  }

  join_files -> commit_changes with {
    workspace_dir: "{{vars.workspace_dir}}",
    full_message: "{{outputs.prepare_commit.full_message}}",
    files_lines: "{{outputs.join_files.files_lines}}"
  }

  ## Per-package audit trail: write docs/renovacy/<pkg>-<from>-to-<to>.md,
  ## update INDEX.md, and `git commit --amend --no-edit` so the audit
  ## doc ships with the upgrade SHA. batch_packages is empty for this
  ## per-package edge — write_audit_md detects single-vs-batch from
  ## the array length.
  commit_changes -> write_audit_md with {
    workspace_dir: "{{vars.workspace_dir}}",
    package_name: "{{outputs.select_candidate.selected_package}}",
    current_version: "{{outputs.select_candidate.current_version}}",
    target_version: "{{outputs.select_candidate.target_version}}",
    risk: "{{outputs.select_candidate.risk}}",
    changelog_summary: "{{outputs.changelog_review}}",
    security_report: "{{outputs.security_audit}}",
    align_summary: "{{outputs.align_code.summary}}",
    validate_report: "{{outputs.validate_upgrade}}",
    commit_sha: "{{outputs.commit_changes.output}}",
    batch_packages: "[]"
  }

  ## Loop back to select_candidate. The attempted slot differs per
  ## context:
  ##   per-package path → outputs.select_candidate.cumulative_attempted
  ##     (the iteratively-grown ledger).
  ##   batch path → outputs.bucket_patches.attempted_after_batch
  ##     (every patch flagged so the loop skips them).
  write_audit_md -> select_candidate when not was_batch as package_loop(50) with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}",
    attempted: "{{outputs.select_candidate.cumulative_attempted}}",
    max_packages: "{{vars.max_packages_per_run}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  write_audit_md -> select_candidate when was_batch with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}",
    attempted: "{{outputs.bucket_patches.attempted_after_batch}}",
    max_packages: "{{vars.max_packages_per_run}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  ## Failure path: revert (or already reverted) → mark failed → loop back.
  revert_changes -> mark_failed_and_continue with {
    selected_package: "{{outputs.select_candidate.selected_package}}",
    reason: "fix_loop exhausted or install/upgrade failed"
  }

  mark_failed_and_continue -> select_candidate as package_loop(50) with {
    packages: "{{outputs.discover_outdated.packages}}",
    scope: "{{vars.scope}}",
    attempted: "{{outputs.select_candidate.cumulative_attempted}}",
    max_packages: "{{vars.max_packages_per_run}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  ## ═══ Phase 2 : Alternating review/fix on cumulative diff ═════════

  alt_review -> reviewer_claude with {
    start_sha: "{{outputs.capture_start_sha.sha}}",
    prior_pushback: "{{outputs.fix_gpt.pushback}}",
    prior_pushback_justification: "{{outputs.fix_gpt.pushback_justification}}",
    previous_scanned_areas: "{{outputs.streak_check.cumulative_scanned_areas}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  alt_review -> reviewer_gpt with {
    start_sha: "{{outputs.capture_start_sha.sha}}",
    prior_pushback: "{{outputs.fix_claude.pushback}}",
    prior_pushback_justification: "{{outputs.fix_claude.pushback_justification}}",
    previous_scanned_areas: "{{outputs.streak_check.cumulative_scanned_areas}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  reviewer_claude -> streak_check as review_loop(15) with {
    approved: "{{outputs.reviewer_claude.approved}}",
    family: "{{outputs.reviewer_claude.family}}",
    blockers: "{{outputs.reviewer_claude.blockers}}",
    fix_plan: "{{outputs.reviewer_claude.fix_plan}}",
    confidence: "{{outputs.reviewer_claude.confidence}}",
    scanned_areas: "{{outputs.reviewer_claude.scanned_areas}}"
  }
  reviewer_gpt -> streak_check as review_loop(15) with {
    approved: "{{outputs.reviewer_gpt.approved}}",
    family: "{{outputs.reviewer_gpt.family}}",
    blockers: "{{outputs.reviewer_gpt.blockers}}",
    fix_plan: "{{outputs.reviewer_gpt.fix_plan}}",
    confidence: "{{outputs.reviewer_gpt.confidence}}",
    scanned_areas: "{{outputs.reviewer_gpt.scanned_areas}}"
  }

  streak_check -> done when stop

  streak_check -> alt_review when "approved"

  streak_check -> fix_claude when "!approved && family == 'claude' && length(blockers) > 0" with {
    blockers: "{{outputs.streak_check.blockers}}",
    fix_plan: "{{outputs.streak_check.fix_plan}}",
    _session_id: "{{outputs.reviewer_claude._session_id}}"
  }
  streak_check -> fix_gpt when "!approved && family == 'gpt' && length(blockers) > 0" with {
    blockers: "{{outputs.streak_check.blockers}}",
    fix_plan: "{{outputs.streak_check.fix_plan}}",
    _session_id: "{{outputs.reviewer_gpt._session_id}}"
  }

  ## After each fix round, commit (deterministic) then resume
  ## alternation. fix_claude and fix_gpt both feed into the same
  ## tool — that's a convergence point, but tool nodes have no
  ## session inheritance so C009 does not apply.
  fix_claude -> review_commit_auto with {
    workspace_dir: "{{vars.workspace_dir}}",
    family: "claude",
    iteration: "{{loop.recovery_loop.iteration}}",
    summary: "{{outputs.fix_claude.summary}}"
  }
  fix_gpt -> review_commit_auto with {
    workspace_dir: "{{vars.workspace_dir}}",
    family: "gpt",
    iteration: "{{loop.recovery_loop.iteration}}",
    summary: "{{outputs.fix_gpt.summary}}"
  }

  review_commit_auto -> alt_review as recovery_loop(20)

  ## Loop-exhaustion fallthroughs (when bounded loops hit max).
  ## review_loop / recovery_loop running out means we never converged
  ## on cross-family approval and the cumulative diff still carries
  ## blockers. Route to `fail` so the run terminates with a non-success
  ## status — the operator sees unresolved blockers in
  ## outputs.streak_check.blockers rather than a silent "done".
  reviewer_claude    -> fail
  reviewer_gpt       -> fail
  review_commit_auto -> fail
  streak_check       -> alt_review
