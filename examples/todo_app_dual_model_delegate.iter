## Fixture : todo_app_dual_model_delegate
## Objectif : Workflow de creation d'une todo app (single page HTML)
## orchestrant deux agents IA via delegation MCP :
##   - Claude  -> claude-code (backend: "claude_code")
##   - Codex   -> codex       (backend: "codex")
##
## Phases :
##   1. Claude implemente la todo app (index.html)
##   2. Codex review l'implementation
##   3. Judge decide si c'est pret (boucle max 3 iterations)
##
## Resultat attendu : un fichier index.html autonome dans le workspace.

vars:
  workspace_dir: string = "${PROJECT_DIR}"

## ─── Prompts ────────────────────────────────────────────────────

prompt implement_system:
  Tu es un developpeur frontend expert.
  Tu implementes des applications web completes dans un seul fichier HTML.
  Le code doit etre propre, bien structure et fonctionnel.
  Ecris directement le fichier index.html dans le repertoire courant.

prompt implement_user:
  Implemente une application todo dans un seul fichier index.html
  dans le repertoire courant.

  Description : {{input.app_description}}

  Retour du reviewer precedent :
  {{input.previous_review}}

  Criteres d'acceptation : {{input.acceptance_criteria}}

  Cree le fichier index.html avec tout le HTML, CSS et JS embarques.

prompt review_impl_system:
  Tu es un reviewer de code frontend exigeant.
  Lis le fichier index.html genere et evalue sa qualite,
  sa conformite aux criteres et son bon fonctionnement.

prompt review_impl_user:
  Review l'implementation de cette application todo.
  Lis le fichier index.html dans le repertoire courant.

  Resultat de l'implementation :
  {{input.implementation}}

  Criteres d'acceptation :
  {{input.acceptance_criteria}}

prompt readiness_system:
  Tu determines si l'application todo est prete pour utilisation.
  Evalue la completude et le respect des criteres d'acceptation.

prompt readiness_user:
  Evalue si cette application todo est prete.

  Resultat de l'implementation :
  {{input.implementation}}

  Review :
  {{input.review}}

  Criteres d'acceptation :
  {{input.acceptance_criteria}}

## ─── Schemas ────────────────────────────────────────────────────

schema todo_app_input:
  app_description: string
  acceptance_criteria: string
  previous_review: string

schema impl_output:
  applied: bool
  summary: string
  files_changed: string[]

schema review_input:
  implementation: json
  acceptance_criteria: string

schema review_output:
  summary: string
  issues: string[]
  strengths: string[]

schema readiness_input:
  implementation: json
  review: json
  acceptance_criteria: string

schema readiness_verdict:
  ready: bool
  remaining_issues: string[]
  confidence: string [enum: "low", "medium", "high"]

## ─── Nodes ──────────────────────────────────────────────────────

agent claude_implement:
  backend: "claude_code"
  input: todo_app_input
  output: impl_output
  publish: implementation
  system: implement_system
  user: implement_user
  session: fresh

agent codex_review:
  backend: "codex"
  input: review_input
  output: review_output
  system: review_impl_system
  user: review_impl_user
  session: fresh

judge readiness_judge:
  backend: "claude_code"
  input: readiness_input
  output: readiness_verdict
  publish: final_verdict
  system: readiness_system
  user: readiness_user
  session: fresh

## ─── Workflow ────────────────────────────────────────────────────

workflow todo_app_dual_model_backend:
  vars:
    app_description: string
    acceptance_criteria: string

  entry: claude_implement

  budget:
    max_parallel_branches: 1
    max_duration: "30m"
    max_cost_usd: 20
    max_tokens: 600000

  ## 1. Implementation -> Review
  claude_implement -> codex_review with {
    implementation: "{{outputs.claude_implement}}",
    acceptance_criteria: "{{vars.acceptance_criteria}}"
  }

  ## 2. Review -> Readiness Judge
  codex_review -> readiness_judge with {
    implementation: "{{outputs.claude_implement}}",
    review: "{{outputs.codex_review}}",
    acceptance_criteria: "{{vars.acceptance_criteria}}"
  }

  ## 3. Judge -> done si pret
  readiness_judge -> done when ready

  ## 4. Judge -> rebouclage si pas pret (max 3 iterations)
  readiness_judge -> claude_implement when not ready as impl_loop(3) with {
    app_description: "{{vars.app_description}}",
    previous_review: "{{outputs.codex_review.summary}}",
    acceptance_criteria: "{{vars.acceptance_criteria}}"
  }
