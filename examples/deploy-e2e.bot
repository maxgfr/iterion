## deploy-e2e — deploy to a real test instance and validate end-to-end.
##
## Demonstrates `secrets: { as: file }`: real-world credentials are
## mounted as READ-ONLY files inside the sandbox that the agent USES
## (passes the path / env var to kubectl, curl, the playwright MCP)
## but is instructed NEVER to open, read, cat, print or summarise. The
## values are still redacted from logs (Layer 0) and DLP-scoped to the
## declared hosts (Layer 2). Set the credentials per-run with
## `value:` exprs, host env, or a cloud bot-secret binding;
## `optional: true` lets the workflow validate + run without them (the
## mount is simply skipped).
##
## Must run under a sandbox — file secrets require a real driver.

secrets:
  ## Cluster credentials, exposed via $KUBECONFIG pointing at the file.
  kubeconfig:
    as: file
    env: KUBECONFIG
    optional: true

  ## A deploy/API token, egress-scoped to the test instance host.
  deploy_token:
    as: file
    optional: true
    hosts: ["api.test.example.com"]

vars:
  app_dir: string = "${PROJECT_DIR}"
  test_url: string = "https://app.test.example.com"

prompt deploy_system:
  Build the app in {{vars.app_dir}}, redeploy it to the test cluster
  (KUBECONFIG is already set to the mounted kubeconfig at
  {{secrets.kubeconfig}}), then validate it end-to-end against
  {{vars.test_url}} with the playwright MCP. For any deploy API call,
  read the token inside a single shell command, e.g.
  `--header "Authorization: Bearer $(cat {{secrets.deploy_token}})"` —
  never print, echo or summarise the token. Report whether the
  deployment is healthy and the smoke test passed.

prompt verdict_system:
  Given the deploy result, decide pass/fail. Pass only when deployed,
  healthy AND test_passed are all true; otherwise fail with a concise
  reason so the deploy agent can fix it on retry.

schema deploy_result:
  deployed: bool
  healthy: bool
  test_passed: bool
  notes: string

schema verdict_schema:
  pass: bool
  reason: string

agent deploy_and_test:
  model: "anthropic/claude-sonnet-4-6"
  backend: "claude_code"
  system: deploy_system
  output: deploy_result

judge verdict:
  model: "openai/gpt-5.4-mini"
  backend: "claw"
  system: verdict_system
  output: verdict_schema

workflow deploy_e2e:
  entry: deploy_and_test
  sandbox: auto
  deploy_and_test -> verdict
  verdict -> done when pass
  verdict -> deploy_and_test as retry(2) when not pass
