## Fixture : vision_attachments
##
## But : prouver le bloc `attachments:` end-to-end — l'editor (ou le
## CLI via curl + /api/runs/uploads) attache une image au lancement,
## le runtime materialise Run.Attachments, le moteur multimodal
## (backend claw) injecte l'image en `api.ContentBlock` et l'agent
## decrit ce qu'il voit. Aucun outil supplementaire n'est declare ;
## c'est la voie multimodale native qui fait le travail.
##
## Lancement :
##   1. curl -F file=@logo.png http://localhost:4891/api/runs/uploads
##      → recupere "upload_id"
##   2. curl -X POST http://localhost:4891/api/runs \
##         -H "Content-Type: application/json" \
##         -d '{"file_path":"examples/vision_attachments.iter",
##              "attachments":{"logo":"<upload_id>"}}'

attachments:
  logo: image
    description: "Logo a analyser"
    accept_mime: ["image/png", "image/jpeg", "image/webp"]
    required: true

prompt vision_system:
  You are a careful visual analyst. The user message contains an
  image and a question. Look at the image and answer concisely,
  filling the structured output schema.

prompt vision_user:
  An image attachment was uploaded for this run. The runtime exposes
  its metadata via the `attachments.<name>` namespace:

   - host path : {{attachments.logo}}
   - MIME      : {{attachments.logo.mime}}
   - byte size : {{attachments.logo.size}}
   - SHA-256   : {{attachments.logo.sha256}}

  Fill the output schema with what you observe in those values:
   - description : a one-sentence summary based on the metadata
                   (e.g. "A small PNG image of <size> bytes").
   - saw_image   : true when path/mime/size resolve to non-empty
                   values (i.e. the runtime materialised the
                   attachment), false otherwise.
   - byte_size   : the numeric value of attachments.logo.size.

schema vision_in:
  hint: string

schema vision_out:
  description: string
  saw_image: bool
  byte_size: int

agent describer:
  ## Pure claw text path (default). The metadata is interpolated as
  ## plain text into the prompt. When the workflow is run against an
  ## Anthropic vision-capable model, the executor additionally splits
  ## the prompt and emits the image bytes as a native ContentBlock —
  ## see docs/attachments.md.
  model: "${ITERION_VISION_MODEL}"
  input: vision_in
  output: vision_out
  system: vision_system
  user: vision_user
  session: fresh

workflow vision_attachments:
  entry: describer

  budget:
    max_parallel_branches: 1
    max_duration: "5m"
    max_cost_usd: 1
    max_tokens: 50000

  describer -> done
