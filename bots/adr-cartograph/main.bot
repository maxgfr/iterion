## ─────────────────────────────────────────────────────────────────
## adr-cartograph v0.1.0 — Adry
##
## Read-only ADR cartographer + completeness auditor. Observes the
## code-as-implemented and produces committable ADR markdown (Nygard
## format) in docs/adr/. Each ADR is a "constat" — a record of the
## decision the code embodies, so a future maintainer can re-challenge
## it. ALSO produces a completeness audit for in-flight features:
## what is fully implemented vs what is missing/unfinished.
##
## Reasonably idempotent: re-running on a converged tree does
## (almost) nothing — no new ADR, no commit, no board churn. The
## audit_cache + detect_changes guard keep a no-op pass essentially
## free.
##
## READ-ONLY ON CODE. The fixer's writeable set is .md files under
## `{{vars.adr_dir}}/` and nothing else; `enforce_fix_scope` reverts
## any out-of-scope edit before the next reviewer sees it.
##
## Workflow shape mirrors docs-refresh:
##   - deterministic scan (scan_adrs) — enumerates the ADR set +
##     next_adr_number, cross-references the sha-cache.
##   - read-only code survey (survey_code) — emits ADR-worthy
##     decisions + feature gaps grounded in the code.
##   - deterministic build_manifest — diffs decisions[] vs adrs[]
##     to compute decision_drift + adr_orphans + coverage_pct.
##   - alternating claude_code (opus) / claw (gpt-5.5) reviewers
##     with cross-family double-approval streak gate.
##   - fixers write ONLY under {{vars.adr_dir}}/; enforce_fix_scope
##     reverts anything else.
##   - prepare_commit drafts the commit message AND files optional
##     type:adr-rechallenge / type:feature-gap handoff issues to
##     the board (inside this node, so no-op re-runs never spam).
##
## Inviolable rules (enforced by skills + prompts + tools):
##   1. Code observes; docs/adr/ records.
##   2. Fixer writeable set: `.md` files under {{vars.adr_dir}}/.
##   3. The audit footprint is determined by scan_adrs +
##      survey_code, not by the reviewer/fixer agents.
##   4. Escape valve: ambiguity → ask_user.
## ─────────────────────────────────────────────────────────────────

vars:
  ## The workspace root the run operates against. Resolved to the
  ## worktree when worktree: auto is set on the workflow.
  workspace_dir: string = "${PROJECT_DIR}"

  ## The ADR directory (universal Nygard convention). Override per-
  ## repo only when the target uses a non-default location (e.g.
  ## `architecture/decisions`). See skills/adr-scope-detection.md.
  adr_dir: string = "docs/adr"

  ## Inter-run audit cache. A repo-root dotfile the operator can
  ## gitignore. NOT iterion's `.iterion/` store — Adry runs against
  ## ANY repo and must not scatter `.iterion/` paths into someone
  ## else's tree.
  audit_cache_path: string = ".adr-cartograph-cache.json"

  ## Code scope reviewers + survey may grep / read to verify ADR
  ## claims and find ADR-worthy decisions. UNIVERSAL DEFAULT: empty
  ## = whole workspace minus `excluded_dirs`. A language/layout-
  ## specific scope is a per-repo --var override, never the catalog
  ## default — Adry must run on Python / Rust / TS / Go repos
  ## identically out of the box.
  code_scope_globs: string = ""

  ## Hard-excluded directories. Comma-separated list of dir names
  ## whose presence anywhere in a path disqualifies it from the
  ## code survey AND the audit cache.
  excluded_dirs: string = ".iterion,.works,.claude,vendor,node_modules,.git,dist,build,out"

  ## Incremental mode hint. When non-empty, scan_adrs computes
  ## `git diff <diff_since>...HEAD --name-only` and surfaces the
  ## result as `recently_changed_code_files`. Reviewers + survey
  ## use this as a HINT to prioritise decisions touching recent
  ## code churn. The full code surface is still in scope; the
  ## hint is non-authoritative.
  diff_since: string = ""

  ## Loop bounds — informational only. iterion's DSL requires
  ## literal integer caps on `as <name>(N)` edges, so the actual
  ## bound is hardcoded in the workflow (review_loop(10),
  ## recovery_loop(15)). Edit the workflow to change them; these
  ## vars exist for documentation parity with docs-refresh.
  max_review_iterations: int = 10
  max_recovery_iterations: int = 15

  ## Coverage threshold (percentage of `build_manifest`'s checkable
  ## anchors that must be verified before stop=true can fire).
  ## Default 80 — high enough to defeat the "rubber-stamp after a
  ## partial audit" failure mode, low enough to allow approval when
  ## a small tail of decisions are genuinely too ambiguous to ADR.
  coverage_target_pct: int = 80

  ## Operator's attention pin — free-text notes that flow into both
  ## the survey and the reviewer prompts (e.g. dispatched from an
  ## issue body via dispatch_vars.scope_notes).
  scope_notes: string = ""

  ## Optional re-challenge invitation. When > 0, prepare_commit files
  ## a `type:adr-rechallenge` issue for every ADR whose Date field is
  ## older than `rechallenge_after_days` days. 0 (default) disables
  ## the invitation. Recommended cadence: 90 days for active projects.
  rechallenge_after_days: int = 0

  ## Auto-exclusion. When non-empty, scan_adrs excludes any file
  ## whose path starts with this prefix from the cache footprint,
  ## and survey_code is told to ignore it. Set to
  ## `bots/adr-cartograph` when running Adry against the iterion
  ## repo itself; otherwise leave empty.
  bundle_self_path: string = ""

  ## Dispatcher-attached issue id. mark_issue_for_review transitions
  ## the issue out of `ready` at run end so the dispatcher's
  ## polling loop doesn't re-pick it. Empty for manual CLI runs.
  issue_id: string = ""


## ─── Prompts ────────────────────────────────────────────────────

prompt survey_code_system:
  You are participating in the `adr-cartograph` (Adry) workflow as
  the survey-phase agent. Your job is read-only: explore the code
  in `{{vars.workspace_dir}}` and emit:

  1. A list of ADR-worthy decisions (`decisions[]`) — non-obvious
     trade-offs the code embodies, each with a real alternative
     considered.
  2. A list of feature completeness gaps (`gaps[]`) — places where
     an in-flight feature is stubbed, missing error handling,
     lacks tests, or is otherwise incomplete.

  LOAD YOUR SKILLS FIRST. The bundle ships five skills under
  `.claude/skills/`:
    - `adry.md` — operating playbook, mission, inviolable rules.
    - `decision-vs-mechanic.md` — the dam against ADR-spam.
      EVERY decision you emit must pass its three checks.
    - `completeness-taxonomy.md` — the 8 enum-locked `gap_kind`
      values you must use for every gap entry.
    - `adr-format.md` — the Nygard format you will help author.
    - `adr-scope-detection.md` — where ADRs live in different
      project shapes.

  Read them BEFORE reasoning, then survey the code.

  SCOPE DISCIPLINE:
   - `vars.code_scope_globs` is your code surface. Empty means
     "whole workspace"; respect `vars.excluded_dirs` always.
     `vars.bundle_self_path` (when non-empty) is the bot's own
     bundle directory — do NOT survey it.
   - When `vars.diff_since` is set, prioritise files surfaced by
     `recently_changed_code_files` (a hint, not a scope reduction).
   - Survey is read-only. Do NOT write any file. Do NOT run any
     command that mutates the workspace. Your output is the
     evidence base; the fixer phase will translate it into
     `.md` under `docs/adr/`.

  PER-DECISION DISCIPLINE (decision-vs-mechanic.md applies):
   - non-obvious trade-off: a peer could NOT predict the choice
     from the code alone.
   - real alternative: name a specific other path that was NOT
     taken, AND the constraint that ruled it out.
   - re-challenge condition: a plausible future constraint change
     that would invite reconsidering this decision.
   - If you cannot do all three honestly, set
     `is_mechanic: true` and the reviewer will drop it.

  PER-GAP DISCIPLINE (completeness-taxonomy.md applies):
   - tag every gap with one of the 8 `gap_kind` values.
   - cite file:line evidence inline — `evidence` must contain
     the tool invocation (read_file, grep) and an excerpt.
   - severity:
       high   — shipped, breaks on documented inputs;
       medium — documented edge case fails;
       low    — internal-only inconsistency.

  Operator scope notes (attention pin):
  {{vars.scope_notes}}

prompt survey_code_user:
  Survey the code in {{vars.workspace_dir}} and produce the
  ADR-worthy decisions list + the feature-completeness gaps list.

  Code surface (empty = whole workspace minus excluded_dirs):
   - code_scope_globs: {{vars.code_scope_globs}}
   - excluded_dirs:    {{vars.excluded_dirs}}
   - bundle_self_path: {{vars.bundle_self_path}}

  Existing ADRs (titles + slugs, do not re-author what already exists):
  {{input.adrs}}

  Recently changed code files (a hint, may be empty):
  {{input.recently_changed_code_files}}

  Procedure:
   1. Build a mental map of the major subsystems via the code
      surface. Use Glob + Grep before Read so you spend your tool
      budget on the load-bearing files.
   2. For each subsystem, ask: does the code embody a non-obvious
      decision worth recording? Apply the three checks from
      `decision-vs-mechanic.md`. If yes, populate a `decisions[]`
      entry. If no, move on.
   3. For each in-flight feature you encounter, ask: is the
      implementation complete? Tag any gap with the matching
      `gap_kind` enum from `completeness-taxonomy.md`.
   4. Cap the output: at most 20 decisions + 30 gaps per run.
      Prioritise by severity (gaps) and re-challenge value
      (decisions). The tail surfaces on subsequent runs.

  Output fields (`survey_output`):
   - decisions: structured decision objects (see
     decision-vs-mechanic.md for the per-entry shape;
     `is_mechanic: true` entries are dropped downstream)
   - gaps:      structured gap objects (see
     completeness-taxonomy.md)
   - surveyed_paths: distinct repo-relative paths you read

prompt review_system:
  You are a rigorous ADR + completeness auditor for the
  `adr-cartograph` (Adry) workflow. Your job is to validate the
  drift candidates the deterministic `build_manifest` tool
  surfaced — places where the code embodies a decision but no
  ADR records it (`decision_drift`), or an existing ADR
  references code that no longer exists (`adr_orphans`) — plus
  the gap entries the survey agent emitted.

  LOAD YOUR SKILLS FIRST. The bundle ships five skills:
    - `adry.md` — operating playbook, inviolable rules.
    - `decision-vs-mechanic.md` — the ADR-worthiness dam.
      Drop any candidate whose `is_mechanic` self-critique is
      true OR which fails the three checks.
    - `completeness-taxonomy.md` — the 8 enum-locked `gap_kind`
      values plus severity guidance.
    - `adr-format.md` — the exact Nygard format the fixer will
      emit. Reviewer enforces shape via the suggested_fix.
    - `adr-scope-detection.md` — the location heuristic.

  Read them before reasoning.

  THE INVIOLABLE RULES (restated for emphasis):
   1. Code observes; docs/adr/ records. You raise blockers that
      tell the fixer to AUTHOR or EDIT markdown under
      `{{vars.adr_dir}}/`. You NEVER suggest code edits.
   2. The audit footprint is `input.decision_drift[]`,
      `input.adr_orphans[]`, and `input.gaps[]`. Treat them as
      immutable; do not expand or contract silently.
   3. If a decision-drift candidate fails `decision-vs-mechanic`'s
      three checks, dismiss it. Spamming docs/adr/ with mechanic
      entries defeats the contract.
   4. G4 GATE — fixers must NEVER touch code. Examine
      `input.prior_code_files_touched`. If non-empty, raise an
      automatic blocker (severity: high, confidence: high)
      describing the contract violation.
   5. COVERAGE GATE — `input.coverage_pct` shows the current
      anchor-level coverage from `build_manifest`. The compute
      node `streak_check` mechanically blocks convergence
      (`stop=false`) when `coverage_pct < coverage_target_pct`.
      You may still vote `approved=true` on a partial audit if
      blockers is empty, but the workflow won't terminate until
      coverage meets the threshold across both families.

  HOW TO USE `input.recently_changed_code_files` (a HINT, when
  non-empty): prioritise candidates touching those files —
  recent churn is the most likely source of fresh drift. The
  full candidate set is still your ceiling.

  HUMAN ESCALATION: call `ask_user` only when the code embodies
  two contradictory decisions and you cannot adjudicate. Do NOT
  use it for ordinary judgment calls — lower `confidence`
  instead.

prompt review_user_claude:
  Adjudicate the ADR drift + gap candidates in
  {{vars.workspace_dir}}.

  Iteration: {{loop.review_loop.iteration}}/{{loop.review_loop.max}}
  Family: claude
  Workspace: {{vars.workspace_dir}}
  ADR directory: {{vars.adr_dir}}
  Scope notes:
  {{vars.scope_notes}}

  ## Manifest summary (deterministic)
  Total ADRs scanned:        {{input.total_adrs}}
  Total decisions surveyed:  {{input.total_decisions}}
  Total gaps surveyed:       {{input.total_gaps}}
  Decision drift (in-code, no ADR): {{input.decision_drift_count}}
  ADR orphans  (ADR exists, code removed): {{input.adr_orphans_count}}
  Verified anchors:          {{input.verified_anchors}}
  Coverage:                  {{input.coverage_pct}}% (target {{input.coverage_target_pct}}%)

  Recently changed code files (hint, may be empty):
  {{input.recently_changed_code_files}}

  ## Candidates (the working set)

  Decision drift:
  {{input.decision_drift}}

  ADR orphans:
  {{input.adr_orphans}}

  Gaps:
  {{input.gaps}}

  ## Cross-family context

  Previous reviewer's verdict (other family, last iteration —
  empty on iter 0):
  {{loop.review_loop.previous_output}}

  Items the fixer pushed back as false-positive:
  {{input.prior_pushback}}
  Justification:
  {{input.prior_pushback_justification}}

  ## Gates

  G4 — fixers must NEVER touch code. The field below MUST be an
  empty array; non-empty = automatic contract-violation blocker:
   - prior code files touched: {{input.prior_code_files_touched}}

  ## Your verdict — emit ONLY structured output

  For each decision_drift candidate, decide:
   A. confirm  — real decision worth recording. Raise a blocker
                 with a suggested_fix that authors a new ADR under
                 `{{vars.adr_dir}}/`. Include the suggested
                 filename (`NNN-kebab-slug.md` where NNN comes
                 from input.next_adr_number) and the structured
                 sections per `adr-format.md`.
   B. dismiss  — mechanic, false positive, or already covered by
                 an existing ADR. Do NOT raise a blocker.

  For each adr_orphan, decide:
   A. confirm  — the code is gone for real. Raise a blocker that
                 marks the ADR Status `Superseded` with a short
                 explanation, OR proposes deletion when the ADR
                 captures a discarded design.
   B. dismiss  — the cited code moved (renamed/refactored) but
                 the decision still holds. Suggest updating the
                 Code link instead.

  For each gap with `severity` in {medium, high}, raise a blocker
  whose suggested_fix is the body the prepare_commit node will
  file as a `type:feature-gap` handoff issue.

  Spot-check budget: `tool_max_steps: 25`. Trust the manifest by
  default; spend tool calls on the top 2-3 highest-stakes
  candidates only.

  Output schema (verdict_output):
   - approved: bool — true ONLY when blockers == [] AND
     coverage_pct >= coverage_target_pct
   - family: "claude"
   - blockers: structured mismatch objects
   - blocker_count: int == len(blockers)
   - fix_plan: short instruction set for the fixer
   - confidence: "low" / "medium" / "high"
   - scanned_areas: distinct paths/areas you investigated this iter

prompt review_user_gpt:
  Adjudicate the ADR drift + gap candidates in
  {{vars.workspace_dir}}.

  Iteration: {{loop.review_loop.iteration}}/{{loop.review_loop.max}}
  Family: gpt
  Workspace: {{vars.workspace_dir}}
  ADR directory: {{vars.adr_dir}}
  Scope notes:
  {{vars.scope_notes}}

  ## Manifest summary
  Total ADRs scanned:        {{input.total_adrs}}
  Total decisions surveyed:  {{input.total_decisions}}
  Total gaps surveyed:       {{input.total_gaps}}
  Decision drift (in-code, no ADR): {{input.decision_drift_count}}
  ADR orphans  (ADR exists, code removed): {{input.adr_orphans_count}}
  Verified anchors:          {{input.verified_anchors}}
  Coverage:                  {{input.coverage_pct}}% (target {{input.coverage_target_pct}}%)

  Recently changed code files (hint, may be empty):
  {{input.recently_changed_code_files}}

  ## Candidates

  Decision drift:
  {{input.decision_drift}}

  ADR orphans:
  {{input.adr_orphans}}

  Gaps:
  {{input.gaps}}

  ## Cross-family context

  Previous reviewer's verdict (other family, last iteration —
  empty on iter 0):
  {{loop.review_loop.previous_output}}

  Items the fixer pushed back as false-positive:
  {{input.prior_pushback}}
  Justification:
  {{input.prior_pushback_justification}}

  ## Gates

  G4 — fixers must NEVER touch code. The field below MUST be an
  empty array; non-empty = automatic contract-violation blocker:
   - prior code files touched: {{input.prior_code_files_touched}}

  ## Your verdict — emit ONLY structured output

  For each decision_drift candidate, decide:
   A. confirm  — real decision worth recording. Raise a blocker
                 with a suggested_fix that authors a new ADR under
                 `{{vars.adr_dir}}/` (filename
                 `NNN-kebab-slug.md`, NNN from
                 input.next_adr_number).
   B. dismiss  — mechanic, false positive, or already covered.

  For each adr_orphan: confirm (Status update or deletion) or
  dismiss (update Code link only).

  For each gap with `severity` in {medium, high}: raise a blocker
  whose suggested_fix is the body to file as a
  `type:feature-gap` handoff issue.

  Spot-check budget: `tool_max_steps: 25`. Trust the manifest by
  default; bulk-confirm based on the manifest's evidence alone.

  Output schema (verdict_output):
   - approved: bool — true ONLY when blockers == [] AND
     coverage_pct >= coverage_target_pct
   - family: "gpt"
   - blockers: structured mismatch objects
   - blocker_count: int == len(blockers)
   - fix_plan: concrete instruction set for the fixer (short)
   - confidence: "low" / "medium" / "high"
   - scanned_areas: distinct paths/areas you investigated

prompt fix_system:
  You are the fixer for the `adr-cartograph` (Adry) workflow.
  You apply corrections to ADR markdown files in
  `{{vars.adr_dir}}/` based on blockers a reviewer has identified.

  LOAD YOUR SKILLS FIRST:
    - `adr-format.md` — the EXACT Nygard format you must emit.
      Filename, front-matter bullet list, required sections,
      repo-relative `../../` reference style.
    - `adry.md` — the inviolable rules, especially Rule 2
      (writeable set).
    - `decision-vs-mechanic.md` — refuse blockers whose
      candidate is a mechanic dressed as a decision.

  HARD CONSTRAINTS:
   1. Writeable set: `.md` files under `{{vars.adr_dir}}/` ONLY.
      You may NEVER write to any other path. A deterministic
      `enforce_fix_scope` tool will revert (`git checkout --`)
      any out-of-scope edit before the next reviewer sees it,
      and the offence will be reported back as a chronic-path
      blocker after three repeats.
   2. `fix_output.code_files_touched[]` MUST be empty. The next
      reviewer will flag non-empty as a workflow contract
      violation (G4 gate).
   3. `fix_output.modified_adr_files[]` and
      `fix_output.authored_adr_files[]` MUST be lists of paths
      that all start with `{{vars.adr_dir}}/`.
   4. Use the next_adr_number passed in as
      `input.next_adr_number` for any new ADR. Do not guess
      the number; do not collide with an existing prefix.
   5. Format conformance: filename `NNN-kebab-slug.md`, H1
      `# ADR-NNN: <phrase>`, the four bullet-list front-matter
      items (Status / Date / Authors / Code), then the five
      H2 sections in order. See adr-format.md for the literal
      shape.

  ESCAPE VALVE:
   If a blocker asks you to author an ADR for a candidate that
   fails `decision-vs-mechanic.md`'s three checks (no real
   alternative, no re-challenge condition, etc.), refuse: add it
   to `pushback[]` with a justification.

  PUSHBACK:
   You may refuse a blocker by adding its exact description to
   `pushback[]` with a clear justification in
   `pushback_justification`.

prompt fix_user:
  Apply ADR-only fixes for these blockers in
  {{vars.workspace_dir}}. ADR directory: {{vars.adr_dir}}.

  Next ADR number (for new authored ADRs):
  {{input.next_adr_number}}

  Blockers to address:
  {{input.blockers}}

  Fix plan from the reviewer:
  {{input.fix_plan}}

  For EACH blocker:
   1. Read the code at the cited `code_anchor` to verify the
      current state. Paste the tool invocation and an excerpt
      into your `summary`.
   2. If the blocker asks you to AUTHOR a new ADR:
        - filename: `{{vars.adr_dir}}/NNN-kebab-slug.md` where
          NNN is the next free integer from input.next_adr_number.
        - shape: H1 + front-matter bullet list + the five H2
          sections, per adr-format.md.
        - cite ALL referenced files with repo-relative `../../`
          paths.
        - include at least one alternative with the specific
          constraint that ruled it out.
   3. If the blocker asks you to EDIT an existing ADR (e.g.
      Status update on an orphan), make the minimal edit. Do
      NOT rewrite the whole ADR.
   4. If the blocker is a mechanic dressed as a decision: push
      back with justification per decision-vs-mechanic.md.
   5. If the blocker is a false positive: push back with
      justification.

  Output fields:
   - applied: true if at least one file was written
   - summary: list of fixes with their tool-invocation evidence
   - authored_adr_files: paths of NEW ADRs you created (subset
     of {{vars.adr_dir}}/)
   - modified_adr_files: paths of EXISTING ADRs you edited
     (subset of {{vars.adr_dir}}/)
   - code_files_touched: MUST be []
   - pushback: items refused
   - pushback_justification: explanation


## ─── Prompts : Commit ──────────────────────────────────────────

prompt prepare_commit_system:
  Your job is two-fold: (a) pick the EXACT set of ADR files to
  commit, draft a semantic commit message; and (b) optionally
  file backlog issues that route work to two sibling bots
  (`adr-rechallenge` and `feature-gap-fill`). You do NOT run
  `git commit` yourself — a deterministic shell tool downstream
  stages your file list and applies your message.

  Procedure (in order):
   1. Run `git status` (read-only) to enumerate working-tree
      changes. `git status --porcelain` lists tracked
      modifications AND new files (`??`). INCLUDE new ADR
      files in the commit set. A brand-new file shows nothing
      under `git diff HEAD -- <file>`; confirm a new file by
      READING it, not by diffing.
   2. Cross-reference: every file you stage MUST start with
      `{{vars.adr_dir}}/`. EXCLUDE any file outside that prefix
      (those will have been reverted by enforce_fix_scope, but
      double-check). EXCLUDE LLM scratch files
      (`notes.md`, `plan.txt`, etc.). EXCLUDE the audit cache
      file `{{vars.audit_cache_path}}` (it gets written later
      by update_cache).
   3. Build the structured commit output:
       - type:   "docs" (default for ADR markdown).
       - scope:  "adr"
       - subject: imperative present, ≤ 72 chars, no trailing
                  period. Example: "record fan-out router
                  trade-off as ADR-019"
       - full_message: type(scope): subject + optional body. Body
                  MUST end with a blank line then the trailer
                  `Bot: adr-cartograph` on its own line, so
                  `git log --grep "^Bot: adr-cartograph"` is the
                  cost-telemetry / revert-tracking hook.
       - files:  exact list of repo-relative paths to stage.
       - committed: false (the downstream tool sets this).
       - filed_issue_ids: leave empty here; populated by your
         board calls below.

  ── Handoff issues ─────────────────────────────────────────

  Before emitting your final structured output, file the
  optional handoff issues. RULES:

   a. `list_labels` FIRST. Call
      `mcp__iterion_board__list_labels` to load the current
      label vocabulary. Reuse existing labels (epic / area /
      severity) rather than inventing parallel names.
   b. Routing uses `set_bot` (the canonical dispatcher
      selector), NOT `assign_issue` (which is for human
      ownership). After every `mcp__iterion_board__create_issue`
      call, IMMEDIATELY follow up with
      `mcp__iterion_board__set_bot` to pin the routing bot.
   c. Always include the label `source:adr-cartograph` so a
      future operator can grep the inbox for Adry-originated
      work.

  ── (1) Re-challenge issues — when `rechallenge_after_days > 0`

  For each ADR whose Date is older than
  `vars.rechallenge_after_days` days (the upstream survey
  flagged them in `input.adrs_aged_out[]`), file:

      mcp__iterion_board__create_issue:
        title:  "Re-challenge ADR-NNN: <title>"
        body:   "Code path: <citation>\nOriginal trade-off:
                 <summary>\nWhy re-challenge now: <reason —
                 e.g. age, triggered consequence>"
        state:  "backlog"
        labels: ["type:adr-rechallenge", "source:adr-cartograph",
                 "axis:architecture", "severity:low"]
        fields: { "bot_args": "--var,adr_path={{vars.adr_dir}}/NNN-<slug>.md" }

      mcp__iterion_board__set_bot:
        id:  <issue id from create_issue response>
        bot: "adr-rechallenge"

  ── (2) Feature-gap issues — for each gap with severity in
  ── {medium, high} from `input.gaps_for_handoff[]`

      mcp__iterion_board__create_issue:
        title:  "Complete feature: <feature>"
        body:   "Implemented:\n<implemented summary>\n\n
                 Missing:\n<missing summary>\n\n
                 Evidence:\n<file:line excerpts>"
        state:  "backlog"
        labels: ["type:feature-gap", "source:adr-cartograph",
                 "axis:<best-fit area from list_labels>",
                 "severity:<level>"]
        fields: { "bot_args": "--var,gap_spec=<encoded body>" }

      mcp__iterion_board__set_bot:
        id:  <issue id from create_issue response>
        bot: "feature-gap-fill"

  Be conservative. Zero handoff issues on a no-op pass is the
  correct outcome — and the workflow's idempotency depends on
  it. Re-runs that produce no new commits skip this node
  entirely.

prompt prepare_commit_user:
  Pick the ADR files and produce the commit message for this
  Adry run. Then file any required handoff issues per the
  system prompt's ritual.

  Workspace: {{vars.workspace_dir}}
  ADR dir:   {{vars.adr_dir}}
  Audit cache (EXCLUDE from commit): {{vars.audit_cache_path}}


## ─── Schemas ────────────────────────────────────────────────────

## scan_output: emitted once by scan_adrs. The adrs[] entry
## carries each ADR's metadata + sha so subsequent passes can
## detect changes. next_adr_number is the integer Adry uses for
## newly-authored ADRs (max NNN prefix + 1). duplicates[] is
## non-empty when two ADRs share an NNN prefix (warning only).
schema scan_output:
  adrs: json
  adr_count: int
  next_adr_number: int
  duplicates: string[]
  pre_verified_adrs: string[]
  recently_changed_code_files: string[]
  bundle_self_path: string
  scope_notes: string

## survey_output: emitted by survey_code. decisions[] entries
## carry the per-entry shape defined in decision-vs-mechanic.md
## (title, context, decision, code_paths, alternative,
## rechallenge, is_mechanic). gaps[] entries carry the shape
## from completeness-taxonomy.md (feature, implemented, missing,
## gap_kind, severity, evidence). Both are json because the DSL
## schema parser does not support nested object arrays.
schema survey_output:
  decisions: json
  gaps: json
  surveyed_paths: string[]

## build_manifest input: the working set the deterministic
## differ consumes.
schema build_manifest_input:
  workspace_dir: string
  adr_dir: string
  adrs: json
  decisions: json
  gaps: json
  code_scope_globs: string
  rechallenge_after_days: int

## build_manifest output: the bounded candidate set the
## reviewers consume. decision_drift = decisions[] not yet
## recorded as ADRs. adr_orphans = ADRs whose cited code paths
## no longer exist. gaps_for_handoff = filtered to
## severity in {medium, high}. adrs_aged_out = ADRs whose Date
## is older than rechallenge_after_days days (empty when the
## var is 0).
schema build_manifest_output:
  total_adrs: int
  total_decisions: int
  total_gaps: int
  decision_drift: json
  decision_drift_count: int
  adr_orphans: json
  adr_orphans_count: int
  gaps_for_handoff: json
  adrs_aged_out: json
  verified_anchors: int
  drifted_anchors: int
  checkable_anchors: int
  coverage_pct: int

## review_input: the bounded shape the reviewers receive.
schema review_input:
  total_adrs: int
  total_decisions: int
  total_gaps: int
  decision_drift: json
  decision_drift_count: int
  adr_orphans: json
  adr_orphans_count: int
  gaps: json
  verified_anchors: int
  coverage_pct: int
  coverage_target_pct: int
  recently_changed_code_files: string[]
  next_adr_number: int
  prior_pushback: string[]
  prior_pushback_justification: string
  prior_code_files_touched: string[]
  cumulative_chronic_paths: string[]

## verdict_output: blockers field stays json (the DSL schema
## parser does not support nested object arrays). blocker_count
## is the explicit count so the streak gate can fire on
## "0 blockers" even when the reviewer soft-rejects.
schema verdict_output:
  approved: bool
  family: string [enum: "claude", "gpt"]
  blockers: json
  blocker_count: int
  fix_plan: string
  confidence: string [enum: "low", "medium", "high"]
  scanned_areas: string[]

## streak_state: cross-family streak tracker + revert history
## fed back into enforce_fix_scope.
schema streak_state:
  stop: bool
  approved: bool
  family: string
  blockers: json
  blocker_count: int
  fix_plan: string
  coverage_pct: int
  cumulative_reverted_paths: string[]
  cumulative_chronic_paths: string[]
  cumulative_declared_paths: string[]

schema fix_input:
  blockers: json
  fix_plan: string
  next_adr_number: int

schema fix_output:
  applied: bool
  summary: string
  authored_adr_files: string[]
  modified_adr_files: string[]
  code_files_touched: string[]
  pushback: string[]
  pushback_justification: string

## Commit-phase schemas. filed_issue_ids carries the IDs of any
## handoff issues filed inside prepare_commit so the operator
## can see them in events / reports.
schema commit_output:
  type: string [enum: "docs", "fix"]
  scope: string
  subject: string
  full_message: string
  files: string[]
  committed: bool
  filed_issue_ids: string[]

schema commit_tool_input:
  full_message: string
  files: string[]
  workspace_dir: string

schema commit_result:
  success: bool
  output: string

## Free-form mark_issue_for_review output (matches docs-refresh).
schema mark_issue_output:
  text: string

## update_cache I/O.
schema update_cache_input:
  workspace_dir: string
  cache_path: string
  adr_dir: string

schema update_cache_output:
  cache_path: string
  entries_written: int
  skipped: string

schema detect_changes_output:
  has_changes: bool

## enforce_fix_scope: identical contract to docs-refresh's
## same-named tool, but scoped to {{vars.adr_dir}}/ rather than
## doc_globs. declared_paths is what the fixer claims to have
## written; the tool reverts anything outside the union of
## declared + adr_dir prefix.
schema enforce_fix_scope_input:
  workspace_dir: string
  adr_dir: string
  declared_paths: string[]
  cumulative_so_far: string[]
  cumulative_so_far_declared: string[]

schema enforce_fix_scope_output:
  reverted_paths: string[]
  kept_paths: int
  declared_count: int
  changed_count: int
  chronic_paths: string[]
  declared_iter: string[]


## ─── Nodes ──────────────────────────────────────────────────────

## scan_adrs runs ONCE upstream of the survey + review loop.
## Enumerates {{vars.adr_dir}}/*.md, parses the bullet-list
## front-matter (Status / Date / Authors / Code / Code context),
## computes next_adr_number and duplicates[], and cross-references
## the sha-cache at {{vars.audit_cache_path}} to seed
## pre_verified_adrs[] (those whose content + cited code shas
## are unchanged since the previous successful run).
##
## Tolerant of: (a) the `**Code**:` / `**Code context**:` dual
## convention, (b) duplicate NNN prefixes (warning, not error),
## (c) a missing ADR directory (returns empty arrays — the
## fixer will create the directory on first author).
##
## Raw-string command — the python snippet embeds quotes, so the
## raw form (backtick-quoted) avoids escape hell. Templates
## {{vars.X}} resolve at iterion's command-substitution layer.
tool scan_adrs:
  command: `WS={{vars.workspace_dir}} ADR_DIR={{vars.adr_dir}} CACHE_PATH={{vars.audit_cache_path}} DIFF_SINCE={{vars.diff_since}} BUNDLE_SELF={{vars.bundle_self_path}} EXCLUDED_DIRS={{vars.excluded_dirs}} SCOPE_NOTES={{vars.scope_notes}} python3 -c "
import os, json, glob, hashlib, re, subprocess, datetime
ws = os.environ['WS']
adr_dir = os.environ.get('ADR_DIR', 'docs/adr').strip()
cache_path = os.environ.get('CACHE_PATH', '').strip()
diff_since = os.environ.get('DIFF_SINCE', '').strip()
bundle_self = os.environ.get('BUNDLE_SELF', '').strip().rstrip(os.sep)
scope_notes = os.environ.get('SCOPE_NOTES', '')
EXCLUDE_DIRS = {d.strip() for d in os.environ.get('EXCLUDED_DIRS', '').split(',') if d.strip()}
os.chdir(ws)
def excluded(p):
    if any(part in EXCLUDE_DIRS for part in p.split(os.sep)):
        return True
    if bundle_self and (p == bundle_self or p.startswith(bundle_self + os.sep)):
        return True
    return False
def sha_of_file(p):
    try:
        with open(p, 'rb') as fh:
            return hashlib.sha1(fh.read()).hexdigest()
    except (FileNotFoundError, IsADirectoryError, PermissionError):
        return 'missing'
adr_files = sorted([f for f in glob.glob(os.path.join(adr_dir, '*.md')) if os.path.isfile(f) and not excluded(f)])
NNN_RE = re.compile(r'^(\d{3,4})-([a-z0-9-]+)\.md$')
STATUS_RE = re.compile(r'^\s*-\s*\*\*Status\*\*\s*:\s*(.+?)\s*$', re.MULTILINE)
DATE_RE = re.compile(r'^\s*-\s*\*\*Date\*\*\s*:\s*(\d{4}-\d{2}-\d{2})\s*$', re.MULTILINE)
TITLE_RE = re.compile(r'^#\s*ADR-\d{3,4}\s*:\s*(.+?)\s*$', re.MULTILINE)
CODE_RE = re.compile(r'^\s*-\s*\*\*Code(?:\s+context)?\*\*\s*:\s*(.+)$', re.MULTILINE)
LINK_RE = re.compile(r'\[([^\]]+)\]\(\.\.\/\.\.\/([^)\s]+)\)')
adrs = []
seen_prefixes = {}
duplicates = []
max_nnn = 0
today = datetime.date.today()
for f in adr_files:
    base = os.path.basename(f)
    m = NNN_RE.match(base)
    if not m:
        continue
    nnn = int(m.group(1))
    slug = m.group(2)
    seen_prefixes.setdefault(m.group(1), []).append(f)
    if nnn > max_nnn:
        max_nnn = nnn
    try:
        with open(f, encoding='utf-8', errors='replace') as fh:
            body = fh.read()
    except (FileNotFoundError, IsADirectoryError, PermissionError):
        continue
    status_m = STATUS_RE.search(body)
    date_m = DATE_RE.search(body)
    title_m = TITLE_RE.search(body)
    code_m = CODE_RE.search(body)
    cited_paths = []
    if code_m:
        cited_paths = sorted({m2.group(2) for m2 in LINK_RE.finditer(code_m.group(1))})
    age_days = None
    if date_m:
        try:
            dt = datetime.date.fromisoformat(date_m.group(1))
            age_days = (today - dt).days
        except ValueError:
            age_days = None
    adrs.append({
        'path': f,
        'nnn': m.group(1),
        'slug': slug,
        'title': title_m.group(1) if title_m else '',
        'status': status_m.group(1) if status_m else '',
        'date': date_m.group(1) if date_m else '',
        'age_days': age_days,
        'sha': sha_of_file(f),
        'cited_paths': cited_paths,
    })
for prefix, paths in seen_prefixes.items():
    if len(paths) > 1:
        duplicates.append(prefix)
duplicates.sort()
recent = []
if diff_since:
    try:
        proc = subprocess.run(['git', 'diff', '--name-only', diff_since + '...HEAD'], capture_output=True, text=True, check=True)
        recent = sorted([l for l in proc.stdout.splitlines() if l and not excluded(l)])
    except Exception:
        recent = []
pre_verified = []
if cache_path:
    try:
        with open(cache_path) as cf:
            cache = json.load(cf)
        entries = cache.get('adr', {})
        for a in adrs:
            entry = entries.get(a['path'])
            if not entry:
                continue
            if entry.get('sha') != a['sha']:
                continue
            refs_ok = True
            for ref in entry.get('refs', []):
                p = ref.get('p', '')
                s = ref.get('s', '')
                if not p:
                    continue
                current = sha_of_file(p) if os.path.exists(p) else 'missing'
                if current != s:
                    refs_ok = False
                    break
            if refs_ok:
                pre_verified.append(a['path'])
    except (FileNotFoundError, json.JSONDecodeError):
        pass
print(json.dumps({
    'adrs': adrs,
    'adr_count': len(adrs),
    'next_adr_number': max_nnn + 1,
    'duplicates': duplicates,
    'pre_verified_adrs': sorted(pre_verified),
    'recently_changed_code_files': recent,
    'bundle_self_path': bundle_self,
    'scope_notes': scope_notes,
}))
"`
  output: scan_output

## survey_code: read-only Claude Code agent. Surveys the code in
## vars.workspace_dir, emits ADR-worthy decisions[] + gaps[]
## grounded in real files. Bounded by code_scope_globs +
## excluded_dirs + bundle_self_path. NO writes; fresh session
## (each run is an independent look).
agent survey_code:
  backend: "claude_code"
  model: "${ITERION_ADRY_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_CLAUDE:-max}"
  input: scan_output
  output: survey_output
  system: survey_code_system
  user: survey_code_user
  session: fresh
  readonly: true
  tool_max_steps: 80
  interaction: human

## build_manifest: deterministic diff of decisions[] vs adrs[]
## and adrs[] vs filesystem. Computes:
##   - decision_drift: decisions whose code_paths are not cited
##                     by any existing ADR (after stripping
##                     is_mechanic entries).
##   - adr_orphans:    ADRs whose Code-cited paths no longer
##                     exist on disk (rename/refactor candidates).
##   - gaps_for_handoff: gaps filtered to
##                     severity in {medium, high}.
##   - adrs_aged_out:  ADRs whose age_days exceeds
##                     rechallenge_after_days (empty when 0).
##   - coverage_pct:   verified / checkable anchor ratio.
##
## Pure python; no LLM. Inputs flow via env vars (JSON-encoded for
## arrays).
tool build_manifest:
  command: `WS={{input.workspace_dir}} ADR_DIR={{input.adr_dir}} ADRS='{{!input.adrs}}' DECISIONS='{{!input.decisions}}' GAPS='{{!input.gaps}}' CODE_GLOBS={{input.code_scope_globs}} RECHALLENGE_DAYS={{input.rechallenge_after_days}} python3 -c "
import os, json
ws = os.environ['WS']
os.chdir(ws)
def jload(name, default):
    raw = os.environ.get(name, '')
    if not raw:
        return default
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        return default
adrs = jload('ADRS', [])
decisions = jload('DECISIONS', [])
gaps = jload('GAPS', [])
try:
    rechallenge_days = int(os.environ.get('RECHALLENGE_DAYS', '0'))
except ValueError:
    rechallenge_days = 0
non_mechanic_decisions = [d for d in decisions if not d.get('is_mechanic')]
adr_paths_cited = set()
for a in adrs:
    for p in a.get('cited_paths', []):
        adr_paths_cited.add(p)
decision_drift = []
for d in non_mechanic_decisions:
    code_paths = d.get('code_paths', []) or []
    if not any(p in adr_paths_cited for p in code_paths):
        decision_drift.append(d)
adr_orphans = []
for a in adrs:
    cited = a.get('cited_paths', []) or []
    if not cited:
        continue
    missing = [p for p in cited if not os.path.exists(p)]
    if missing and len(missing) == len(cited):
        out = dict(a)
        out['missing_paths'] = missing
        adr_orphans.append(out)
gaps_for_handoff = [g for g in gaps if g.get('severity') in ('medium', 'high')]
adrs_aged_out = []
if rechallenge_days > 0:
    for a in adrs:
        age = a.get('age_days')
        if isinstance(age, int) and age > rechallenge_days:
            adrs_aged_out.append(a)
verified = len(adrs) - len(adr_orphans)
drifted = len(decision_drift) + len(adr_orphans)
checkable = verified + drifted
coverage_pct = (verified * 100 // checkable) if checkable > 0 else 100
print(json.dumps({
    'total_adrs': len(adrs),
    'total_decisions': len(decisions),
    'total_gaps': len(gaps),
    'decision_drift': decision_drift,
    'decision_drift_count': len(decision_drift),
    'adr_orphans': adr_orphans,
    'adr_orphans_count': len(adr_orphans),
    'gaps_for_handoff': gaps_for_handoff,
    'adrs_aged_out': adrs_aged_out,
    'verified_anchors': verified,
    'drifted_anchors': drifted,
    'checkable_anchors': checkable,
    'coverage_pct': coverage_pct,
}))
"`
  input: build_manifest_input
  output: build_manifest_output

router alt:
  mode: round_robin

judge reviewer_claude:
  backend: "claude_code"
  model: "${ITERION_ADRY_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_CLAUDE:-medium}"
  input: review_input
  output: verdict_output
  system: review_system
  user: review_user_claude
  session: fresh
  tool_max_steps: 25
  interaction: human

judge reviewer_gpt:
  backend: "claw"
  model: "${ITERION_ADRY_MODEL_GPT:-openai/gpt-5.5}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_GPT:-medium}"
  input: review_input
  output: verdict_output
  system: review_system
  user: review_user_gpt
  session: fresh
  tools: [bash, read_file, glob, grep]
  tool_max_steps: 12
  interaction: human

## Deterministic streak detector + coverage gate.
##
## stop=true iff (cross-family double approval) AND
## (coverage_pct >= coverage_target_pct). Soft-approval
## (low-confidence rejection) is passed through as `approved`
## for routing but the streak still requires a hard approval.
##
## blocker_count == 0 is treated as effective approval so a
## "nothing to fix, low-confidence" verdict from both families
## still terminates rather than deadlocking on confidence: low.
compute streak_check:
  output: streak_state
  expr:
    stop: "(input.approved || input.blocker_count == 0) && (loop.review_loop.previous_output.approved || loop.review_loop.previous_output.blocker_count == 0) && input.family != loop.review_loop.previous_output.family && outputs.build_manifest.coverage_pct >= vars.coverage_target_pct"
    approved: "input.approved || input.confidence == 'low' || input.blocker_count == 0"
    family: "input.family"
    blockers: "input.blockers"
    blocker_count: "input.blocker_count"
    fix_plan: "input.fix_plan"
    coverage_pct: "outputs.build_manifest.coverage_pct"
    cumulative_reverted_paths: "concat(outputs.streak_check.cumulative_reverted_paths, input.enforce_reverted_paths)"
    cumulative_chronic_paths: "unique(concat(outputs.streak_check.cumulative_chronic_paths, input.enforce_chronic_paths))"
    cumulative_declared_paths: "unique(concat(outputs.streak_check.cumulative_declared_paths, input.enforce_declared_iter))"

agent fix_claude:
  backend: "claude_code"
  model: "${ITERION_ADRY_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_CLAUDE:-max}"
  input: fix_input
  output: fix_output
  system: fix_system
  user: fix_user
  session: inherit
  interaction: human

agent fix_gpt:
  backend: "claw"
  model: "${ITERION_ADRY_MODEL_GPT:-openai/gpt-5.5}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_GPT:-high}"
  input: fix_input
  output: fix_output
  system: fix_system
  user: fix_user
  session: inherit
  tools: [bash, read_file, write_file, file_edit, glob, grep]
  tool_max_steps: 40
  interaction: human


## ─── Nodes : Commit + handoff issues ────────────────────────────

agent prepare_commit:
  backend: "claude_code"
  model: "${ITERION_ADRY_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_ADRY_EFFORT_CLAUDE:-max}"
  output: commit_output
  system: prepare_commit_system
  user: prepare_commit_user
  session: fresh
  readonly: true
  capabilities: [board.read, board.create, board.assign, board.label]

tool commit_changes:
  command: "git -C {{input.workspace_dir}} add -- {{input.files}} && (git -C {{input.workspace_dir}} diff --cached --quiet || git -C {{input.workspace_dir}} commit -m {{input.full_message}})"
  input: commit_tool_input
  output: commit_result

## mark_issue_for_review: identical pattern to docs-refresh.
## After convergence, transition the tracker issue out of
## `ready` so the dispatcher does not re-pick it. No-op when
## vars.issue_id is empty (manual CLI runs).
tool mark_issue_for_review:
  command: `if [ -n {{vars.issue_id}} ]; then ID={{vars.issue_id}}; ID_SHORT=${ID#native:}; PORT=${ITERION_DISPATCHER_PORT:-4891}; curl -sS -X POST -H "Content-Type: application/json" -d '{"to":"review"}' "http://localhost:${PORT}/api/v1/native/issues/${ID_SHORT}/transition" 2>&1 | head -c 1000 || true; else echo '{"skipped":"no issue_id"}'; fi`
  output: mark_issue_output

## detect_changes: deterministic guard between converged review
## and the commit phase. A no-op pass (no .md written) bypasses
## prepare_commit + commit_changes + mark_issue_for_review and
## goes straight to update_cache + done — so handoff issues are
## NEVER filed when nothing changed.
tool detect_changes:
  command: `WS={{vars.workspace_dir}} CACHE={{vars.audit_cache_path}} python3 -c "
import os, subprocess, json
os.chdir(os.environ['WS'])
cache = os.environ.get('CACHE', '').strip()
lines = subprocess.run(['git', 'status', '--porcelain'], capture_output=True, text=True).stdout.splitlines()
sig = [l for l in lines if l.strip() and not (cache and l[3:].strip() == cache)]
print(json.dumps({'has_changes': len(sig) > 0}))
"`
  output: detect_changes_output

## enforce_fix_scope: HARDER than docs-refresh's same-named tool.
## Adry is read-only on code by mission, so the writeable set is
## the union of declared_paths (what the fixer claims to have
## written) AND any path starting with {{input.adr_dir}}/. Any
## edited file outside that union is reverted via
## `git checkout --`. The cumulative_so_far history is fed
## forward by streak_check so the tool can compute chronic_paths
## itself (≥ 3 reverts of the same path).
##
## Positional argv with -- and --- sentinels so iterion's
## shell-tokenised string[] inputs land as separate argv entries.
tool enforce_fix_scope:
  command: `python3 -c "
import os, json, subprocess, sys
from collections import Counter
args = sys.argv[1:]
ws = args[0] if args else ''
adr_dir = args[1] if len(args) > 1 else 'docs/adr'
rest = args[2:]
try:
    i = rest.index('--')
    declared = set(rest[:i])
    after = rest[i+1:]
    try:
        j = after.index('---')
        cumulative_so_far = after[:j]
        cumulative_declared = set(after[j+1:])
    except ValueError:
        cumulative_so_far = after
        cumulative_declared = set()
except ValueError:
    declared = set(rest)
    cumulative_so_far = []
    cumulative_declared = set()
effective_declared = declared | cumulative_declared
adr_prefix = adr_dir.rstrip('/') + '/'
os.chdir(ws)
try:
    proc = subprocess.run(['git', 'status', '--porcelain'], capture_output=True, text=True, check=True)
    raw = [l for l in proc.stdout.splitlines() if l.strip()]
    changed = set()
    for l in raw:
        path = l[3:].strip()
        if path:
            changed.add(path)
except Exception:
    changed = set()
out_of_scope = sorted(p for p in changed if (p not in effective_declared) and (not p.startswith(adr_prefix)))
reverted = []
for path in out_of_scope:
    try:
        subprocess.run(['git', 'checkout', '--', path], check=True, capture_output=True)
        reverted.append(path)
    except subprocess.CalledProcessError:
        pass
counts = Counter(cumulative_so_far) + Counter(reverted)
chronic = sorted([p for p, c in counts.items() if c >= 3])
print(json.dumps({
    'reverted_paths': reverted,
    'kept_paths': len(changed) - len(reverted),
    'declared_count': len(declared),
    'changed_count': len(changed),
    'chronic_paths': chronic,
    'declared_iter': sorted(declared),
}))
" {{input.workspace_dir}} {{input.adr_dir}} {{input.declared_paths}} -- {{input.cumulative_so_far}} --- {{input.cumulative_so_far_declared}}`
  input: enforce_fix_scope_input
  output: enforce_fix_scope_output

## update_cache: rewrites the inter-run sha-cache so the NEXT
## Adry run can skip pre_verified_adrs. Captures each ADR's
## current sha AND the sha of each path it cites in its Code
## front-matter, so a change in either invalidates the entry.
##
## Empty cache_path disables the write (useful for one-shot CI
## runs that don't persist state).
##
## Runs AFTER commit_changes so a failed commit doesn't poison
## the cache with audit data that wasn't actually shipped. The
## no-change path reaches it directly via detect_changes.
tool update_cache:
  command: `python3 -c "
import os, json, hashlib, re, sys, pathlib, glob
ws = sys.argv[1]
cache_path = sys.argv[2]
adr_dir = sys.argv[3] if len(sys.argv) > 3 else 'docs/adr'
if not cache_path:
    print(json.dumps({'cache_path': '', 'entries_written': 0, 'skipped': 'no cache_path'}))
    sys.exit(0)
os.chdir(ws)
def sha_of_file(p):
    try:
        with open(p, 'rb') as fh:
            return hashlib.sha1(fh.read()).hexdigest()
    except (FileNotFoundError, IsADirectoryError, PermissionError):
        return 'missing'
LINK_RE = re.compile(r'\[([^\]]+)\]\(\.\.\/\.\.\/([^)\s]+)\)')
CODE_RE = re.compile(r'^\s*-\s*\*\*Code(?:\s+context)?\*\*\s*:\s*(.+)$', re.MULTILINE)
adr_entries = {}
for f in sorted(glob.glob(os.path.join(adr_dir, '*.md'))):
    if not os.path.isfile(f):
        continue
    try:
        with open(f, encoding='utf-8', errors='replace') as fh:
            body = fh.read()
    except (FileNotFoundError, IsADirectoryError, PermissionError):
        continue
    code_m = CODE_RE.search(body)
    refs = []
    if code_m:
        cited = sorted({m.group(2) for m in LINK_RE.finditer(code_m.group(1))})
        for p in cited:
            refs.append({'p': p, 's': sha_of_file(p) if os.path.exists(p) else 'missing'})
    adr_entries[f] = {'sha': sha_of_file(f), 'refs': refs}
out_path = pathlib.Path(cache_path)
out_path.parent.mkdir(parents=True, exist_ok=True)
with open(out_path, 'w') as out:
    json.dump({'v': 1, 'adr': adr_entries}, out, indent=2, sort_keys=True)
print(json.dumps({'cache_path': str(out_path), 'entries_written': len(adr_entries), 'skipped': ''}))
" {{input.workspace_dir}} {{input.cache_path}} {{input.adr_dir}}`
  input: update_cache_input
  output: update_cache_output


## ─── Workflow ───────────────────────────────────────────────────

workflow adr_cartograph:
  entry: scan_adrs

  budget:
    max_parallel_branches: 1
    max_duration: "4h"
    max_cost_usd: 120

  compaction:
    threshold: 0.9
    preserve_recent: 8

  scan_adrs -> survey_code
  survey_code -> build_manifest with {
    workspace_dir: "{{vars.workspace_dir}}",
    adr_dir: "{{vars.adr_dir}}",
    adrs: "{{outputs.scan_adrs.adrs}}",
    decisions: "{{outputs.survey_code.decisions}}",
    gaps: "{{outputs.survey_code.gaps}}",
    code_scope_globs: "{{vars.code_scope_globs}}",
    rechallenge_after_days: "{{vars.rechallenge_after_days}}"
  }
  build_manifest -> alt

  ## Round-robin alternates: 1st pass → claude, 2nd → gpt, repeat.
  alt -> reviewer_claude with {
    total_adrs: "{{outputs.build_manifest.total_adrs}}",
    total_decisions: "{{outputs.build_manifest.total_decisions}}",
    total_gaps: "{{outputs.build_manifest.total_gaps}}",
    decision_drift: "{{outputs.build_manifest.decision_drift}}",
    decision_drift_count: "{{outputs.build_manifest.decision_drift_count}}",
    adr_orphans: "{{outputs.build_manifest.adr_orphans}}",
    adr_orphans_count: "{{outputs.build_manifest.adr_orphans_count}}",
    gaps: "{{outputs.build_manifest.gaps_for_handoff}}",
    verified_anchors: "{{outputs.build_manifest.verified_anchors}}",
    coverage_pct: "{{outputs.build_manifest.coverage_pct}}",
    coverage_target_pct: "{{vars.coverage_target_pct}}",
    recently_changed_code_files: "{{outputs.scan_adrs.recently_changed_code_files}}",
    next_adr_number: "{{outputs.scan_adrs.next_adr_number}}",
    prior_pushback: "{{outputs.fix_gpt.pushback}}",
    prior_pushback_justification: "{{outputs.fix_gpt.pushback_justification}}",
    prior_code_files_touched: "{{outputs.fix_claude.code_files_touched}}",
    cumulative_chronic_paths: "{{outputs.streak_check.cumulative_chronic_paths}}"
  }
  alt -> reviewer_gpt with {
    total_adrs: "{{outputs.build_manifest.total_adrs}}",
    total_decisions: "{{outputs.build_manifest.total_decisions}}",
    total_gaps: "{{outputs.build_manifest.total_gaps}}",
    decision_drift: "{{outputs.build_manifest.decision_drift}}",
    decision_drift_count: "{{outputs.build_manifest.decision_drift_count}}",
    adr_orphans: "{{outputs.build_manifest.adr_orphans}}",
    adr_orphans_count: "{{outputs.build_manifest.adr_orphans_count}}",
    gaps: "{{outputs.build_manifest.gaps_for_handoff}}",
    verified_anchors: "{{outputs.build_manifest.verified_anchors}}",
    coverage_pct: "{{outputs.build_manifest.coverage_pct}}",
    coverage_target_pct: "{{vars.coverage_target_pct}}",
    recently_changed_code_files: "{{outputs.scan_adrs.recently_changed_code_files}}",
    next_adr_number: "{{outputs.scan_adrs.next_adr_number}}",
    prior_pushback: "{{outputs.fix_claude.pushback}}",
    prior_pushback_justification: "{{outputs.fix_claude.pushback_justification}}",
    prior_code_files_touched: "{{outputs.fix_gpt.code_files_touched}}",
    cumulative_chronic_paths: "{{outputs.streak_check.cumulative_chronic_paths}}"
  }

  reviewer_claude -> streak_check as review_loop(10) with {
    approved: "{{outputs.reviewer_claude.approved}}",
    family: "{{outputs.reviewer_claude.family}}",
    blockers: "{{outputs.reviewer_claude.blockers}}",
    blocker_count: "{{outputs.reviewer_claude.blocker_count}}",
    fix_plan: "{{outputs.reviewer_claude.fix_plan}}",
    confidence: "{{outputs.reviewer_claude.confidence}}",
    enforce_reverted_paths: "{{outputs.enforce_fix_scope.reverted_paths}}",
    enforce_chronic_paths: "{{outputs.enforce_fix_scope.chronic_paths}}",
    enforce_declared_iter: "{{outputs.enforce_fix_scope.declared_iter}}"
  }
  reviewer_gpt -> streak_check as review_loop(10) with {
    approved: "{{outputs.reviewer_gpt.approved}}",
    family: "{{outputs.reviewer_gpt.family}}",
    blockers: "{{outputs.reviewer_gpt.blockers}}",
    blocker_count: "{{outputs.reviewer_gpt.blocker_count}}",
    fix_plan: "{{outputs.reviewer_gpt.fix_plan}}",
    confidence: "{{outputs.reviewer_gpt.confidence}}",
    enforce_reverted_paths: "{{outputs.enforce_fix_scope.reverted_paths}}",
    enforce_chronic_paths: "{{outputs.enforce_fix_scope.chronic_paths}}",
    enforce_declared_iter: "{{outputs.enforce_fix_scope.declared_iter}}"
  }

  ## Convergence: cross-family double-approval + coverage gate.
  ## EFFICIENCY: route the converged streak through a deterministic
  ## has-changes guard — run the LLM prepare_commit only when the
  ## fixers actually changed the tree. A review-only convergence
  ## (no new ADRs to commit) skips straight to update_cache + done,
  ## so no handoff issues are filed on a no-op pass.
  streak_check -> detect_changes when stop

  detect_changes -> prepare_commit when has_changes
  detect_changes -> update_cache when not has_changes with {
    workspace_dir: "{{vars.workspace_dir}}",
    cache_path: "{{vars.audit_cache_path}}",
    adr_dir: "{{vars.adr_dir}}"
  }

  prepare_commit -> commit_changes with {
    full_message: "{{outputs.prepare_commit.full_message}}",
    files: "{{outputs.prepare_commit.files}}",
    workspace_dir: "{{vars.workspace_dir}}"
  }

  commit_changes -> mark_issue_for_review
  mark_issue_for_review -> update_cache with {
    workspace_dir: "{{vars.workspace_dir}}",
    cache_path: "{{vars.audit_cache_path}}",
    adr_dir: "{{vars.adr_dir}}"
  }

  update_cache -> done

  ## Soft-approval (no streak yet, or low-confidence rejection):
  ## keep alternating without invoking the fixer.
  streak_check -> alt when "approved"

  ## Medium/high-confidence rejection with concrete blockers:
  ## route to the SAME-family fixer (inherit reviewer's session
  ## via _session_id).
  streak_check -> fix_claude when "!approved && family == 'claude' && blocker_count > 0" with {
    blockers: "{{outputs.streak_check.blockers}}",
    fix_plan: "{{outputs.streak_check.fix_plan}}",
    next_adr_number: "{{outputs.scan_adrs.next_adr_number}}",
    _session_id: "{{outputs.reviewer_claude._session_id}}"
  }
  streak_check -> fix_gpt when "!approved && family == 'gpt' && blocker_count > 0" with {
    blockers: "{{outputs.streak_check.blockers}}",
    fix_plan: "{{outputs.streak_check.fix_plan}}",
    next_adr_number: "{{outputs.scan_adrs.next_adr_number}}",
    _session_id: "{{outputs.reviewer_gpt._session_id}}"
  }

  ## Interpose enforce_fix_scope between fix_* and the rebuild
  ## so out-of-scope edits are reverted before the next reviewer
  ## sees them. The loop counter follows the inbound edge —
  ## recovery_loop bounds total fix attempts.
  fix_claude -> enforce_fix_scope as recovery_loop(15) with {
    workspace_dir: "{{vars.workspace_dir}}",
    adr_dir: "{{vars.adr_dir}}",
    declared_paths: "{{outputs.fix_claude.modified_adr_files}}",
    cumulative_so_far: "{{outputs.streak_check.cumulative_reverted_paths}}",
    cumulative_so_far_declared: "{{outputs.streak_check.cumulative_declared_paths}}"
  }
  fix_gpt -> enforce_fix_scope as recovery_loop(15) with {
    workspace_dir: "{{vars.workspace_dir}}",
    adr_dir: "{{vars.adr_dir}}",
    declared_paths: "{{outputs.fix_gpt.modified_adr_files}}",
    cumulative_so_far: "{{outputs.streak_check.cumulative_reverted_paths}}",
    cumulative_so_far_declared: "{{outputs.streak_check.cumulative_declared_paths}}"
  }
  ## Re-run build_manifest after each fix iter so reviewers see
  ## the fresh state. Inputs mirror the initial-flow edge.
  enforce_fix_scope -> build_manifest with {
    workspace_dir: "{{vars.workspace_dir}}",
    adr_dir: "{{vars.adr_dir}}",
    adrs: "{{outputs.scan_adrs.adrs}}",
    decisions: "{{outputs.survey_code.decisions}}",
    gaps: "{{outputs.survey_code.gaps}}",
    code_scope_globs: "{{vars.code_scope_globs}}",
    rechallenge_after_days: "{{vars.rechallenge_after_days}}"
  }

  ## Loop-exhaustion fallthroughs: bounded review_loop /
  ## recovery_loop used up WITHOUT stop firing — route to `fail`
  ## (NOT `done`) so a deterministic non-convergence is visible
  ## rather than masquerading as a silent empty success.
  reviewer_claude -> fail
  reviewer_gpt    -> fail
  fix_claude      -> fail
  fix_gpt         -> fail
  streak_check    -> alt
