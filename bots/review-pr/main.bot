## ─────────────────────────────────────────────────────────────────
## review_pr — "Revi", a read-only cross-family code reviewer.
##
## Revi reviews the changes on the current branch and PUBLISHES the
## findings — it never edits, fixes, or commits code. That mutation
## job belongs to the improve-loops (Billy = branch_improve_loop,
## Willy = whole_improve_loop). Revi is the PR reviewer: it reads the
## diff, reasons about it with two independent reviewers from
## different model families (Claude + GPT), then a single emit step
## merges + de-duplicates their findings and writes them to the
## iterion native kanban board (one issue per finding) plus a markdown
## report.
##
## Shape (single pass — no loop, no convergence, nothing to converge
## ON since Revi changes nothing between iterations):
##
##   fan (fan_out_all)
##     ├─ reviewer_claude  (claude_code, read-only)
##     └─ reviewer_gpt     (claw + openai/gpt-5.5, read-only tools)
##   reviewer_* -> emit    (await: wait_all)   board + markdown report
##   emit -> pr_gate       (deterministic: was a pr_url given?)
##     ├─ no  -> done
##     └─ yes -> publish_review  (skill-guided forge PR review) ->
##               publish_health  (deterministic anti-façade gate) -> done
##
## Cross-family value: an issue flagged by BOTH families is far more
## likely real than one flagged by a single reviewer. emit raises the
## confidence of cross-confirmed findings and labels them so the
## operator can triage agreement first.
##
## Scope discipline (matches the loop bots): reviewers diff the
## WORKING TREE against the merge-base of `base_ref` and HEAD —
## `git diff $(git merge-base base_ref HEAD)` — so both committed and
## uncommitted branch changes are reviewed. To review ONLY the
## uncommitted working tree, run with `--var base_ref=HEAD` (then the
## merge-base is HEAD and the diff is HEAD-vs-working-tree).
##
## Read-only safety: no node mutates source. reviewer_claude is
## `readonly: true`; reviewer_gpt is given only read tools (bash,
## read_file, glob, grep — no write_file/file_edit). The single
## downstream `emit` step writes exactly one file (the report) and
## creates board issues over MCP; it runs after the parallel reviewers
## converge, so the one-mutating-branch workspace rule holds.
##
## v2 opportunity: very large diffs can overflow a reviewer's context.
## The loop bots solve this with a deterministic `plan_chunks` shard
## step; Revi v1 instructs reviewers to triage `git diff --stat` first
## and prioritise the highest-impact hunks. Port plan_chunks here when
## reviewing 1k+ LoC PRs becomes common.
##
## FORGE PR REVIEW (v0.2.0 — implemented, the primary intended use):
## When `--var pr_url=<PR/MR url>` is given, Revi ALSO publishes its
## merged findings directly onto that PR as a proper forge review —
## inline comments anchored to file:line, including ```suggestion
## code-change blocks (when a finding carries a concrete `replacement`)
## the author can apply in one click — on top of the native kanban
## board + markdown report it always writes. Forge-agnostic: the
## `publish_review` step reads the `forge-pr-review.md` skill and
## dispatches by URL host (GitHub `gh`, GitLab `glab`, Forgejo/Gitea
## API) — no forge names are baked into this DSL (universal-bots
## doctrine). A deterministic `publish_health` gate flags a no-op /
## failed publish (findings existed but 0 comments landed) so a façade
## is never silent. `post_to_board` remains the local sink; both run.
##
## Remaining enhancement (not yet built): auto-resolve base/head from
## the PR URL. Today review the LOCAL checkout (base_ref..HEAD) and
## publish to pr_url — so check out the PR branch and pass its base as
## base_ref. See the `pr_url` var doc below. Manual launch against a PR
## (`--var pr_url=<url>`) works today; a PR-event trigger
## (dispatcher/webhook auto-launch on PR open/update) is the other
## remaining enhancement.
## ─────────────────────────────────────────────────────────────────

secrets:
  ## Forge API token used to post the review on a PR/MR when the run is
  ## unattended — e.g. an org webhook launch where no forge CLI is
  ## pre-authenticated on the host. Mounted read-only as a FILE the
  ## publish step hands to `gh`/`glab` (path/env only, never read into a
  ## prompt). `optional: true` so manual/local runs that rely on host
  ## auth (or don't post at all) are unaffected when it isn't provided.
  ## An org binds its forge credential to this name via a bot-secret
  ## binding and can scope egress with the binding's allowed_hosts;
  ## forge-agnostic, so the same name serves GitHub / GitLab / Forgejo.
  forge_token:
    as: file
    optional: true

vars:
  workspace_dir: string = "${PROJECT_DIR}"

  ## Branch comparison base. Reviewers audit
  ## `git diff $(git merge-base base_ref HEAD)` (working tree vs the
  ## merge-base), so committed + uncommitted branch changes are both in
  ## scope. Default "main" covers the common GitHub/GitLab/Forgejo
  ## integration-branch name; pass `--var base_ref=develop` for another
  ## base, or `--var base_ref=HEAD` to review only uncommitted changes.
  base_ref: string = "main"

  ## Free-text steering for the reviewers (e.g. "focus on the new auth
  ## middleware" or "this is a hotfix, prioritise correctness"). Empty
  ## = review the whole diff against the full production-ready grid.
  scope_notes: string = ""

  ## Drop findings below this severity (order: low < medium < high <
  ## critical). Default "low" surfaces everything.
  severity_threshold: string = "low"

  ## Cap the number of board issues / report rows (highest severity
  ## first). A capped run says so prominently in the report so it is
  ## never mistaken for "only N issues exist".
  max_findings: int = 40

  ## When true, emit creates one native-board issue per kept finding
  ## (label source:revi). When false, emit writes the markdown report
  ## only — useful for a read-only PR comment workflow with no board.
  post_to_board: bool = true

  ## Markdown report destination, repo-root-relative. A neutral
  ## dotfile the operator can gitignore — deliberately NOT under
  ## .iterion/ so Revi never scatters engine state into the target
  ## repo's tree.
  report_path: string = ".review-pr/findings.md"

  ## FORGE PR REVIEW (v0.2.0). When set to a pull/merge-request URL,
  ## Revi ALSO publishes its merged findings onto that PR as a real
  ## forge review: one inline comment per finding anchored to file:line,
  ## emitting a one-click ```suggestion block when the finding carries a
  ## concrete `replacement`, else a plain inline comment. Empty (default)
  ## = today's board + markdown-report behaviour only.
  ##
  ## Forge-agnostic: the publish step reads the `forge-pr-review.md`
  ## skill and dispatches by the URL host — GitHub (`gh`), GitLab
  ## (`glab`), or Forgejo/Gitea (API). The relevant CLI must be
  ## authenticated on the host (e.g. `gh auth login`).
  ##
  ## v1 diff model: review the LOCAL checkout (base_ref..HEAD, as
  ## always) and publish to this PR. So check out the PR's branch
  ## locally and pass its base as `base_ref` (e.g.
  ## `--var base_ref=main --var pr_url=https://github.com/o/r/pull/42`).
  ## Auto-resolving base/head from the PR URL is a future enhancement.
  pr_url: string = ""

  ## Review posting mode when pr_url is set: "inline" (default — one
  ## comment per finding anchored to file:line) or "summary" (a single
  ## rolled-up note). Unattended webhook launches default to "summary"
  ## for a lower failure surface (no diff-position mapping); flip to
  ## inline once validated for the target forge.
  pr_review_mode: string = "inline"

## ─── Prompts ────────────────────────────────────────────────────

prompt review_system:
  You are an EXTREMELY demanding, methodical code reviewer performing
  a PRODUCTION-READY review of the changes on the current branch. You
  are READ-ONLY: you NEVER edit, fix, format, or commit anything. Your
  only output is a structured list of findings — fixing is another
  bot's job.

  REVIEW SCOPE (crucial):
  1. Enumerate the changed files with
     `git -C {{vars.workspace_dir}} diff --name-only $(git -C {{vars.workspace_dir}} merge-base {{vars.base_ref}} HEAD)`.
     This is the working-tree diff against the merge-base of
     `{{vars.base_ref}}` and HEAD — it captures the changes the branch
     introduced (committed AND uncommitted). That diff is your scope.
  2. Read the actual diff with
     `git -C {{vars.workspace_dir}} diff $(git -C {{vars.workspace_dir}} merge-base {{vars.base_ref}} HEAD)`.
     On a large diff, read `--stat` first and prioritise the
     highest-impact hunks; never let context overflow silently.
  3. You MAY read surrounding code (callers, conventions, the host
     package) to judge how the change integrates, but you MUST only
     report issues in the CHANGED lines/files. Pre-existing issues the
     branch did not touch are out of scope — note them in `summary`
     at most, never as findings.

  AXES (cover what's relevant to the change):
    - Correctness: logic bugs, off-by-one, wrong conditionals, missing
      cases, broken invariants, incorrect API usage.
    - Security: auth, input validation, secret leaks, injection
      (shell/SQL/template), path traversal, unsafe deserialization,
      SSRF.
    - Concurrency: races, deadlocks, unbalanced locks, double-close,
      unbounded goroutines/channels, missing timeouts.
    - Error handling: swallowed errors, missing checks, panics on
      untrusted input, partial-failure cleanup.
    - Data: migrations, transactions, idempotence, ordering, data loss
      on crash.
    - Performance: O(n^2) on hot paths, N+1 queries, unbounded memory,
      needless allocations on hot paths.
    - Tests & maintainability: missing coverage for the new behaviour,
      dead code, leaky abstractions that will cause bugs.

  ANTI-FAÇADE DISCIPLINE:
    - Report only REAL, concrete, actionable issues anchored to a
      specific `file:line`. Every finding must name what breaks and
      under what condition.
    - NO stylistic nitpicks, NO "consider renaming", NO speculative
      "this could maybe" unless it is a genuine latent bug. If you
      would not block a PR on it, do not file it.
    - Rate each finding's `confidence` honestly. A guess is `low`.
    - Finding nothing is a valid, common outcome — return an empty
      `findings` array and say so in `summary`. Do NOT invent issues
      to look thorough.

  OUTPUT — emit `review_output`:
    - `family`: YOUR model family — "claude" or "gpt" (the user
      message tells you which). Be exact: a wrong family breaks the
      cross-family agreement signal downstream.
    - `findings`: a JSON array. Each finding is an object:
        {
          "file": "relative/path.go",
          "line": 142,
          "line_end": 142,
          "severity": "critical" | "high" | "medium" | "low",
          "category": "correctness" | "security" | "concurrency" |
                      "error-handling" | "data" | "performance" |
                      "tests" | "maintainability",
          "title": "short noun phrase incl. the symptom",
          "detail": "what breaks, under what condition, why it matters",
          "suggestion": "one-line remediation sketch (no patch)",
          "replacement": "",
          "confidence": "low" | "medium" | "high"
        }
      `line` / `line_end`: the anchor span IN THE CHANGED CODE (a single
      line → set both equal). Anchor to lines the branch actually added
      or modified — that is where a forge can attach an inline comment.
      `replacement`: the literal new code for lines [`line`..`line_end`],
      ready to apply in one click (the forge renders it as a ```suggestion
      block). PROVIDE IT whenever the fix is LOCAL and HIGH-CONFIDENCE —
      a competent dev would accept it verbatim. It MAY span several lines
      and change the line count: the forge replaces the WHOLE anchored
      range, so set `line`/`line_end` to the smallest range that fully
      contains the fix and reproduce every UNCHANGED line inside that
      range verbatim. (To ADD a line — e.g. a `defer resp.Body.Close()`
      before line 18 — anchor line=18,line_end=18 and put BOTH the new
      line and the original line 18 in `replacement`.) A clean one-click
      fix is high-value: prefer it over a prose-only sketch. Leave it ""
      ONLY when the fix genuinely is not a localizable replacement — it
      needs edits in other files, an import far from the anchor, or it is
      judgement-dependent (several equally valid approaches). Never put a
      diff, prose, or a partial line in `replacement` — only the literal,
      complete replacement text; when empty, your one-line `suggestion`
      sketch is posted as a plain comment instead.
    - `scanned_areas`: the (axis, file) surfaces you actually audited.
    - `summary`: one paragraph — overall risk read + anything notable
      that did not rise to a finding.

prompt review_user_claude:
  You are the CLAUDE-family reviewer — set `family` to "claude" in your
  output.

  Workspace: {{vars.workspace_dir}}
  Base ref:  {{vars.base_ref}}
  Operator steering (may be empty): {{vars.scope_notes}}

  Run the git scope commands above yourself, read the diff, and produce
  your `review_output`.

prompt review_user_gpt:
  You are the GPT-family reviewer — set `family` to "gpt" in your
  output.

  Workspace: {{vars.workspace_dir}}
  Base ref:  {{vars.base_ref}}
  Operator steering (may be empty): {{vars.scope_notes}}

  Use your `bash`, `read_file`, `glob` and `grep` tools to run the git
  scope commands, read the diff and surrounding code, then produce your
  `review_output`. You have NO write tools — you are read-only by
  construction.

prompt emit_system:
  You merge two INDEPENDENT code reviews (one Claude-family, one
  GPT-family) into a single de-duplicated finding set and PUBLISH it.
  You are read-only on source code: you write exactly one report file
  and (optionally) create kanban issues. You NEVER edit the code under
  review.

  STEP 1 — MERGE & DEDUPE:
    - Union the two `findings` arrays.
    - Two findings are the SAME issue when they share roughly the same
      `file` and overlapping `line` and describe the same defect — even
      if worded differently. Collapse them into one.
    - A finding raised by BOTH families is "cross-confirmed": keep the
      higher severity, set its confidence to "high", and remember to
      label/flag it as agreed-by-both. Cross-confirmed findings are the
      operator's highest-trust signal.
    - Keep family-unique findings too (one reviewer often sees what the
      other misses), at their own confidence.

  STEP 2 — THRESHOLD & CAP:
    - Drop findings whose severity is below `{{vars.severity_threshold}}`
      (low < medium < high < critical).
    - Sort by severity (critical first), then cross-confirmed first.
    - Keep at most `{{vars.max_findings}}`. If you drop any to the cap,
      state it PROMINENTLY at the top of the report (e.g. "⚠ Capped:
      showing N of M findings — raise max_findings or narrow scope and
      re-run") so a capped run is never read as a clean bill of health.

  STEP 3 — BOARD (only when `{{vars.post_to_board}}` is true):
    - Read `{{vars.workspace_dir}}/.claude/skills/iterion-board.md`
      for the board MCP tools before your first call.
    - For each KEPT finding, call `mcp__iterion_board__create_issue`
      ONCE with:
        title  — short noun phrase incl. the anchor, e.g.
                 "SSRF in proxy handler at pkg/server/proxy.go:142"
        body   — markdown, using the template below
        state  — "ready"
        labels — ["severity:<level>", "type:<category>",
                  "source:revi"] plus "cross-confirmed" when both
                  families flagged it. Severity/type labels lowercase.
      One issue per finding. No batching. Capture each returned id;
      collect any rejected create into `failed_issues` and CONTINUE —
      never fail the run on a single rejected issue.
    - When `{{vars.post_to_board}}` is false, skip all board calls and
      leave `issues_created` empty.

    Body template (markdown):
    ```
    ## Anchor
    `<file>:<line>`

    ## Severity / Type / Confidence
    `<severity>` · `<category>` · `<confidence>`<cross-confirmed?>

    ## What breaks
    <detail — the defect and the condition that triggers it>

    ## Fix sketch
    <suggestion — one paragraph, no patch>

    ## Reviewers
    <claude | gpt | both>
    ```

  STEP 4 — REPORT:
    Write a markdown summary to
    `{{vars.workspace_dir}}/{{vars.report_path}}` (create parent dirs):
      # Code review — Revi
      ## Summary       (counts by severity; cross-confirmed count; cap
                        banner if any)
      ## Findings      (table: severity, category, file:line, title,
                        reviewers, board issue id)
      ## Agreement     (one line: N of M findings cross-confirmed)

  RETURN `emit_output`:
    - `report_path`: absolute path of the markdown file you wrote.
    - `total_findings`: number of findings KEPT after threshold+cap.
    - `issues_created`: the board issue ids you created (empty when
      post_to_board is false).
    - `failed_issues`: any board creates the runtime rejected.
    - `findings`: the FINAL merged/threshold/capped finding set as a
      JSON array, in the SAME per-object shape the reviewers emitted —
      preserve `file`, `line`, `line_end`, `severity`, `category`,
      `title`, `detail`, `suggestion`, `replacement`, `confidence`, and
      add `"reviewers": "claude" | "gpt" | "both"`. A downstream step may
      publish these onto a forge PR, so keep `line`/`line_end` and any
      `replacement` exactly as given. This is the same set you reported —
      do not re-summarise or drop fields.

prompt emit_user:
  Workspace:          {{vars.workspace_dir}}
  Severity threshold: {{vars.severity_threshold}}
  Max findings:       {{vars.max_findings}}
  Post to board:      {{vars.post_to_board}}
  Report path:        {{vars.report_path}}

  ── Claude-family review ──
  Summary: {{outputs.reviewer_claude.summary}}
  Findings (JSON):
  {{outputs.reviewer_claude.findings}}
  Areas audited: {{outputs.reviewer_claude.scanned_areas}}

  ── GPT-family review ──
  Summary: {{outputs.reviewer_gpt.summary}}
  Findings (JSON):
  {{outputs.reviewer_gpt.findings}}
  Areas audited: {{outputs.reviewer_gpt.scanned_areas}}

  Merge, dedupe, threshold, cap, publish, and report per your
  instructions.

prompt publish_review_system:
  You publish a completed code review onto a pull / merge request as a
  proper forge review: ONE review carrying an inline comment per
  finding, anchored to the exact `file:line` in the PR's diff. You are
  READ-ONLY on the source code — you post comments, you never edit,
  fix, or commit anything in the workspace.

  LOAD THE `forge-pr-review.md` SKILL FIRST. It is the catalogue: how
  to detect the forge from the PR URL, the exact CLI / API call for
  GitHub, GitLab and Forgejo/Gitea, how to anchor an inline comment to
  a diff line, and the per-forge ```suggestion syntax. Follow it; do
  not improvise an API you have not confirmed there.

  PROCEDURE:
   1. Detect the forge from the PR URL host and confirm the matching
      CLI is authenticated (the skill says how). If the forge is
      unrecognised or the CLI is not authenticated, publish NOTHING:
      return published=false with a precise `skipped_reason`. Never
      pretend to have posted.
   2. For each finding, build an inline comment anchored to its
      `file` + `line`..`line_end`:
        - If `replacement` is non-empty, emit a ```suggestion block
          (per the skill's syntax for this forge) so the author can
          apply the fix in one click. Put the `title` + `detail`
          above the block.
        - Otherwise post a plain inline comment: `title`, then
          `detail`, then the one-line `suggestion` sketch.
        - Prefix each comment with the severity + category + whether it
          was cross-confirmed (`reviewers == "both"`).
      A finding whose line is NOT in the PR diff cannot take an inline
      comment — collect those and include them in the review's summary
      body instead (do not silently drop them).
   3. Post them as a SINGLE review (event = comment, not approve /
      request-changes — Revi advises, it does not gate the merge) with
      a summary body: total findings, severity counts, cross-confirmed
      count, and any findings that could not be anchored inline.
   4. VERIFY: re-fetch the review you just created (the skill gives the
      read call) and COUNT the inline comments the forge actually
      stored. Report that re-fetched count as `comments_posted` — never
      an optimistic self-estimate. Capture the review URL.

  ANTI-FAÇADE: `comments_posted` and `review_url` must come from the
  re-fetch in step 4, and your `summary` must cite the verification
  call you ran. A claim of success with no re-fetch evidence is a
  façade and will be flagged by the downstream health gate.

  STACK / FORGE-AGNOSTIC: the repo and the forge may be anything. Read
  the skill and adapt; never assume a particular forge or language.

prompt publish_review_user:
  Publish this review onto the pull/merge request.

  PR URL:        {{input.pr_url}}
  Workspace:     {{input.workspace_dir}}
  Base ref:      {{input.base_ref}}
  Findings kept: {{input.total_findings}}

  Findings to publish (JSON array — file, line, line_end, severity,
  category, title, detail, suggestion, replacement, confidence,
  reviewers):
  {{input.findings}}

  Follow your system prompt and the `forge-pr-review.md` skill. Post one
  review with inline comments (```suggestion blocks where `replacement`
  is set), then re-fetch to verify.

  Your FINAL action MUST be to emit the `publish_output` structured object
  with ALL fields set: published, forge, review_url, comments_posted,
  suggestions_posted, skipped_reason, summary. Emit it even if some posts
  failed — report the partial counts and put the reason in `summary`. Do NOT
  finish with a prose message; the run fails when the structured output is
  missing.

## ─── Schemas ────────────────────────────────────────────────────

schema review_output:
  ## family is enum-constrained so a hallucinated third value fails
  ## structured-output validation (triggering the retry path) instead
  ## of silently breaking the cross-family agreement signal.
  family: string [enum: "claude", "gpt"]
  ## findings is a free-form JSON array of finding objects (the schema
  ## DSL has no object-array type); the per-object shape is specified
  ## in review_system. emit reads it as JSON.
  findings: json
  scanned_areas: string[]
  summary: string

schema emit_output:
  report_path: string
  total_findings: int
  issues_created: string[]
  failed_issues: string[]
  ## The final merged/capped finding set, carried forward so the forge
  ## publish step can map each finding to an inline PR comment. Same
  ## per-object shape the reviewers emit (file/line/line_end/severity/
  ## category/title/detail/suggestion/replacement/confidence/reviewers).
  findings: json

schema diff_precheck_output:
  is_empty: bool
  changed_files: int

## ─── Forge PR review (v0.2.0) schemas ───────────────────────────

## pr_gate: deterministic branch on whether a PR target was given, so
## the (LLM) publish step is reached ONLY when pr_url is non-empty.
## Carries emit's findings + counts through to publish_review.
schema pr_gate_input:
  pr_url: string
  findings: json
  total_findings: int

schema pr_gate_output:
  has_pr: bool
  pr_url: string
  findings: json
  total_findings: int

schema publish_input:
  pr_url: string
  findings: json
  total_findings: int
  workspace_dir: string
  base_ref: string

schema publish_output:
  ## published: a forge review was successfully created.
  published: bool
  ## forge: "github" | "gitlab" | "forgejo" | "unknown" (detected from
  ## the pr_url host). Free-form string, not a closed DSL enum.
  forge: string
  ## review_url: link to the posted review/comment thread (evidence).
  review_url: string
  ## comments_posted: inline comments the forge ACCEPTED (re-fetched as
  ## evidence, not self-reported optimistically).
  comments_posted: int
  ## suggestions_posted: of those, how many carried a ```suggestion block.
  suggestions_posted: int
  ## skipped_reason: non-empty when nothing was published (e.g. unknown
  ## forge, CLI not authenticated, zero anchorable findings).
  skipped_reason: string
  ## summary: what was posted + the re-fetch evidence behind the counts.
  summary: string

schema publish_health_input:
  published: bool
  comments_posted: int
  total_findings: int
  skipped_reason: string
  review_url: string

## Deterministic anti-façade gate: when a publish was requested AND
## there were findings, at least one inline comment must have landed.
## degraded=true surfaces a loud banner (the board + report already
## succeeded, so this informs rather than hard-fails the run).
schema publish_health_output:
  degraded: bool
  banner: string

## ─── Nodes ──────────────────────────────────────────────────────

## EFFICIENCY guard (deterministic, no LLM): compute the review diff
## (working tree vs the merge-base of base_ref + HEAD — the same diff the
## reviewers audit). If it is empty there is nothing to review, so
## short-circuit past both LLM reviewers + emit and finish fast. Only skips
## when the merge-base resolves AND the diff is empty; on any ambiguity
## (e.g. base_ref absent) it runs the reviewers — never wrongly skips a
## real review.
tool diff_precheck:
  command: `WS={{vars.workspace_dir}} BASE={{vars.base_ref}} python3 -c "
import os, subprocess, json
os.chdir(os.environ['WS'])
base = os.environ.get('BASE', 'main')
mb = subprocess.run(['git', 'merge-base', base, 'HEAD'], capture_output=True, text=True).stdout.strip()
if not mb:
    print(json.dumps({'is_empty': False, 'changed_files': -1})); raise SystemExit(0)
out = subprocess.run(['git', 'diff', '--name-only', mb], capture_output=True, text=True).stdout.strip()
files = [f for f in out.splitlines() if f.strip()]
print(json.dumps({'is_empty': len(files) == 0, 'changed_files': len(files)}))
"`
  output: diff_precheck_output

router fan:
  mode: fan_out_all

judge reviewer_claude:
  backend: "claude_code"
  model: "${ITERION_VIBE_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_VIBE_EFFORT_CLAUDE:-high}"
  output: review_output
  system: review_system
  user: review_user_claude
  session: fresh
  ## Hard read-only: claude_code keeps Read/Grep/Bash for running git +
  ## reading code, but Write/Edit are removed so the reviewer cannot
  ## mutate the code it is judging.
  readonly: true

judge reviewer_gpt:
  ## Explicit backend pin: "openai/gpt-5.5" only resolves via claw.
  ## Without it the auto-resolver routes through claude_code, which
  ## doesn't recognise openai/* models and the schema validator fails.
  backend: "claw"
  model: "${ITERION_VIBE_MODEL_GPT:-openai/gpt-5.5}"
  reasoning_effort: "${ITERION_VIBE_EFFORT_GPT:-high}"
  output: review_output
  system: review_system
  user: review_user_gpt
  session: fresh
  ## Read-only toolset only (no write_file / file_edit): the claw
  ## reviewer can run git + read the workspace but has no structured
  ## path to edit it.
  tools: [bash, read_file, glob, grep]
  tool_max_steps: 30

agent emit:
  backend: "claude_code"
  model: "${ITERION_VIBE_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_VIBE_EFFORT_EMIT:-medium}"
  output: emit_output
  system: emit_system
  user: emit_user
  session: fresh
  ## Converge the two parallel reviewer branches: emit runs once, after
  ## BOTH reviewers complete, and reads their outputs directly.
  await: wait_all
  ## board.read to load the iterion-board skill, board.create +
  ## board.label to file findings. emit writes the report file via its
  ## ordinary claude_code tools.
  capabilities: [board.read, board.create, board.label]

## ─── Forge PR review (v0.2.0) nodes ─────────────────────────────

## Deterministic branch (no LLM): reach the forge publish step ONLY
## when a pr_url was given. Passes emit's findings + counts through so
## publish_review reads them as input.* (stable across the edge).
compute pr_gate:
  input: pr_gate_input
  output: pr_gate_output
  expr:
    has_pr: "input.pr_url != ''"
    pr_url: "input.pr_url"
    findings: "input.findings"
    total_findings: "input.total_findings"

## Skill-guided, forge-agnostic publish. claude_code so it has Bash +
## the host forge CLIs (gh / glab) and full read tools; it posts PR
## comments via the CLI/API, never edits workspace source. The per-forge
## knowledge lives in skills/forge-pr-review.md — no forge names in this
## DSL. Self-verifies by re-fetching the posted review (anti-façade).
agent publish_review:
  backend: "claude_code"
  model: "${ITERION_VIBE_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_VIBE_EFFORT_EMIT:-medium}"
  input: publish_input
  output: publish_output
  system: publish_review_system
  user: publish_review_user
  session: fresh
  ## No `interaction: human` here: unlike the reviewers' escalation contract,
  ## the publish step MUST reliably END by emitting the publish_output schema.
  ## An interactive turn let the agent finish with prose instead, so the run
  ## ended failed_resumable on a missing-fields validation even though the
  ## inline comments had already posted. The webhook always supplies a concrete
  ## pr_url, so there is nothing to ask a human about.

## Deterministic anti-façade gate (no LLM): when findings existed but
## zero inline comments landed, emit a loud banner. The board + report
## already succeeded upstream, so this informs (degraded=true) rather
## than hard-failing the run. Forge-agnostic: a pure count assertion.
tool publish_health:
  command: `TOTAL={{input.total_findings}} POSTED={{input.comments_posted}} PUBLISHED={{input.published}} REVIEW_URL={{input.review_url}} SKIPPED={{input.skipped_reason}} python3 -c "
import os, json, sys
total = int(os.environ.get('TOTAL', '0') or '0')
posted = int(os.environ.get('POSTED', '0') or '0')
review_url = os.environ.get('REVIEW_URL', '')
skipped = os.environ.get('SKIPPED', '')
degraded = total > 0 and posted == 0
if degraded:
    banner = chr(9888) + ' FORGE PUBLISH FAILED: ' + str(total) + ' finding(s) to post but 0 inline comments landed on the PR (reason: ' + (skipped or 'none given') + '). The board + markdown report still succeeded; fix the forge CLI auth and re-run with the same pr_url to publish.'
else:
    banner = 'forge publish OK: ' + str(posted) + ' inline comment(s) posted; review: ' + (review_url or 'n/a')
sys.stderr.write(banner + chr(10))
print(json.dumps({'degraded': degraded, 'banner': banner}))
"`
  input: publish_health_input
  output: publish_health_output

## ─── Workflow ───────────────────────────────────────────────────

workflow review_pr:
  entry: diff_precheck

  budget:
    ## Two read-only reviewer branches run in parallel; emit runs alone
    ## afterwards.
    max_parallel_branches: 2
    max_duration: "45m"
    max_cost_usd: 20

  ## EFFICIENCY: an empty review diff skips both LLM reviewers + emit.
  diff_precheck -> fan when not is_empty
  diff_precheck -> done when is_empty

  ## Fan out to both family reviewers.
  fan -> reviewer_claude
  fan -> reviewer_gpt

  ## Converge on emit (await: wait_all). emit reads
  ## outputs.reviewer_claude / outputs.reviewer_gpt directly, so the
  ## edges carry no data mapping.
  reviewer_claude -> emit
  reviewer_gpt -> emit

  ## emit always runs (board + markdown report). Then pr_gate decides
  ## whether to ALSO publish to a forge PR — only when pr_url is set —
  ## feeding emit's merged findings forward to the publish step.
  emit -> pr_gate with {
    pr_url: "{{vars.pr_url}}",
    findings: "{{outputs.emit.findings}}",
    total_findings: "{{outputs.emit.total_findings}}"
  }
  ## No PR target → finish after the board + report (the default,
  ## zero extra LLM cost). PR target → skill-guided forge publish.
  pr_gate -> done when not has_pr
  pr_gate -> publish_review when has_pr with {
    pr_url: "{{outputs.pr_gate.pr_url}}",
    findings: "{{outputs.pr_gate.findings}}",
    total_findings: "{{outputs.pr_gate.total_findings}}",
    workspace_dir: "{{vars.workspace_dir}}",
    base_ref: "{{vars.base_ref}}"
  }
  ## Deterministic anti-façade gate on the publish result, then done.
  publish_review -> publish_health with {
    published: "{{outputs.publish_review.published}}",
    comments_posted: "{{outputs.publish_review.comments_posted}}",
    total_findings: "{{outputs.pr_gate.total_findings}}",
    skipped_reason: "{{outputs.publish_review.skipped_reason}}",
    review_url: "{{outputs.publish_review.review_url}}"
  }
  publish_health -> done
