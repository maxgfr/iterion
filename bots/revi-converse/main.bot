## ─────────────────────────────────────────────────────────────────
## revi-converse — "Revi (converse)", an in-thread question-answerer.
##
## Sibling of review-pr (Revi). Today's webhook routing:
##   - `/revi` with NO args -> review-pr (re-review the MR).
##   - `/revi <question>`   -> revi-converse (answer the question
##                              IN THE SAME discussion thread).
##
## Stateless: each reply is one short, idempotent run. The thread is
## the conversation state (see docs/forge-conversations.md "the thread
## is the state").
##
## Shape (single LLM step + deterministic post-condition):
##
##   converse_agent  (claude_code, reads diff + question, posts reply
##                    via curl + forge_token, per skills/forge-reply.md)
##     -> converse_health  (deterministic anti-façade gate)
##     -> done
##
## The agent itself is responsible for:
##   1. Reading the question + the MR diff against base_ref's merge-base
##      (same scope discipline as Revi).
##   2. Producing a CONCISE, GROUNDED answer (file:line anchored).
##   3. Posting the answer as a REPLY in `{{vars.discussion_id}}` via
##      the forge_token (skill: forge-reply.md). Anti-trigger-loop:
##      the body MUST NOT begin with the literal `/revi` (or `/ask`)
##      token, else the bot loops forever — the skill enforces this.
##
## Read-only safety: no write tools needed beyond the curl POST that
## publishes the answer. No board writes, no source mutation.
##
## TODO (deferred): the elegant follow-up is a `forge.reply` DSL
## capability — sibling of `board.create` — opening an in-process
## `forge_reply(thread_id, body)` tool that lets iterion own the
## posting (vs raw curl in a skill). See docs/forge-conversations.md
## §A4 and the §8 note in skills/forge-reply.md.
## ─────────────────────────────────────────────────────────────────

secrets:
  ## Forge API token used to POST the answer note. Mounted as a FILE
  ## the agent passes to curl by path — never read into a prompt or
  ## echoed. `optional: true` keeps local/manual runs unaffected when
  ## the binding isn't available (the skill detects + skips posting).
  ## Same binding name as review-pr so an org-level forge_token
  ## binding (or per-webhook secret override) resolves both bots.
  forge_token:
    as: file
    optional: true

vars:
  workspace_dir: string = "${PROJECT_DIR}"

  ## Branch comparison base — same semantics as review-pr's base_ref.
  ## The agent diffs `git merge-base base_ref HEAD` to ground its
  ## answer in the actual change set. Defaults to the common
  ## integration-branch name; the webhook handler overrides it from
  ## the MR's target_branch.
  base_ref: string = "main"

  ## The pull/merge-request URL the conversation lives on. Used to
  ## derive forge host + project + iid for the reply POST. Webhook
  ## handler injects this; manual runs MUST pass it via --var.
  pr_url: string = ""

  ## The discussion thread id to reply IN. Webhook handler injects
  ## this from the parsed note (GitLab: oa.discussion_id; GitHub: the
  ## review-comment id). Empty disables posting (the agent still
  ## composes an answer for inspection in the report).
  discussion_id: string = ""

  ## The operator's original note body (raw — includes the leading
  ## `/revi <question>` slash-command). The agent strips the
  ## command prefix when echoing the question back in the answer.
  trigger_note: string = ""

  ## The question itself — the args after `/revi`. The webhook
  ## handler passes this (`cmdArgs`); the agent uses it as the
  ## primary question to answer. Empty falls back to trigger_note.
  converse_question: string = ""

  ## The forge username of the operator who asked the question.
  ## Used to address them in the answer ("Re: <replier> — …").
  replier: string = ""

## ─── Prompts ────────────────────────────────────────────────────

prompt converse_system:
  You are Revi (converse) — a senior, READ-ONLY code reviewer
  answering an operator's follow-up question on an open MR/PR. You
  are NOT performing a fresh review. You are NOT editing or
  committing code. You produce ONE focused, grounded answer and
  POST it as a reply in the existing discussion thread.

  ── SCOPE ──
  1. The MR diff against its merge-base IS the surface you reason
     about. Enumerate changed files first:
       git -C {{vars.workspace_dir}} diff --name-only $(git -C {{vars.workspace_dir}} merge-base {{vars.base_ref}} HEAD)
     Read the diff (or the relevant hunks) before answering anything
     about specific changes:
       git -C {{vars.workspace_dir}} diff $(git -C {{vars.workspace_dir}} merge-base {{vars.base_ref}} HEAD)
     You MAY read surrounding code (callers, conventions) to ground
     a claim; cite it by `file:line` when you do.
  2. The OPERATOR'S QUESTION is the steering. Answer THAT question.
     Do NOT branch into adjacent advice unless the answer genuinely
     requires it. A concise answer is a sign of mastery, not
     laziness.

  ── ANSWER SHAPE ──
  - 3-8 sentences, prose. Markdown fences (≤3 lines of code) only
    when a code quotation sharpens the answer. NO bullet-point
    essays.
  - Every concrete claim must be anchored to a `file:line` from the
    diff, OR explicitly attributed ("based on the MR description",
    "based on the earlier review comment", "from the surrounding
    code at file:line"). NO hand-wavy "this might be risky".
  - "I don't know" is acceptable when the diff genuinely doesn't say
    — name what would let you answer.

  ── POSTING ──
  Read `{{vars.workspace_dir}}/.claude/skills/forge-reply.md` for
  the forge-specific reply call (GitLab discussions/<id>/notes via
  curl + PRIVATE-TOKEN, GitHub /pulls/.../comments/<id>/replies,
  Forgejo/Gitea fallback). Derive the host + project + iid from
  `{{vars.pr_url}}`. The token comes from the file secret
  `/run/iterion/secrets/forge_token` — pass it to curl by path or
  via `$(cat …)`; NEVER read it into a prompt or echo it.

  ── ANTI-TRIGGER-LOOP (CRITICAL) ──
  The reply body MUST NOT BEGIN with the literal token `/revi` (or
  `/ask` in any case). The webhook trigger fires on a note whose
  FIRST non-whitespace token is `/revi`, so a body starting with
  it would re-fire the webhook -> infinite loop. Safe patterns:
    - Quote: `Use \`/revi\` to retry.`
    - Re-anchor: `Re-trigger via /revi.` (token not first).
    - Prepend `Re:` or `Answer:` so the body opens with prose.
  VERIFY this yourself before posting.

  ── VERIFY ──
  After the POST, re-fetch the discussion (the skill gives the call)
  and confirm a new note id appeared. Capture its URL as
  `reply_url`. A success claim without a verify call is a façade.

  ── OUTPUT ──
  Your FINAL action MUST emit the `converse_output` structured object
  with ALL fields set: posted, forge, reply_url, answer_preview,
  skipped_reason, summary. Emit it even on partial success — report
  what you did and put the reason in `summary`. Do NOT finish with a
  prose message; the run fails when the structured output is missing.

prompt converse_user:
  Workspace:           {{vars.workspace_dir}}
  Base ref:            {{vars.base_ref}}
  PR/MR URL:           {{vars.pr_url}}
  Discussion thread:   {{vars.discussion_id}}
  Replier (operator):  {{vars.replier}}

  ── Operator's question ──
  {{vars.converse_question}}

  ── Original note body (for context — includes the leading slash-command) ──
  {{vars.trigger_note}}

  Read the question, read the relevant slice of the MR diff (and any
  surrounding code you need to ground a claim), draft a concise
  grounded answer per your system prompt, POST it as a reply in the
  discussion thread per `forge-reply.md`, VERIFY by re-fetching, and
  emit `converse_output`.

prompt converse_health_system:
  Deterministic anti-façade gate (no LLM). Reads the upstream
  converse_agent's output and emits a banner the report surfaces.

## ─── Schemas ────────────────────────────────────────────────────

schema converse_output:
  ## posted: a reply note was successfully created in the thread.
  posted: bool
  ## forge: "github" | "gitlab" | "forgejo" | "unknown" (detected
  ## from pr_url host). Free-form string, not a closed DSL enum.
  forge: string
  ## reply_url: link to the posted note (from the VERIFY step).
  reply_url: string
  ## answer_preview: the first ~200 chars of the answer the bot
  ## posted, for the report (so the operator sees what landed
  ## without opening the forge). NOT the full body.
  answer_preview: string
  ## skipped_reason: non-empty when nothing was posted (token
  ## missing, forge unrecognised, thread not addressable, etc.).
  skipped_reason: string
  ## summary: one paragraph — the question, the gist of the answer,
  ## the VERIFY call evidence. A success claim without a VERIFY
  ## call is a façade flagged by the downstream health gate.
  summary: string

schema converse_health_input:
  posted: bool
  reply_url: string
  skipped_reason: string

## Deterministic anti-façade gate: when the agent claimed posted
## but produced no reply_url, surface a loud banner. Forge-agnostic
## — a pure invariant check.
schema converse_health_output:
  degraded: bool
  banner: string

## ─── Nodes ──────────────────────────────────────────────────────

agent converse_agent:
  backend: "claude_code"
  model: "${ITERION_VIBE_MODEL_CLAUDE:-claude-opus-4-8}"
  reasoning_effort: "${ITERION_VIBE_EFFORT_CONVERSE:-medium}"
  output: converse_output
  system: converse_system
  user: converse_user
  session: fresh
  ## No `interaction: human` here: an unattended webhook launch has
  ## nothing to ask a human about, and a leftover interactive turn
  ## let the agent finish with prose instead of the structured
  ## output (same lesson as review-pr's publish_review).

## Deterministic anti-façade gate (no LLM): when the agent claimed
## posted=true but produced no reply_url, emit a loud banner. The
## run still succeeds — this informs (degraded=true) rather than
## hard-failing. Forge-agnostic: pure invariant assertion.
tool converse_health:
  command: `POSTED={{input.posted}} REPLY_URL={{input.reply_url}} SKIPPED={{input.skipped_reason}} python3 -c "
import os, json, sys
posted = os.environ.get('POSTED', 'false') == 'true'
reply = os.environ.get('REPLY_URL', '')
skipped = os.environ.get('SKIPPED', '')
degraded = posted and not reply
if degraded:
    banner = chr(9888) + ' FORGE REPLY UNVERIFIED: agent claimed posted=true but emitted no reply_url. Treat as not-yet-confirmed; re-check the thread before re-triggering.'
elif not posted:
    banner = 'forge reply skipped: ' + (skipped or 'no reason given')
else:
    banner = 'forge reply OK: ' + reply
sys.stderr.write(banner + chr(10))
print(json.dumps({'degraded': degraded, 'banner': banner}))
"`
  input: converse_health_input
  output: converse_health_output

## ─── Workflow ───────────────────────────────────────────────────

workflow revi_converse:
  entry: converse_agent

  budget:
    ## One short LLM step + a deterministic gate. Conversations
    ## must feel snappy.
    max_parallel_branches: 1
    max_duration: "10m"
    max_cost_usd: 5

  converse_agent -> converse_health with {
    posted: "{{outputs.converse_agent.posted}}",
    reply_url: "{{outputs.converse_agent.reply_url}}",
    skipped_reason: "{{outputs.converse_agent.skipped_reason}}"
  }
  converse_health -> done
