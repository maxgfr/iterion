#!/bin/sh
# AppRun is the entrypoint of the AppImage. It sets up the runtime
# environment so the bundled WebKitGTK libraries are visible and then
# execs the real binary.
#
# Inspired by the standard linuxdeploy-plugin-gtk template.

HERE="$(dirname "$(readlink -f "${0}")")"

export PATH="$HERE/usr/bin:$PATH"
export LD_LIBRARY_PATH="$HERE/usr/lib:$HERE/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH"
export GDK_PIXBUF_MODULE_FILE="$HERE/usr/lib/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export GIO_MODULE_DIR="$HERE/usr/lib/gio/modules"
export GSETTINGS_SCHEMA_DIR="$HERE/usr/share/glib-2.0/schemas"

# WebKitGTK process model: tell webkit to look for its helper processes
# inside the AppDir rather than $PATH.
export WEBKIT_DISABLE_COMPOSITING_MODE=1
export WEBKIT_EXEC_PATH="$HERE/usr/lib/webkit2gtk-4.1"

# Disable WebKit's bubblewrap sandbox: it can't traverse the AppImage's
# read-only squashfs mount + bundled libs path mapping reliably across
# distros. The AppImage already executes inside the user's UID with no
# extra privileges, so the security delta is minimal in practice — the
# WebKit upstream guidance is "drop the sandbox if the host integration
# can't be trusted to provide /proc, /dev/shm and the matching seccomp
# profile". Without this the WebView reaches "ready" but renders a grey
# rectangle on Ubuntu 24.04-derived distros (Mint 22, Pop!_OS 24).
export WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1

exec "$HERE/usr/bin/iterion-desktop" "$@"
