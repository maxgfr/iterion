# Security: don't run install scripts by default (prevent supply chain attacks)
ignore-scripts=true
# Security: strict peer dependencies
strict-peer-dependencies=true
# Security: verify package integrity
resolution-mode=highest
# Security: don't allow arbitrary pre/post scripts
enable-pre-post-scripts=false
# Audit: auto-audit on install
audit=true
# Lockfile
prefer-frozen-lockfile=true
