# Example env file for `task cloud:up` / `docker compose -f docker-compose.cloud.yml up`.
# Copy to .env and fill in. Values left empty fall back to the safe-but-
# insecure dev defaults baked into docker-compose.cloud.yml — fine for
# smoke tests, ABSOLUTELY NOT fine for any environment that reaches the
# public internet.

# === Auth foundation (REQUIRED in production) ========================
# Generate with: openssl rand -base64 48
ITERION_JWT_SECRET=
# Generate with: openssl rand -base64 32  (must decode to exactly 32 bytes)
ITERION_SECRETS_KEY=

# First-boot super-admin. The server prints a one-time random password
# at WARN level on first start when the users collection is empty;
# change it on first login.
ITERION_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Sign-up policy. invite_only (default) requires an invitation token
# from a team admin; open auto-creates a personal team for every new
# email registered.
ITERION_SIGNUP_MODE=invite_only

# Externally-reachable origin used to build OIDC redirect URIs.
# When you front the server with an Ingress + TLS, set this to the
# public hostname (e.g. https://iterion.example.com).
ITERION_PUBLIC_URL=http://localhost:4891

# Cookie security. Keep true in production (HTTPS-only). Set false
# only for HTTP local development.
ITERION_COOKIE_SECURE=false

# === SSO providers (all optional) ====================================
# Each provider is opt-in via the *_ENABLED flag. The client_id +
# client_secret pair is registered with the IdP under a redirect URI
# of $ITERION_PUBLIC_URL/api/auth/oidc/<name>/callback.

ITERION_OIDC_GOOGLE_ENABLED=false
ITERION_OIDC_GOOGLE_CLIENT_ID=
ITERION_OIDC_GOOGLE_CLIENT_SECRET=

ITERION_OIDC_GITHUB_ENABLED=false
ITERION_OIDC_GITHUB_CLIENT_ID=
ITERION_OIDC_GITHUB_CLIENT_SECRET=

# Generic OIDC (Keycloak, Auth0, Azure AD, Okta, …)
ITERION_OIDC_GENERIC_ENABLED=false
ITERION_OIDC_GENERIC_ISSUER_URL=
ITERION_OIDC_GENERIC_CLIENT_ID=
ITERION_OIDC_GENERIC_CLIENT_SECRET=

# === OAuth-forfait (Phase D) =========================================
# Public OAuth client ids the server uses to refresh user-supplied
# Claude Code / ChatGPT subscription tokens. Empty disables refresh
# of that kind (users have to re-paste credentials.json on expiry).
ITERION_OAUTH_FORFAIT_ANTHROPIC_CLIENT_ID=
ITERION_OAUTH_FORFAIT_CODEX_CLIENT_ID=

# === Env-fallback LLM credentials (only used when no BYOK key) =======
# In cloud mode users register their keys in the admin UI; the values
# below are consulted only when a workflow requests a provider with
# no team-scoped key configured. Leave empty to make BYOK strict.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
